# Google Analytics 4
# Get this from Google Analytics: Admin > Property > Data Streams > Measurement ID
PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity
# Get this from clarity.microsoft.com after creating a project
PUBLIC_CLARITY_ID=your-clarity-project-id

# reCAPTCHA (for contact/subscription forms)
# Get these from https://www.google.com/recaptcha/admin
PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# Mailchimp (for email subscriptions)
# Get these from your Mailchimp account settings
PUBLIC_MAILCHIMP_AUDIENCE_ID=your-audience-id
PUBLIC_MAILCHIMP_SERVER=your-server-prefix

# Optional: Sentry for error tracking
# PUBLIC_SENTRY_DSN=your-sentry-dsn
