---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_URL } from '../consts';
import { Image } from 'astro:assets';
import SEOSchema from '../components/SEOSchema.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, seoTitle, description, pubDate, updatedDate, heroImage, category, faqs = [] } = Astro.props;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === category && p.data.title !== title && !p.data.hidden)
  .slice(0, 3);
---

<BaseLayout title={seoTitle || title} description={description} author={SITE_AUTHOR} publishedDate={pubDate} updatedDate={updatedDate} robotsMeta="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, noodp" theme="dark">
	<SEOSchema 
		type="BlogPosting" 
		title={title} 
		description={description} 
		image={heroImage?.src ? `${SITE_URL}${heroImage.src}` : undefined}
		publishedDate={pubDate}
		updatedDate={updatedDate}
		faqs={faqs}
	/>
	<main class="flex-grow docs-site-container border-x px-4 md:px-6 py-8 md:py-12 lg:py-16">
		<article class="prose prose-base md:prose-lg lg:prose-xl max-w-4xl mx-auto">
			<div class="w-full max-w-3xl mx-auto mb-6 md:mb-8">
				{heroImage && (
					<Image 
						width={1020} 
						height={510} 
						src={heroImage} 
						alt={title} 
						class="w-full object-cover rounded-xl md:rounded-2xl shadow-lg border border-border" 
						loading="eager" 
						fetchpriority="high"
						decoding="async" 
					/>
				)}
			</div>
			<div>
				<div class="text-center mb-8 md:mb-12">
					<div class="text-xs md:text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3 md:mb-4">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="italic mt-1 text-[10px] md:text-xs">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<h1 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-extrabold text-foreground tracking-tight leading-tight px-2">{title}</h1>
					<div class="flex items-center justify-center gap-2 md:gap-3 mt-4 md:mt-6">
						<div class="w-8 md:w-10 h-8 md:h-10 rounded-full bg-gradient-to-br from-primary to-emerald-500 flex items-center justify-center text-white font-black text-xs md:text-sm flex-shrink-0" aria-hidden="true">
							{SITE_AUTHOR.charAt(0).toUpperCase()}
						</div>
						<div class="text-left">
							<p class="text-xs md:text-sm font-bold text-foreground">{SITE_AUTHOR} — Hustle Teacher</p>
							<p class="text-[10px] md:text-xs text-muted-foreground"><FormattedDate date={pubDate} /></p>
						</div>
					</div>
					<hr class="border-t border-border mt-6 md:mt-8" />
				</div>

				<div class="blog-content px-1 md:px-0">
					<slot />
				</div>
				
				<div class="mt-12 md:mt-16 p-6 md:p-8 rounded-2xl md:rounded-3xl bg-gradient-to-r from-secondary/40 to-background border border-border flex flex-col md:flex-row gap-5 md:gap-8 items-center md:items-start shadow-sm relative overflow-hidden">
					<div class="absolute -top-4 -right-4 text-primary/5 pointer-events-none">
						<svg class="w-48 h-48" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.570 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
					</div>
					<div class="z-10 w-16 md:w-24 h-16 md:h-24 rounded-xl md:rounded-2xl bg-gradient-to-br from-primary to-emerald-500 flex items-center justify-center text-white font-black text-2xl md:text-3xl shadow-xl transform rotate-3 flex-shrink-0">
						{SITE_AUTHOR.charAt(0).toUpperCase()}
					</div>
					<div class="text-center md:text-left">
						<h3 class="text-base md:text-xl font-bold text-foreground mb-2">About the Author: {SITE_AUTHOR}</h3>
						<p class="text-sm md:text-base text-muted-foreground leading-relaxed mb-3 md:mb-4">
							{SITE_AUTHOR} is a digital entrepreneur and the founder of <strong>Hustle Teacher</strong>. With years of experience in online business, he specializes in helping students and beginners build sustainable income streams through proven side hustles.
						</p>
						<div class="flex flex-wrap justify-center md:justify-start gap-3 md:gap-4">
							<a href="/about/" class="text-xs md:text-sm font-bold text-primary hover:underline">Full Bio →</a>
							<a href="/" class="text-xs md:text-sm font-bold text-primary hover:underline">More Guides →</a>
						</div>
					</div>
				</div>
			</div>
		</article>

		{relatedPosts.length > 0 && (
			<section class="max-w-4xl mx-auto px-0 pb-12 md:pb-16 mt-12 md:mt-16">
				<hr class="border-t border-border mb-8 md:mb-12" />
				<h2 class="text-xl md:text-2xl font-bold text-foreground mb-6 md:mb-8">More Guides in This Category</h2>
				<div class="grid gap-4 md:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
					{relatedPosts.map(post => (
						<a
							href={`/blog/${post.id}/`}
							class="group block rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-lg transition-all duration-300 overflow-hidden"
						>
							{post.data.heroImage && (
								<div class="aspect-video overflow-hidden">
									<Image
										width={600}
										height={338}
										src={post.data.heroImage}
										alt={post.data.title}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
										decoding="async"
									/>
								</div>
							)}
							<div class="p-4 md:p-5">
								<h3 class="text-sm md:text-base font-bold text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2 mb-2">{post.data.title}</h3>
								<p class="text-xs md:text-sm text-muted-foreground line-clamp-2">{post.data.description}</p>
								<span class="inline-flex items-center text-[10px] md:text-xs font-bold text-primary mt-3 group-hover:translate-x-1 transition-transform">Read guide →</span>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</main>
</BaseLayout>

<style>
	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		color: var(--foreground);
	}
	.prose :global(p),
	.prose :global(li),
	.prose :global(blockquote) {
		color: var(--foreground);
	}
	.prose :global(blockquote) {
		border-left: 4px solid hsl(var(--primary));
		background: linear-gradient(to right, hsla(var(--primary), 0.1), transparent);
		padding: 1rem 1.5rem;
		margin: 1.5rem 0;
		font-style: italic;
		border-radius: 0 8px 8px 0;
	}
	.prose :global(h2) {
		font-size: 1.5rem;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}
	.prose :global(h3) {
		font-size: 1.25rem;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
	}
	.prose :global(p) {
		font-size: 0.95rem;
		line-height: 1.75;
		margin-bottom: 1.25rem;
	}
	.prose :global(ul) {
		list-style: none;
		padding-left: 0;
	}
	.prose :global(ul > li) {
		padding-left: 1.75rem;
		margin-bottom: 0.75rem;
		position: relative;
	}
	.prose :global(ul > li::before) {
		content: "✅";
		position: absolute;
		left: 0;
		top: 0.1rem;
		font-size: 1.1rem;
	}
	.prose :global(li) {
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.prose :global(strong) {
		color: hsl(var(--foreground));
		font-weight: 800;
	}
	.prose :global(img) {
		border-radius: 12px;
		box-shadow: 0 8px 30px rgba(0,0,0,0.12);
		border: 1px solid hsl(var(--border));
		max-width: 80%;
		margin: 2.5rem auto;
		display: block;
	}
	@media (min-width: 768px) {
		.prose :global(h2) {
			font-size: 1.875rem;
		}
		.prose :global(h3) {
			font-size: 1.5rem;
		}
		.prose :global(p),
		.prose :global(li) {
			font-size: 1rem;
		}
	}
</style>
