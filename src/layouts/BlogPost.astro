---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_URL } from '../consts';
import { Image } from 'astro:assets';
import SEOSchema from '../components/SEOSchema.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, seoTitle, description, pubDate, updatedDate, heroImage, category, faqs = [] } = Astro.props;

// Fetch related posts from the same category
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === category && p.data.title !== title)
  .slice(0, 3);
---

<BaseLayout title={seoTitle || title} description={description} author={SITE_AUTHOR} publishedDate={pubDate} updatedDate={updatedDate} robotsMeta="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, noodp" theme="light">
	{/* Inject Article Schema with FAQ if available */}
	<SEOSchema 
		type="BlogPosting" 
		title={title} 
		description={description} 
		image={heroImage?.src ? `${SITE_URL}${heroImage.src}` : undefined}
		publishedDate={pubDate}
		updatedDate={updatedDate}
		faqs={faqs}
	/>
	<main class="flex-grow docs-site-container border-x px-4 py-8 md:py-16">
		<article class="prose prose-base md:prose-lg max-w-4xl mx-auto">
			<div class="w-full mb-8">
				{heroImage && (
					<Image 
						width={1020} 
						height={510} 
						src={heroImage} 
						alt={title} 
						class="w-full object-cover rounded-2xl shadow-lg border border-border" 
						loading="eager" 
						fetchpriority="high"
						decoding="async" 
					/>
				)}
			</div>
			<div>
				<div class="text-center mb-12">
					<div class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<div class="italic mt-1">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					<h1 class="text-3xl md:text-5xl font-extrabold text-foreground tracking-tight leading-tight">{title}</h1>
					<!-- Author byline -->
					<div class="flex items-center justify-center gap-3 mt-6">
						<div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary to-emerald-500 flex items-center justify-center text-white font-black text-sm flex-shrink-0" aria-hidden="true">
							{SITE_AUTHOR.charAt(0).toUpperCase()}
						</div>
						<div class="text-left">
							<p class="text-sm font-bold text-foreground">{SITE_AUTHOR} — Hustle Teacher</p>
							<p class="text-xs text-muted-foreground"><FormattedDate date={pubDate} /></p>
						</div>
					</div>
					<hr class="border-t border-border mt-8" />
				</div>

				{/* Affiliate Disclaimer */}
				<div class="mb-10 p-4 rounded-xl bg-secondary/30 border border-border text-xs text-muted-foreground italic">
					<strong>Affiliate Disclosure:</strong> This post may contain affiliate links, which means we may receive a commission, at no cost to you, if you make a purchase through a link. We only recommend products we believe in.
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-[1fr_250px] gap-12 items-start">
					<div class="blog-content">
						<slot />
					</div>
					
					{/* Sticky Table of Contents for Desktop */}
					<aside class="hidden lg:block sticky top-24 self-start">
						<div class="p-6 rounded-2xl bg-card border border-border">
							<h3 class="text-sm font-bold uppercase tracking-widest text-foreground mb-4">Table of Contents</h3>
							<div id="toc" class="text-sm space-y-3 text-muted-foreground">
								{/* TOC will be hydrated via client-side script if needed or plain CSS */}
								<ul class="list-none p-0 m-0 space-y-2">
									<li class="hover:text-primary transition-colors cursor-pointer"><a href="#intro">Introduction</a></li>
									<li class="hover:text-primary transition-colors cursor-pointer"><a href="#guide">Step-by-Step Guide</a></li>
									<li class="hover:text-primary transition-colors cursor-pointer"><a href="#monetization">Monetization</a></li>
									<li class="hover:text-primary transition-colors cursor-pointer"><a href="#tools">Recommended Tools</a></li>
									<li class="hover:text-primary transition-colors cursor-pointer"><a href="#faq">FAQs</a></li>
								</ul>
							</div>
						</div>
					</aside>
				</div>
				
				{/* Author Box (E-E-A-T) */}
				<div class="mt-16 p-8 rounded-3xl bg-secondary/20 border border-border flex flex-col md:flex-row gap-8 items-center md:items-start">
					<div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-primary to-emerald-500 flex items-center justify-center text-white font-black text-3xl shadow-xl transform rotate-3">
						{SITE_AUTHOR.charAt(0).toUpperCase()}
					</div>
					<div class="text-center md:text-left">
						<h3 class="text-xl font-bold text-foreground mb-2">About the Author: {SITE_AUTHOR}</h3>
						<p class="text-muted-foreground leading-relaxed mb-4">
							{SITE_AUTHOR} is a digital entrepreneur and the founder of <strong>Hustle Teacher</strong>. With years of experience in online business, he specializes in helping students and beginners build sustainable income streams through proven side hustles.
						</p>
						<div class="flex flex-wrap justify-center md:justify-start gap-4">
							<a href="/about" class="text-sm font-bold text-primary hover:underline">Full Bio →</a>
							<a href="/" class="text-sm font-bold text-primary hover:underline">More Guides →</a>
						</div>
					</div>
				</div>
			</div>
		</article>

		<!-- Related Posts Section: fixes orphan pages and internal link issues -->
		{relatedPosts.length > 0 && (
			<section class="max-w-4xl mx-auto px-0 pb-16 mt-16">
				<hr class="border-t border-border mb-12" />
				<h2 class="text-2xl font-bold text-foreground mb-8">More Guides in This Category</h2>
				<div class="grid gap-6 md:grid-cols-3">
					{relatedPosts.map(post => (
						<a
							href={`/blog/${post.id}/`}
							class="group block rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-lg transition-all duration-300 overflow-hidden"
						>
							{post.data.heroImage && (
								<div class="aspect-video overflow-hidden">
									<Image
										width={600}
										height={338}
										src={post.data.heroImage}
										alt={post.data.title}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
										decoding="async"
									/>
								</div>
							)}
							<div class="p-5">
								<h3 class="text-base font-bold text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2">{post.data.title}</h3>
								<p class="text-sm text-muted-foreground mt-2 line-clamp-2">{post.data.description}</p>
								<span class="inline-flex items-center text-xs font-bold text-primary mt-4 group-hover:translate-x-1 transition-transform">Read guide →</span>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</main>
</BaseLayout>

<style>
	.prose {
		color: rgb(var(--gray-dark));
	}
	.hero-image img {
		display: block;
		margin: 0 auto;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
	}
</style>
