---
/**
 * BaseLayout.astro
 * 
 * A global layout component that consolidates BaseHead + Header + Footer.
 * Every page should use this layout instead of manually importing those three.
 * 
 * Usage:
 *   <BaseLayout title="Page Title" description="Page description">
 *     <main>...page content...</main>
 *   </BaseLayout>
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { ImageMetadata } from 'astro';
import '../styles/starwind.css';

interface Props {
	title: string;
	description: string;
	image?: string | ImageMetadata;
	author?: string;
	publishedDate?: Date;
	updatedDate?: Date;
	/** Extra classes applied to <body> e.g. a specific page color scheme */
	bodyClass?: string;
	/** Custom robots meta tag content forwarded to BaseHead */
	robotsMeta?: string;
	/** Theme of the page: 'light' or 'dark' */
	theme?: 'light' | 'dark';
}

const {
	title,
	description,
	image,
	author,
	publishedDate,
	updatedDate,
	bodyClass = '',
	robotsMeta,
	theme = 'dark',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			author={author}
			publishedDate={publishedDate}
			updatedDate={updatedDate}
			robotsMeta={robotsMeta}
		/>
		<!-- Named slot for per-page head injections (SEO schemas, preloads, etc.) -->
		<slot name="head" />
	</head>
		<body class={`bg-background text-foreground scheme-dark min-h-screen flex flex-col ${bodyClass}`}>
		<div class="cursor" id="cursor"></div>
		<div class="cursor-dot" id="cursorDot"></div>
		<Header />
		<slot />
		<Footer />
		<script is:inline>
			// ── CUSTOM CURSOR ────────────────────────────────────────
			const cursor    = document.getElementById('cursor');
			const cursorDot = document.getElementById('cursorDot');
			document.addEventListener('mousemove', e => {
			  if (cursor && cursorDot) {
			    cursor.style.left    = (e.clientX - 14) + 'px';
			    cursor.style.top     = (e.clientY - 14) + 'px';
			    cursorDot.style.left = (e.clientX - 3)  + 'px';
			    cursorDot.style.top  = (e.clientY - 3)  + 'px';
			  }
			});
			document.addEventListener('mousedown', () => { if (cursor) cursor.style.transform = 'scale(0.8)'; });
			document.addEventListener('mouseup',   () => { if (cursor) cursor.style.transform = 'scale(1)'; });

			// ── SCROLL REVEAL ────────────────────────────────────────
			const reveals = document.querySelectorAll('.reveal');
			const revealObserver = new IntersectionObserver((entries) => {
			  entries.forEach(entry => {
			    if (entry.isIntersecting) entry.target.classList.add('visible');
			  });
			}, { threshold: 0.15 });
			reveals.forEach(el => revealObserver.observe(el));

			// ── COIN BURST ON CLICK (desktop pointer only) ──────────
			if (!window.matchMedia('(pointer: coarse)').matches) {
			  document.addEventListener('click', e => {
			    for (let i = 0; i < 8; i++) {
			      const coin = document.createElement('div');
			      coin.style.cssText = `
			        position:fixed;left:${e.clientX-15}px;top:${e.clientY-15}px;
			        width:30px;height:30px;border-radius:50%;
			        background:radial-gradient(circle at 35% 35%,#FFD700,#8B6914);
			        border:3px solid #0a0a0a;display:flex;align-items:center;
			        justify-content:center;font-family:Cinzel,serif;font-weight:700;
			        font-size:0.7rem;color:#0a0a0a;z-index:9998;pointer-events:none;
			      `;
			      coin.textContent = '$';
			      document.body.appendChild(coin);
			      const angle = (Math.PI * 2 / 8) * i;
			      const speed = Math.random() * 3 + 2;
			      let vx = Math.cos(angle) * speed;
			      let vy = Math.sin(angle) * speed;
			      let x = e.clientX - 15, y = e.clientY - 15, opacity = 1;
			      (function animCoin() {
			        x += vx; y += vy; vy += 0.2; opacity -= 0.025;
			        coin.style.left    = x + 'px';
			        coin.style.top     = y + 'px';
			        coin.style.opacity = opacity;
			        if (opacity > 0) requestAnimationFrame(animCoin);
			        else coin.remove();
			      })();
			    }
			  });
			}
		</script>
	</body>
</html>
