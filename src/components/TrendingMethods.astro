---
const trendingItems = [
  { name: "Dropshipping", icon: "📦", glow: "from-blue-500" },
  { name: "Crypto Trading", icon: "📈", glow: "from-green-500" },
  { name: "AI Automation", icon: "🤖", glow: "from-purple-500" },
  { name: "YouTube Shorts", icon: "📱", glow: "from-red-500" },
  { name: "SaaS Builders", icon: "💻", glow: "from-sky-500" },
  { name: "Digital Products", icon: "🎨", glow: "from-fuchsia-500" },
];
---

<section class="docs-site-container border-x py-16 bg-gradient-to-b from-background to-card/20">
    <div class="mx-auto max-w-7xl px-4">
        <div class="flex items-center justify-center gap-3 mb-10 animate-fade-in-up">
            <span class="text-3xl animate-pulse">🔥</span>
            <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight text-foreground">
                Trending Right Now
            </h2>
            <span class="text-3xl animate-pulse">🔥</span>
        </div>

        <div class="flex flex-wrap justify-center gap-4">
            {trendingItems.map((item, i) => (
                <a 
                    href="#pathways"
                    class={`group relative flex items-center gap-3 px-6 py-4 bg-card border border-border rounded-full hover:border-primary/50 transition-all duration-300 hover:scale-110 hover:shadow-[0_0_20px_rgba(0,0,0,0.1)] hover:shadow-primary/20 animate-zoom-in cursor-pointer`}
                    style={`animation-delay: ${i * 100}ms;`}
                >
                    <div class={`absolute inset-0 rounded-full opacity-0 group-hover:opacity-10 bg-gradient-to-r ${item.glow} to-transparent transition-opacity duration-300`}></div>
                    <span class="text-2xl relative z-10 group-hover:animate-bounce">{item.icon}</span>
                    <span class="font-bold text-foreground relative z-10 tracking-tight">{item.name}</span>
                </a>
            ))}
        </div>
    </div>
</section>
