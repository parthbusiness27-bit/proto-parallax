---
interface Props {
	items: string[];
	title?: string;
}

const { 
	items = [], 
	title = "What you'll learn in this guide" 
} = Astro.props;
---

<div class="my-8 p-6 rounded-2xl bg-gradient-to-br from-card to-secondary/30 border border-border shadow-sm">
	<h3 class="text-xl font-bold text-foreground mb-4 flex items-center gap-2">
		<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
		{title}
	</h3>
	<ul class="grid gap-3 sm:grid-cols-2 list-none p-0 m-0">
		{items.map((item) => (
			<li class="flex items-start gap-3 text-muted-foreground m-0">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary mt-0.5 flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
				<span class="text-sm md:text-base">{item}</span>
			</li>
		))}
	</ul>
</div>
