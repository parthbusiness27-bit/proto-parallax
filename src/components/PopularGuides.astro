---
const guides = [
  { title: "How To Start Dropshipping", description: "Learn the exact step-by-step process to build your first store.", icon: "🛍️", slug: "ecommerce" },
  { title: "How To Start Freelancing", description: "Land your first high-paying client in 30 days.", icon: "💻", slug: "freelancing" },
  { title: "How To Make Money With YouTube", description: "Grow your channel and monetize your audience.", icon: "▶️", slug: "content-creator" },
  { title: "Best Side Hustles For Beginners", description: "Easy and quick ways to start earning your first $100.", icon: "🚀", slug: "side-hustles" },
  { title: "Start Affiliate Marketing", description: "Promote products and earn passive commissions.", icon: "🔗", slug: "affiliate", image: "affiliate_marketing_guide.png" },
  { title: "Become a Virtual Assistant", description: "Learn how to provide admin support from home.", icon: "☎️", slug: "virtual-assistant", image: "virtual_assistant_guide.png" },
  { title: "Create & Sell Digital Products", description: "Turn your knowledge into courses and templates.", icon: "📦", slug: "digital-products", image: "digital_products_guide.png" },
  { title: "Make Money with AI Automation", description: "Use AI bots and scripts to automate businesses.", icon: "🤖", slug: "ai-income", image: "ai_automation_guide.png" }
];
import { Image } from 'astro:assets';
import affiliateImg from '../assets/affiliate_marketing_guide.png';
import vaImg from '../assets/virtual_assistant_guide.png';
import digitalImg from '../assets/digital_products_guide.png';
import aiImg from '../assets/ai_automation_guide.png';

const imageMap: Record<string, any> = {
    "affiliate_marketing_guide.png": affiliateImg,
    "virtual_assistant_guide.png": vaImg,
    "digital_products_guide.png": digitalImg,
    "ai_automation_guide.png": aiImg
};
---

<section class="docs-site-container border-x py-24 bg-card/30">
    <div class="mx-auto max-w-7xl px-4">
        <div class="text-center mb-16 animate-fade-in-up">
            <h2 class="text-3xl md:text-5xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-foreground to-foreground/70 mb-4 tracking-tight">
                Popular Guides
            </h2>
            <p class="text-muted-foreground text-xl max-w-2xl mx-auto">
                Step-by-step blueprints to start your online business.
            </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {guides.map((guide, i) => (
                <a href={guide.slug ? `/blog/category/${guide.slug}` : "/blog"} class={`group block p-6 bg-card border border-border rounded-2xl hover:border-primary/50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 animate-fade-in-up`} style={`animation-delay: ${i * 100}ms;`}>
                    {guide.image && imageMap[guide.image] ? (
                        <div class="mb-4 overflow-hidden rounded-xl aspect-video w-full bg-muted">
                            <Image 
                                src={imageMap[guide.image]} 
                                alt={`${guide.title} overview graphic`}
                                width={400}
                                height={225}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    ) : (
                        <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">{guide.icon}</div>
                    )}
                    <h3 class="text-xl font-bold mb-2 text-foreground group-hover:text-primary transition-colors">{guide.title}</h3>
                    <p class="text-muted-foreground text-sm">{guide.description}</p>
                </a>
            ))}
        </div>
    </div>
</section>
