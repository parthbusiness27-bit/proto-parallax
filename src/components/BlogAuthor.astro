---
interface Props {
	name: string;
	bio: string;
	avatar: string;
	expertise: string[];
}

const { name, bio, avatar, expertise } = Astro.props;
---

<div class="bg-card border border-border rounded-2xl p-6 md:p-8 mt-12 md:mt-16 animate-fade-in">
	<div class="flex flex-col md:flex-row gap-6 items-center md:items-start text-center md:text-left">
		<div class="relative group">
			<div class="absolute -inset-1 bg-gradient-to-r from-primary to-emerald-500 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
			<img 
				src={avatar} 
				alt={name} 
				class="relative w-24 h-24 md:w-32 md:h-32 rounded-full object-cover border-4 border-background shadow-xl"
			/>
		</div>
		<div class="flex-1">
			<div class="flex flex-col md:flex-row md:items-center gap-2 mb-3">
				<h3 class="text-xl md:text-2xl font-bold text-foreground">{name}</h3>
				<div class="flex flex-wrap gap-2 justify-center md:justify-start">
					{expertise.map((skill) => (
						<span class="text-[10px] md:text-xs font-bold uppercase tracking-wider bg-primary/10 text-primary px-2 py-0.5 rounded-full border border-primary/20">
							{skill}
						</span>
					))}
				</div>
			</div>
			<p class="text-sm md:text-base text-muted-foreground leading-relaxed mb-4">
				{bio}
			</p>
			<div class="flex justify-center md:justify-start gap-4">
				<a href="https://twitter.com/hustleteacher" class="text-muted-foreground hover:text-primary transition-colors">
					<span class="sr-only">Twitter</span>
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.25h-6.657l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
				</a>
				<a href="https://linkedin.com/in/hustleteacher" class="text-muted-foreground hover:text-primary transition-colors">
					<span class="sr-only">LinkedIn</span>
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
				</a>
			</div>
		</div>
	</div>
</div>
