---
import { Image } from 'astro:assets';
---

<section id="success-stories" class="docs-site-container border-x py-16 md:py-24 bg-card/50 overflow-hidden relative">
    <div class="mx-auto max-w-7xl px-4 relative z-10">
        <div class="text-center mb-12 md:mb-16 animate-fade-in-up">
            <div class="inline-flex items-center gap-2 px-3 py-1 mb-4 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-sm font-bold tracking-wide">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                VERIFIED WINS
            </div>
            <h2 class="text-3xl md:text-5xl font-extrabold text-foreground mb-4 tracking-tight">
                They Made Their First <span class="bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 to-emerald-600">$100</span>.
            </h2>
            <p class="text-muted-foreground text-lg md:text-xl max-w-2xl mx-auto">
                Real people from our community who took action. Read their stories or submit your own!
            </p>
        </div>

        <div class="relative max-w-7xl mx-auto">
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-4">
                
                <!-- Story Card 1 (Teenager) -->
                <div class="bg-black border border-border rounded-2xl p-6 md:p-8 hover:border-emerald-500/50 hover:shadow-[0_0_30px_rgba(16,185,129,0.1)] transition-all duration-300 relative group flex flex-col h-full">
                    <div class="absolute top-6 right-6 opacity-20 group-hover:opacity-100 transition-opacity flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-border group-hover:border-emerald-500/50 transition-colors bg-muted flex-shrink-0">
                            <img src="/assets/success-kid.jpg" alt="Rahul" class="w-full h-full object-cover" loading="lazy" />
                        </div>
                        <div>
                            <h3 class="font-bold text-foreground text-lg">Rahul S.</h3>
                            <p class="text-sm text-primary tracking-wide">Video Editor</p>
                        </div>
                    </div>
                    <blockquote class="text-muted-foreground italic mb-6 text-[15px] leading-relaxed flex-grow">
                        "I'm just 16 and thought freelancing was only for adults. I used the Short-Form Video Creation guide, learned Premiere Pro over the weekend, and landed a local client on Monday. Made my first $100 before my mid-term exams!"
                    </blockquote>
                    <div class="flex items-center gap-2 mt-auto">
                        <span class="inline-block px-3 py-1 bg-muted rounded-full text-xs font-semibold text-foreground">#ContentCreation</span>
                    </div>
                </div>

                <!-- Story Card 2 (9-to-5) -->
                <div class="bg-black border border-border rounded-2xl p-6 md:p-8 hover:border-emerald-500/50 hover:shadow-[0_0_30px_rgba(16,185,129,0.1)] transition-all duration-300 relative group flex flex-col h-full">
                    <div class="absolute top-6 right-6 opacity-20 group-hover:opacity-100 transition-opacity flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-border group-hover:border-emerald-500/50 transition-colors bg-muted flex-shrink-0">
                            <img src="/assets/success-worker.jpg" alt="Aman" class="w-full h-full object-cover" loading="lazy" />
                        </div>
                        <div>
                            <h3 class="font-bold text-foreground text-lg">Aman P.</h3>
                            <p class="text-sm text-primary tracking-wide">IT Consultant</p>
                        </div>
                    </div>
                    <blockquote class="text-muted-foreground italic mb-6 text-[15px] leading-relaxed flex-grow">
                        "Working 9-to-5 left me exhausted. But following the AI Automation Agency guide, I built a simple automated outreach bot for a real estate agent. It took me 3 nights, and he paid me $300 upfront. This completely shifted my mindset."
                    </blockquote>
                    <div class="flex items-center gap-2 mt-auto">
                        <span class="inline-block px-3 py-1 bg-muted rounded-full text-xs font-semibold text-foreground">#Agencies</span>
                    </div>
                </div>

                <!-- Story Card 3 (Housewife) -->
                <div class="bg-black border border-border rounded-2xl p-6 md:p-8 hover:border-emerald-500/50 hover:shadow-[0_0_30px_rgba(16,185,129,0.1)] transition-all duration-300 relative group flex flex-col h-full">
                    <div class="absolute top-6 right-6 opacity-20 group-hover:opacity-100 transition-opacity flex items-center justify-center w-12 h-12 rounded-full bg-emerald-500/20 text-emerald-400">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    </div>
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-border group-hover:border-emerald-500/50 transition-colors bg-muted flex-shrink-0">
                            <img src="/assets/success-housewife.jpg" alt="Priya" class="w-full h-full object-cover" loading="lazy" />
                        </div>
                        <div>
                            <h3 class="font-bold text-foreground text-lg">Priya D.</h3>
                            <p class="text-sm text-primary tracking-wide">Digital Creator</p>
                        </div>
                    </div>
                    <blockquote class="text-muted-foreground italic mb-6 text-[15px] leading-relaxed flex-grow">
                        "I wanted financial independence without compromising my time at home. The Digital Products guide taught me how to sell Notion Templates. Yesterday, I woke up to 8 sales notifications totalling $120. Best feeling ever!"
                    </blockquote>
                    <div class="flex items-center gap-2 mt-auto">
                        <span class="inline-block px-3 py-1 bg-muted rounded-full text-xs font-semibold text-foreground">#DigitalProducts</span>
                    </div>
                </div>

            </div>
        </div>

        <div class="text-center mt-8 animate-fade-in-up">
            <a href="/contact/" class="inline-flex items-center justify-center rounded-xl bg-muted hover:bg-muted/80 text-foreground h-12 px-8 font-semibold transition-colors duration-300 group">
                Submit Your Story
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="ml-2 group-hover:translate-x-1 transition-transform" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
            <p class="mt-3 text-xs text-muted-foreground">Every published story receives a direct feature link!</p>
        </div>
    </div>
</section>
