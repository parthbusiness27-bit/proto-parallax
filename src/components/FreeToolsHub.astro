---
const freeTools = [
  { name: "Side Hustle Idea Generator", icon: "💡", link: "/tools/side-hustle-idea-generator/" },
  { name: "YouTube Earnings Calculator", icon: "💰", link: "/tools/youtube-earnings-calculator/" },
  { name: "Blog Title Generator", icon: "✍️", link: "/tools/blog-title-generator/" },
  { name: "Affiliate Profit Calculator", icon: "📊", link: "/tools/affiliate-commission-calculator/" }
];

const moreTools = [
  { name: "SEO Keyword Generator", icon: "🔎", link: "/tools/hashtag-generator/" },
  { name: "Content Idea Generator", icon: "🧠", link: "/tools/content-idea-generator/" },
  { name: "YouTube Title Generator", icon: "🎬", link: "/tools/youtube-title-generator/" },
  { name: "Dropshipping Profit Calc", icon: "🚢", link: "/tools/dropshipping-profit-calculator/" }
];
---

<section class="docs-site-container border-x py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4">
        <div class="text-center mb-12 md:mb-16 animate-fade-in-up">
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">
                Free <span class="bg-gradient-to-r from-primary to-emerald-500 bg-clip-text text-transparent">Tools</span>
            </h2>
            <p class="text-muted-foreground text-lg md:text-xl max-w-2xl mx-auto">
                Calculate your earnings and generate ideas instantly.
            </p>
        </div>

        <!-- Free Tools Section -->
        <div class="mb-10 md:mb-16">
            <h3 class="text-xl md:text-2xl font-bold mb-6 md:mb-8 text-foreground flex items-center gap-3">
                <span class="bg-primary/20 text-primary w-9 h-9 md:w-10 md:h-10 rounded-full flex items-center justify-center text-lg md:text-xl">🎁</span>
                Calculators & Generators
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
                {freeTools.map((tool, i) => (
                    <a href={tool.link} class={`group flex items-center gap-3 md:gap-4 p-3 md:p-4 bg-card border border-border rounded-xl hover:border-emerald-500/50 transition-all duration-300 hover:shadow-md hover:-translate-y-1 animate-fade-in-up`} style={`animation-delay: ${i * 100}ms;`}>
                        <div class="text-xl md:text-2xl bg-emerald-500/10 text-emerald-500 p-2 md:p-3 rounded-lg group-hover:bg-emerald-500/20 transition-colors flex-shrink-0">{tool.icon}</div>
                        <span class="font-bold text-foreground text-xs md:text-sm leading-tight">{tool.name}</span>
                    </a>
                ))}
            </div>
        </div>

        <!-- More Free Tools Section -->
        <div>
            <h3 class="text-xl md:text-2xl font-bold mb-6 md:mb-8 flex items-center gap-3 text-foreground">
                <span class="bg-emerald-500/20 text-emerald-500 w-9 h-9 md:w-10 md:h-10 rounded-full flex items-center justify-center text-lg md:text-xl">🛠️</span>
                More Free Tools
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
                {moreTools.map((tool, i) => (
                    <a href={tool.link} class={`group relative overflow-hidden flex items-center gap-3 md:gap-4 p-3 md:p-4 bg-gradient-to-br from-card to-emerald-500/5 border border-emerald-500/20 rounded-xl hover:border-emerald-500/50 transition-all duration-300 hover:shadow-[0_0_20px_rgba(16,185,129,0.15)] hover:-translate-y-1 animate-fade-in-up`} style={`animation-delay: ${(i * 100) + 200}ms;`}>
                        <div class="text-xl md:text-2xl bg-emerald-500/10 text-emerald-500 p-2 md:p-3 rounded-lg group-hover:bg-emerald-500/20 group-hover:scale-110 transition-all origin-center flex-shrink-0">{tool.icon}</div>
                        <span class="font-bold text-foreground text-xs md:text-sm pr-2 md:pr-4 relative z-10 leading-tight">{tool.name}</span>
                    </a>
                ))}
            </div>
        </div>
        
        <div class="text-center mt-10 md:mt-14">
            <a href="/tools/" class="inline-flex items-center justify-center px-6 md:px-8 py-3 md:py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all hover:scale-105 shadow-lg gap-2">
                View All 25+ Free Tools →
            </a>
        </div>
    </div>
</section>


