---
import { SOCIAL_TWITTER, SOCIAL_INSTAGRAM, SOCIAL_PINTEREST, SOCIAL_YOUTUBE } from '../consts';
import { categories } from '../../scripts/categories.js';
const today = new Date();
---

<footer class="border-t border-border bg-black text-muted-foreground mt-auto">
	<div class="docs-site-container mx-auto px-4 py-10 md:py-12 lg:py-16">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
			<!-- Brand Area -->
			<div class="col-span-1 sm:col-span-2 lg:col-span-1 flex flex-col items-start">
				<a href="/" class="mb-3 md:mb-4 hover:opacity-80 transition-opacity flex items-center" aria-label="Go to Hustle Teacher Homepage">
					<span class="text-lg md:text-xl font-black tracking-tight bg-gradient-to-r from-primary to-emerald-500 bg-clip-text text-transparent">
						HUSTLE TEACHER
					</span>
				</a>
				<p class="text-sm mb-4 md:mb-6">Your Guide to Making Money Online.</p>
				<div class="flex flex-wrap gap-4">
					<a href={SOCIAL_TWITTER} target="_blank" class="hover:text-primary transition-colors" aria-label="Twitter">
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.004 3.916H5.078z"></path></svg>
					</a>
					<a href={SOCIAL_INSTAGRAM} target="_blank" class="hover:text-primary transition-colors" aria-label="Instagram">
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
					</a>
					<a href={SOCIAL_YOUTUBE} target="_blank" class="hover:text-primary transition-colors" aria-label="YouTube">
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					</a>
					<a href={SOCIAL_PINTEREST} target="_blank" class="hover:text-primary transition-colors" aria-label="Pinterest">
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.965 1.406-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.162 0 7.398 2.965 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
					</a>
				</div>
			</div>

			<!-- Core Links -->
			<div>
				<h4 class="font-semibold text-foreground mb-3 md:mb-4 text-sm md:text-base">Explore</h4>
				<ul class="space-y-2 md:space-y-3 text-sm">
					<li><a href="/start-here/" class="hover:text-primary transition-colors">Start Here</a></li>
					<li><a href="/blog/" class="hover:text-primary transition-colors">All Guides</a></li>
					<li><a href="/tools/" class="hover:text-primary transition-colors">Free Tools</a></li>
					<li><a href="/resources/" class="hover:text-primary transition-colors">Resources</a></li>
				</ul>
			</div>

			<!-- Pathways -->
			<div>
				<h4 class="font-semibold text-foreground mb-3 md:mb-4 text-sm md:text-base">Pathways</h4>
				<ul class="space-y-2 md:space-y-3 text-sm">
					{categories.slice(0, 6).map(cat => (
						<li><a href={`/blog/category/${cat.slug}/`} class="hover:text-primary transition-colors">{cat.title}</a></li>
					))}
					<li><a href="/blog/" class="hover:text-primary transition-colors font-medium text-primary text-xs md:text-sm">View All →</a></li>
				</ul>
			</div>

			<!-- Connect -->
			<div>
				<h4 class="font-semibold text-foreground mb-3 md:mb-4 text-sm md:text-base">Connect</h4>
				<ul class="space-y-2 md:space-y-3 text-sm">
					<li><a href="/contact/" class="hover:text-primary transition-colors">Contact Us</a></li>
					<li><a href="/#newsletter" class="hover:text-primary transition-colors">Join Newsletter</a></li>
					<li><a href="/about/" class="hover:text-primary transition-colors">About Us</a></li>
				</ul>
			</div>
		</div>

		<div class="mt-10 md:mt-12 pt-6 md:pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center text-xs md:text-sm gap-2">
			<p>&copy; 2021-{today.getFullYear()} Hustle Teacher. All rights reserved.</p>
			<div class="flex gap-4 md:gap-6">
				<a href="/privacy-policy/" class="hover:text-primary transition-colors">Privacy</a>
				<a href="/terms-conditions/" class="hover:text-primary transition-colors">Terms</a>
				<a href="/disclaimer/" class="hover:text-primary transition-colors">Disclaimer</a>
			</div>
		</div>
	</div>
</footer>
