---
const today = new Date();
---

<footer class="border-t border-border bg-card text-muted-foreground mt-auto">
	<div class="docs-site-container mx-auto px-4 py-12 md:py-16">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
			<!-- Brand Area -->
			<div class="col-span-1 md:col-span-1 flex flex-col items-start">
				<a href="/" class="mb-4 hover:opacity-80 transition-opacity flex items-center" aria-label="Go to Hustle Teacher Homepage">
					<span class="text-xl font-black tracking-tight" style="background: linear-gradient(to right, #6366f1, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
						HUSTLE TEACHER
					</span>
				</a>
				<p class="text-sm">Your Guide to Making Money Online.</p>
				<div class="flex gap-4 mt-6">
					<a href="https://twitter.com/HustleTeacher" target="_blank" class="hover:text-foreground transition-colors">
						<span class="sr-only">Twitter</span>
						<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.004 3.916H5.078z"></path></svg>
					</a>
				</div>
			</div>

			<!-- Core Links -->
			<div>
				<h4 class="font-semibold text-foreground mb-4">Explore</h4>
				<ul class="space-y-3 text-sm">
					<li><a href="/start-here" class="hover:text-foreground transition-colors">Start Here</a></li>
					<li><a href="/blog" class="hover:text-foreground transition-colors">Blog</a></li>
					<li><a href="/tools" class="hover:text-foreground transition-colors">Tools</a></li>
					<li><a href="/resources" class="hover:text-foreground transition-colors">Resources</a></li>
				</ul>
			</div>

			<!-- Interaction -->
			<div>
				<h4 class="font-semibold text-foreground mb-4">Connect</h4>
				<ul class="space-y-3 text-sm">
					<li><a href="/contact" class="hover:text-foreground transition-colors">Contact Us</a></li>
					<li><a href="/#newsletter" class="hover:text-foreground transition-colors">Join Newsletter</a></li>
					<li><a href="/about" class="hover:text-foreground transition-colors">About Us</a></li>
				</ul>
			</div>

			<!-- Legal -->
			<div>
				<h4 class="font-semibold text-foreground mb-4">Legal</h4>
				<ul class="space-y-3 text-sm">
					<li><a href="/privacy-policy" class="hover:text-foreground transition-colors">Privacy Policy</a></li>
					<li><a href="/terms-conditions" class="hover:text-foreground transition-colors">Terms of Service</a></li>
					<li><a href="/disclaimer" class="hover:text-foreground transition-colors">Disclaimer</a></li>
				</ul>
			</div>
		</div>

		<div class="mt-12 pt-8 border-t border-border flex flex-col md:flex-row justify-between items-center text-xs">
			<p>&copy; {today.getFullYear()} Hustle Teacher. All rights reserved.</p>
		</div>
	</div>
</footer>
