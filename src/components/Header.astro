---
import { SITE_TITLE, SOCIAL_TWITTER, SOCIAL_INSTAGRAM, SOCIAL_YOUTUBE, SOCIAL_PINTEREST } from '../consts';
import { categories } from '../../scripts/categories.js';
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-black">
	<nav class="docs-site-container flex h-14 md:h-16 items-center justify-between px-4 md:px-0">
		<div class="font-bold flex items-center animate-fade-in-down">
			<a href="/" class="hover:opacity-80 transition-opacity flex items-center" aria-label="Go to Hustle Teacher Homepage">
				<span class="nav-logo">
					HUSTLE TEACHER
				</span>
			</a>
		</div>
		<div class="hidden md:flex items-center space-x-4 lg:space-x-6 text-sm font-medium">
			<a href="/" class="transition-colors hover:text-primary text-foreground" aria-label="Home page">Home</a>
			<a href="/roles/" class="transition-colors hover:text-primary text-foreground">Role Blueprints</a>
			<a href="/the-mindset-blueprint/" class="transition-colors hover:text-primary text-foreground">The Mindset Blueprint</a>
			<a href="/start-here/" class="transition-colors hover:text-primary text-foreground">Start Here</a>
			
			<!-- Guides Mega-Menu (All 11 Categories) -->
			<div class="relative group">
				<button 
					class="flex items-center gap-1 transition-colors hover:text-primary text-foreground focus:outline-none"
					aria-haspopup="true"
					aria-expanded="false"
					aria-label="View guides categories"
				>
					Guides
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
				</button>
				<div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-[740px] z-50">
					<div class="bg-card/95 backdrop-blur-xl border border-border shadow-2xl rounded-2xl p-6 grid grid-cols-3 gap-x-4 gap-y-3">

						{categories.map((cat) => (
							<a href={`/blog/category/${cat.slug}`} class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
								<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">{cat.title}</div>
								<div class="text-[11px] text-muted-foreground line-clamp-1">{cat.subcategories.slice(0, 3).join(', ')}...</div>
							</a>
						))}

						<!-- View All footer -->
						<div class="flex items-center justify-end">
							<a href="/blog/" class="text-primary font-semibold hover:underline text-sm">View All &rarr;</a>
						</div>

					</div>
				</div>
			</div>

			<div class="relative group">
				<a href="/tools/" class="transition-colors hover:text-primary text-foreground flex items-center gap-2">
					Tools
					<span class="inline-flex items-center rounded-full bg-emerald-500/10 px-1.5 py-0.5 text-[10px] font-bold text-emerald-600 border border-emerald-500/20 animate-pulse">
						NEW
					</span>
				</a>
			</div>
			<a href="/resources/" class="transition-colors hover:text-primary text-foreground">Resources</a>
			
			<!-- Connect & Info Dropdown -->
			<div class="relative group">
				<button 
					class="flex items-center gap-1 transition-colors hover:text-primary text-foreground focus:outline-none"
					aria-haspopup="true"
					aria-expanded="false"
					aria-label="View connect and information links"
				>
					Connect
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
				</button>
				<div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-48 z-50">
					<div class="bg-card/95 backdrop-blur-xl border border-border shadow-2xl rounded-xl p-2 flex flex-col">
						<a href="/about/" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">About Us</a>
						<a href="/contact/" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">Contact</a>
						<a href="/#newsletter" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">Newsletter</a>
					</div>
				</div>
			</div>
		</div>
		<div class="flex items-center space-x-2 md:space-x-4">
			<a href={SOCIAL_YOUTUBE} target="_blank" class="hidden xl:flex items-center text-muted-foreground hover:text-primary transition-colors" aria-label="Watch on YouTube">
				<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
			</a>
			<a href={SOCIAL_INSTAGRAM} target="_blank" class="hidden lg:flex items-center text-muted-foreground hover:text-primary transition-colors" aria-label="Follow us on Instagram">
				<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
			</a>
			<a href={SOCIAL_PINTEREST} target="_blank" class="hidden lg:flex items-center text-muted-foreground hover:text-primary transition-colors" aria-label="Follow us on Pinterest">
				<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.965 1.406-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.162 0 7.398 2.965 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
			</a>
			<!-- Mobile Menu Button -->
			<button 
				id="mobile-menu-btn" 
				class="md:hidden flex flex-col justify-center items-center w-10 h-10 p-2 focus:outline-none z-50 text-foreground"
				aria-label="Toggle Mobile Menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<span class="w-6 h-0.5 bg-foreground transition-all duration-300 rounded-full"></span>
				<span class="w-6 h-0.5 bg-foreground transition-all duration-300 rounded-full my-1"></span>
				<span class="w-6 h-0.5 bg-foreground transition-all duration-300 rounded-full"></span>
			</button>
			<a href="/#newsletter" class="hidden sm:inline-flex items-center justify-center rounded-lg text-xs md:text-sm font-semibold transition-colors focus-visible:outline-none nav-cta text-black h-8 md:h-9 px-3 md:px-4">
				Updates
			</a>
		</div>
	</nav>
	<!-- Mobile Dropdown Menu -->
	<div id="mobile-menu" class="fixed inset-0 bg-black z-40 transform translate-x-full transition-transform duration-300 flex flex-col pt-20 px-6 overflow-y-auto">
		<div class="flex justify-end mb-4">
			<button id="mobile-menu-close" class="w-10 h-10 flex items-center justify-center rounded-full bg-muted text-foreground hover:bg-muted/80 transition-colors" aria-label="Close menu">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
			</button>
		</div>
		<nav class="flex flex-col space-y-1 text-base md:text-lg font-medium">
			<a href="/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">Home</a>
			<a href="/roles/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">Role Blueprints</a>
			<a href="/the-mindset-blueprint/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">The Mindset Blueprint</a>
			<a href="/start-here/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">Start Here</a>
			<a href="/blog/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">All Guides</a>
			<a href="/tools/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg flex items-center gap-2">
				Tools
				<span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2 py-0.5 text-[10px] font-bold text-emerald-600 border border-emerald-500/20">NEW</span>
			</a>
			<a href="/resources/" class="text-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">Resources</a>
			<div class="border-t border-border my-2 pt-2"></div>
			<a href="/about/" class="text-muted-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">About Us</a>
			<a href="/contact/" class="text-muted-foreground hover:text-primary hover:bg-muted/50 transition-colors py-3 px-4 rounded-lg">Contact</a>
		</nav>
		<div class="mt-8 mb-6">
			<a href="/#newsletter" class="flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-primary to-emerald-500 text-white font-bold h-12 shadow-lg">
				Join Newsletter
			</a>
		</div>
		<div class="flex justify-center gap-6">
			<a href={SOCIAL_YOUTUBE} target="_blank" class="text-muted-foreground hover:text-primary transition-colors" aria-label="YouTube"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
			<a href={SOCIAL_INSTAGRAM} target="_blank" class="text-muted-foreground hover:text-primary transition-colors" aria-label="Instagram"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
			<a href={SOCIAL_PINTEREST} target="_blank" class="text-muted-foreground hover:text-primary transition-colors" aria-label="Pinterest"><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.965 1.406-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.162 0 7.398 2.965 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg></a>
		</div>
	</div>
</header>
<script>
	(function() {
		const menuBtn = document.getElementById('mobile-menu-btn');
		const menuClose = document.getElementById('mobile-menu-close');
		const mobileMenu = document.getElementById('mobile-menu');
		const spans = menuBtn?.querySelectorAll('span');
		let isOpen = false;
		
		function openMenu() {
			isOpen = true;
			mobileMenu?.classList.remove('translate-x-full');
			mobileMenu?.classList.add('translate-x-0');
			menuBtn?.setAttribute('aria-expanded', 'true');
			if (spans && spans.length === 3) {
				spans[0].style.transform = 'translateY(8px) rotate(45deg)';
				spans[1].style.opacity = '0';
				spans[2].style.transform = 'translateY(-8px) rotate(-45deg)';
			}
			document.body.style.overflow = 'hidden';
		}
		
		function closeMenu() {
			isOpen = false;
			mobileMenu?.classList.add('translate-x-full');
			mobileMenu?.classList.remove('translate-x-0');
			menuBtn?.setAttribute('aria-expanded', 'false');
			if (spans && spans.length === 3) {
				spans[0].style.transform = 'none';
				spans[1].style.opacity = '1';
				spans[2].style.transform = 'none';
			}
			document.body.style.overflow = '';
		}
		
		menuBtn?.addEventListener('click', () => {
			if (isOpen) closeMenu();
			else openMenu();
		});
		
		menuClose?.addEventListener('click', closeMenu);
		
		const mobileLinks = mobileMenu?.querySelectorAll('a');
		mobileLinks?.forEach(link => {
			link.addEventListener('click', closeMenu);
		});
		
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && isOpen) closeMenu();
		});
	})();
</script>
