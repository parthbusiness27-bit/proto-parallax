---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-black supports-[backdrop-filter]:bg-black/95">
	<nav class="docs-site-container flex h-14 items-center justify-between">
		<h2 class="font-bold flex items-center animate-fade-in-down">
			<a href="/" class="hover:opacity-80 transition-opacity flex items-center" aria-label="Go to Hustle Teacher Homepage">
				<span class="text-xl md:text-2xl font-black tracking-tight" style="background: linear-gradient(to right, #6366f1, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
					HUSTLE TEACHER
				</span>
			</a>
		</h2>
		<div class="hidden md:flex items-center space-x-6 text-sm font-medium">
			<HeaderLink href="/" class="transition-colors hover:text-white/80 text-white">Home</HeaderLink>
			<HeaderLink href="/start-here" class="transition-colors hover:text-white/80 text-white">Start Here</HeaderLink>
			
			<!-- Guides Mega-Menu (All 11 Categories) -->
			<div class="relative group">
				<button class="flex items-center gap-1 transition-colors hover:text-white/80 text-white focus:outline-none">
					Guides
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
				</button>
				<div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-[740px] z-50">
					<div class="bg-card/95 backdrop-blur-xl border border-border shadow-2xl rounded-2xl p-6 grid grid-cols-3 gap-x-4 gap-y-3">

						<a href="/blog/category/side-hustles" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">📚 Side Hustles for Students</div>
							<div class="text-xs text-muted-foreground">Flexible hours &amp; low experience</div>
						</a>

						<a href="/blog/category/skill-based" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">🎯 Skill-Based Income</div>
							<div class="text-xs text-muted-foreground">Design, writing, SEO, marketing</div>
						</a>

						<a href="/blog/category/tech-programming" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">👨‍💻 Tech &amp; Programming</div>
							<div class="text-xs text-muted-foreground">Web, App &amp; Shopify Dev</div>
						</a>

						<a href="/blog/category/content-creator" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">🎥 Content Creator Income</div>
							<div class="text-xs text-muted-foreground">YouTube, Blogging &amp; Socials</div>
						</a>

						<a href="/blog/category/digital-products" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">📦 Digital Product Businesses</div>
							<div class="text-xs text-muted-foreground">E-books, courses, templates</div>
						</a>

						<a href="/blog/category/online-business" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">🏪 Online Business Models</div>
							<div class="text-xs text-muted-foreground">E-commerce &amp; digital businesses</div>
						</a>

						<a href="/blog/category/ai-income" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">🤖 AI-Powered Income</div>
							<div class="text-xs text-muted-foreground">Prompt engineering &amp; AI tools</div>
						</a>

						<a href="/blog/category/virtual-assistant" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">🧑‍💻 Virtual Assistant &amp; Support</div>
							<div class="text-xs text-muted-foreground">Admin, ops &amp; lead gen</div>
						</a>

						<a href="/blog/category/affiliate" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">💸 Affiliate &amp; Monetization</div>
							<div class="text-xs text-muted-foreground">Passive commissions &amp; audiences</div>
						</a>

						<a href="/blog/category/digital-assets" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">📈 Digital Assets &amp; Trading</div>
							<div class="text-xs text-muted-foreground">Crypto, domains &amp; flipping</div>
						</a>

						<a href="/blog/category/automation" class="block group/link px-3 py-2 -mx-3 rounded-lg hover:bg-muted/50 transition-colors">
							<div class="font-semibold text-foreground group-hover/link:text-primary transition-colors text-sm">⚙️ Automation &amp; Tools</div>
							<div class="text-xs text-muted-foreground">SaaS, scrapers &amp; bots</div>
						</a>

						<!-- View All footer -->
						<div class="flex items-center justify-end">
							<a href="/blog" class="text-primary font-semibold hover:underline text-sm">View All &rarr;</a>
						</div>

					</div>
				</div>
			</div>

			<HeaderLink href="/tools" class="transition-colors hover:text-white/80 text-white">Tools</HeaderLink>
			<HeaderLink href="/resources" class="transition-colors hover:text-white/80 text-white">Resources</HeaderLink>
			
			<!-- Connect & Info Dropdown -->
			<div class="relative group">
				<button class="flex items-center gap-1 transition-colors hover:text-white/80 text-white focus:outline-none">
					Connect
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-180 transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
				</button>
				<div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-48 z-50">
					<div class="bg-card/95 backdrop-blur-xl border border-border shadow-2xl rounded-xl p-2 flex flex-col">
						<a href="/about" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">About Us</a>
						<a href="/contact" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">Contact</a>
						<a href="/#newsletter" class="block px-4 py-2 rounded-md font-medium text-foreground hover:bg-muted/50 hover:text-primary transition-colors">Newsletter</a>
					</div>
				</div>
			</div>
		</div>
		<div class="flex items-center space-x-4">
			<a href="/#newsletter" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-purple-600 text-black hover:bg-purple-700 h-9 px-4 py-2">
				Join Newsletter
			</a>
		</div>
	</nav>
</header>

<style>
/* We now use Tailwind CSS for all header styling */
@media (max-width: 768px) {
	.text-sm\.font-medium > a {
		display: none;
	}
}
</style>