	<div id="mobile-menu" class="fixed inset-0 bg-black/95 backdrop-blur-xl z-40 transform translate-x-full transition-transform duration-300 flex flex-col pt-20 px-6 overflow-y-auto">
		<nav class="flex flex-col space-y-6 text-xl font-bold">
			<a href="/" class="text-white hover:text-primary transition-colors border-b border-white/10 pb-4">Home</a>
