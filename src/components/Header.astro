				<span class="inline-flex items-center rounded-full bg-emerald-500/20 px-2 py-0.5 text-xs font-black text-emerald-400 border border-emerald-500/30">NEW</span>
			</a>
			<a href="/resources" class="text-white hover:text-primary transition-colors border-b border-white/10 pb-4">Resources</a>
			<a href="/about" class="text-white hover:text-primary transition-colors border-b border-white/10 pb-4">About Us</a>
			<a href="/contact" class="text-white hover:text-primary transition-colors border-b border-white/10 pb-4">Contact</a>
		</nav>
		<div class="mt-8 mb-12">
			<a href="/#newsletter" class="flex w-full items-center justify-center rounded-xl bg-gradient-to-r from-primary to-emerald-500 text-white font-black h-12">
