			<button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-8 h-8 space-y-1.5 focus:outline-none z-50">
				<span class="w-6 h-0.5 bg-white transition-all duration-300 rounded-full"></span>
				<span class="w-6 h-0.5 bg-white transition-all duration-300 rounded-full"></span>
				<span class="w-6 h-0.5 bg-white transition-all duration-300 rounded-full"></span>
			</button>
			<a href="/#newsletter" class="hidden sm:inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 disabled:opacity-50 bg-primary/20 text-white border-primary/50 border hover:bg-primary/40 h-9 px-4 py-2">
