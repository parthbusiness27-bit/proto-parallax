---
interface Props {
	title: string;
	description: string;
	monetizationMethods: Array<{
		name: string;
		potential: string;
		description: string;
	}>;
}

const { title, description, monetizationMethods = [] } = Astro.props;
---

<section class="my-12 p-8 rounded-2xl bg-gradient-to-br from-emerald-500/5 to-primary/5 border border-primary/20 shadow-lg relative overflow-hidden">
	{/* Decorative background element */}
	<div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/10 rounded-full blur-3xl -z-10"></div>
	
	<div class="relative z-10">
		<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider mb-4">
			<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
			Monetization Strategy
		</div>
		<h2 class="text-2xl font-bold text-foreground mb-4">{title}</h2>
		<p class="text-muted-foreground mb-8 text-lg">{description}</p>

		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{monetizationMethods.map((method) => (
				<div class="p-5 rounded-xl bg-card border border-border hover:border-primary/30 transition-all">
					<div class="flex items-center justify-between mb-3">
						<h4 class="font-bold text-foreground">{method.name}</h4>
						<span class="text-[10px] font-black px-2 py-0.5 rounded bg-primary text-primary-foreground uppercase">{method.potential}</span>
					</div>
					<p class="text-sm text-muted-foreground">{method.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
