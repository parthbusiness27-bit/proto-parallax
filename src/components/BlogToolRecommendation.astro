---
import { Image } from 'astro:assets';

interface Props {
	name: string;
	description: string;
	url: string;
	icon?: string;
	image?: any;
	isAffiliate?: boolean;
}

const { name, description, url, icon, image, isAffiliate = true } = Astro.props;
---

<div class="my-8 rounded-2xl border border-border bg-card overflow-hidden hover:border-primary/50 transition-colors shadow-sm">
	<div class="p-6 flex flex-col md:flex-row gap-6 items-center">
		{image && (
			<div class="w-full md:w-32 h-32 flex-shrink-0 bg-secondary/50 rounded-xl overflow-hidden flex items-center justify-center border border-border/50">
				<Image src={image} alt={name} class="max-w-[80%] max-h-[80%] object-contain" />
			</div>
		)}
		{!image && icon && (
			<div class="w-20 h-20 flex-shrink-0 bg-primary/10 rounded-full flex items-center justify-center text-3xl">
				{icon}
			</div>
		)}
		<div class="flex-grow text-center md:text-left">
			<h4 class="text-xl font-bold text-foreground mb-2">{name}</h4>
			<p class="text-muted-foreground text-sm md:text-base mb-4">{description}</p>
			<a 
				href={url} 
				target="_blank" 
				rel={`noopener noreferrer ${isAffiliate ? 'nofollow sponsored' : ''}`}
				class="inline-flex items-center justify-center px-6 py-2 rounded-full bg-primary text-primary-foreground font-bold hover:brightness-110 transition-all text-sm"
			>
				Get Started with {name}
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
			</a>
			{isAffiliate && (
				<p class="text-[10px] text-muted-foreground mt-2 uppercase tracking-tighter opacity-70">Affiliate Link</p>
			)}
		</div>
	</div>
</div>
