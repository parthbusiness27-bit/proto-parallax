---
// ResourceCard.astro
interface Props {
  title: string;
  description: string;
  url: string;
  icon?: string;
  isPremium?: boolean;
  price?: string;
}

const { title, description, url, icon, isPremium = false, price } = Astro.props;
---

<div class={`group relative flex flex-col p-6 rounded-2xl transition-all duration-300 hover:-translate-y-1 ${isPremium ? 'bg-gradient-to-br from-card to-primary/5 border border-primary/20 hover:border-primary/50 hover:shadow-[0_0_30px_rgba(79,70,229,0.15)]' : 'bg-card border border-border hover:border-emerald-500/50 hover:shadow-lg'}`}>
    {isPremium && price && (
        <div class="absolute top-4 right-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm">
            {price}
        </div>
    )}

    <div class={`w-14 h-14 rounded-xl flex items-center justify-center text-3xl mb-6 transition-all ${isPremium ? 'bg-primary/10 text-primary group-hover:bg-primary/20 group-hover:scale-110' : 'bg-emerald-500/10 text-emerald-500 group-hover:bg-emerald-500/20'}`}>
        {icon || (isPremium ? '⭐' : '📂')}
    </div>

    <h3 class="text-xl font-bold text-foreground mb-3 group-hover:text-primary transition-colors">{title}</h3>
    <p class="text-muted-foreground text-sm leading-relaxed mb-6 flex-grow">{description}</p>

    <a href={url} class={`inline-flex items-center justify-center w-full rounded-xl text-sm font-semibold transition-all h-11 ${isPremium ? 'bg-primary text-white hover:bg-primary/90 shadow-[0_4px_14px_0_rgba(79,70,229,0.39)] hover:shadow-[0_6px_20px_rgba(79,70,229,0.23)] hover:-translate-y-0.5' : 'bg-muted text-foreground hover:bg-emerald-500 hover:text-white'}`}>
        {isPremium ? 'Get Premium Version →' : 'Download Template'}
    </a>
</div>
