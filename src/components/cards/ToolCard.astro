---
// ToolCard.astro
interface Props {
  title: string;
  description: string;
  url: string;
  icon?: string;
  isPremium?: boolean;
  price?: string;
}

const { title, description, url, icon, isPremium = false, price } = Astro.props;
---

<a href={url} class={`group relative p-[1px] rounded-3xl transition-all duration-500 hover:scale-[1.02] active:scale-[0.98] ${isPremium ? 'hover:shadow-[0_0_40px_rgba(99,102,241,0.3)]' : 'hover:shadow-[0_0_30px_rgba(16,185,129,0.2)]'}`}>
  <!-- Animated Border Glow -->
  <div class={`absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10 blur-xl ${isPremium ? 'bg-gradient-to-br from-primary/50 to-purple-500/50' : 'bg-gradient-to-br from-emerald-500/50 to-teal-500/50'}`}></div>
  
  <!-- Content Container -->
  <div class={`relative h-full flex flex-col items-start gap-4 p-6 rounded-[23px] backdrop-blur-xl border transition-all duration-500 ${isPremium ? 'bg-black/40 border-primary/30 group-hover:border-primary/60' : 'bg-black/20 border-white/5 group-hover:border-emerald-500/40'}`}>
    
    <!-- Icon Prism -->
    <div class="relative mb-2">
      <div class={`absolute inset-0 blur-lg opacity-40 group-hover:opacity-100 transition-opacity ${isPremium ? 'bg-primary' : 'bg-emerald-500'}`}></div>
      <div class={`relative text-3xl w-16 h-16 flex items-center justify-center rounded-2xl border backdrop-blur-md transition-transform group-hover:rotate-6 duration-500 ${isPremium ? 'bg-primary/20 border-primary/50 shadow-[0_0_15px_rgba(79,70,229,0.3)]' : 'bg-emerald-500/20 border-emerald-500/50 shadow-[0_0_15px_rgba(16,185,129,0.2)]'}`}>
        {icon || (isPremium ? '💎' : '🎁')}
      </div>
    </div>
    
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-2">
        <h4 class={`font-black text-xl tracking-tight transition-colors ${isPremium ? 'text-white group-hover:text-primary-400' : 'text-white'}`}>
          {title}
        </h4>
        {isPremium && (
          <span class="bg-primary/20 text-primary-400 text-[10px] font-black px-2 py-0.5 rounded-full border border-primary/30 uppercase tracking-tighter">PREMIUM</span>
        )}
      </div>
      <p class="text-sm text-gray-400 leading-relaxed font-medium line-clamp-3 group-hover:text-gray-200 transition-colors">
        {description}
      </p>
    </div>

    <!-- Interactive Footer -->
    <div class="w-full mt-4 pt-4 border-t border-white/5 flex items-center justify-between">
      {price ? (
        <span class="text-sm font-black text-primary-400">{price}</span>
      ) : (
        <span class={`text-[10px] font-black uppercase tracking-widest ${isPremium ? 'text-primary-400' : 'text-emerald-400'}`}>
          {isPremium ? 'Access Now' : 'Free Tool'}
        </span>
      )}
      <div class={`w-8 h-8 rounded-full flex items-center justify-center transition-all ${isPremium ? 'bg-primary/20 group-hover:bg-primary text-primary group-hover:text-white' : 'bg-white/5 group-hover:bg-emerald-500 text-white'}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </div>
    </div>
  </div>
</a>

