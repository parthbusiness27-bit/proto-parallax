---
const freeResources = [
  { name: "Side Hustle Core Setup", price: "Free", desc: "Basic templates and tools to launch your first hustle.", icon: "🔧", link: "/tools" },
  { name: "Creator Mini-Course", price: "Free", desc: "A brief crash course on audience building.", icon: "📱", link: "/blog/category/content-creator" },
  { name: "Weekly Newsletter", price: "Free", desc: "Our best strategies sent directly to your inbox.", icon: "📬", link: "/#newsletter" }
];

const premiumResources = [
  { name: "Freelancing Starter Guide", price: "$15", desc: "Everything you need to land your first client.", icon: "📘", link: "/blog/category/freelancing" },
  { name: "YouTube Growth Ebook", price: "$12", desc: "Scale your channel from 0 to 10k subscribers.", icon: "📕", link: "/blog/category/content-creator" },
  { name: "Side Hustle Toolkit", price: "$7", desc: "Premium templates, checklists, and cold-email scripts.", icon: "🧰", link: "/resources" }
];
---

<section class="docs-site-container border-x py-24 bg-card/30">
    <div class="mx-auto max-w-7xl px-4">
        <div class="text-center mb-16 animate-fade-in-up">
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">
                Build Your Arsenal
            </h2>
            <p class="text-muted-foreground text-xl max-w-2xl mx-auto">
                Start with our free tools, then scale up with our premium blueprints.
            </p>
        </div>

        <!-- Free Section -->
        <div class="mb-16">
            <h3 class="text-2xl font-bold mb-8 text-foreground flex items-center gap-3">
                <span class="bg-primary/20 text-primary w-10 h-10 rounded-full flex items-center justify-center text-xl">🎁</span>
                Free Resources
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {freeResources.map((product, i) => (
                    <div class={`group relative p-8 bg-card border border-border rounded-3xl hover:border-emerald-500/50 transition-all duration-300 hover:shadow-xl animate-fade-in-up overflow-hidden`} style={`animation-delay: ${i * 100}ms;`}>
                        <div class="absolute top-0 right-0 bg-emerald-500/10 text-emerald-500 font-bold px-4 py-1 rounded-bl-xl text-sm z-10 border-b border-l border-emerald-500/20">{product.price}</div>
                        <div class="text-5xl mb-6 relative z-10">{product.icon}</div>
                        <h4 class="text-2xl font-bold mb-3 text-foreground tracking-tight relative z-10">{product.name}</h4>
                        <p class="text-muted-foreground mb-8 relative z-10">{product.desc}</p>
                        <a href={product.link} class="block text-center w-full py-3 rounded-xl bg-muted text-foreground font-bold hover:bg-emerald-500 hover:text-white transition-colors relative z-10">
                            Access Now
                        </a>
                    </div>
                ))}
            </div>
        </div>

        <!-- Premium Section -->
        <div>
            <h3 class="text-2xl font-bold mb-8 text-foreground flex items-center gap-3">
                <span class="bg-primary/20 text-primary w-10 h-10 rounded-full flex items-center justify-center text-xl">💎</span>
                Premium Versions
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {premiumResources.map((product, i) => (
                    <div class={`group relative p-8 bg-card border border-border rounded-3xl hover:border-primary/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(79,70,229,0.15)] animate-fade-in-up overflow-hidden`} style={`animation-delay: ${(i * 100) + 300}ms;`}>
                        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity z-0"></div>
                        <div class="absolute top-0 right-0 bg-primary text-white font-bold px-4 py-1 rounded-bl-xl text-sm z-10 shadow-sm">{product.price}</div>
                        <div class="text-5xl mb-6 relative z-10 group-hover:scale-110 transition-transform origin-bottom-left">{product.icon}</div>
                        <h4 class="text-2xl font-bold mb-3 text-foreground tracking-tight relative z-10">{product.name}</h4>
                        <p class="text-muted-foreground mb-8 relative z-10">{product.desc}</p>
                        <a href={product.link} class="block text-center w-full py-3 rounded-xl bg-primary/10 text-primary border border-primary/20 font-bold hover:bg-primary hover:text-white transition-all relative z-10" data-gumroad-overlay-checkout="true">
                            Get Premium
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
