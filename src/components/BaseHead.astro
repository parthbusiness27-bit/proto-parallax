---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR, SITE_URL } from '../consts';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title: string;
	seoTitle?: string;
	description: string;
	image?: string | ImageMetadata;
	author?: string;
	publishedDate?: Date;
	updatedDate?: Date;
	/** Custom robots meta tag content. Defaults to full-index for home/posts, noindex for archives/search. */
	robotsMeta?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { 
	title, 
	seoTitle,
	description, 
	image = '/logo.png', 
	author = SITE_AUTHOR,
	publishedDate,
	updatedDate,
	robotsMeta = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID || "G-HG27BZGSGX";
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || "vtxphchxvm";
---

<!-- ======================== -->
<!-- SECURITY & META HEADERS  -->
<!-- ======================== -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="robots" content={robotsMeta} />

<!-- Security Headers (Content Security Policy) -->
<meta http-equiv="Content-Security-Policy" content="
	upgrade-insecure-requests;
	default-src 'self' https:;
	script-src 'self' 'unsafe-inline' https: https://www.googletagmanager.com https://clarity.microsoft.com https://www.google.com https://www.gstatic.com;
	style-src 'self' 'unsafe-inline' https:;
	img-src 'self' data: https: blob:;
	font-src 'self' data: https:;
	connect-src 'self' https: https://www.googletagmanager.com https://clarity.microsoft.com https://www.google-analytics.com;
	base-uri 'self';
	form-action 'self' https:;
" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="color-scheme" content="light dark" />

<!-- Favicon & Icons -->
<link rel="icon" type="image/png" href="/logo.png" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/logo.png" />
<link rel="manifest" href="/manifest.json" />
<meta name="msapplication-config" content="/browserconfig.xml" />
<meta name="theme-color" content="#4338ca" />

<!-- Preloads -->
<link rel="preload" href="/logo.png" as="image" type="image/png" fetchpriority="high" />

<!-- Feeds & Documentation -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://assets.mlcdn.com">
<link rel="preconnect" href="https://fonts.mailerlite.com">
<link rel="dns-prefetch" href="https://fonts.googleapis.com">
<link rel="dns-prefetch" href="https://fonts.gstatic.com">
<link rel="dns-prefetch" href="https://assets.mlcdn.com">
<link rel="dns-prefetch" href="https://fonts.mailerlite.com">
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Poppins:wght@400;500;600;700;800;900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://assets.mlcdn.com/fonts.css?version=1773240" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://fonts.mailerlite.com/css?family=Open+Sans:300,400,600,700" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
	<link href="https://assets.mlcdn.com/fonts.css?version=1773240" rel="stylesheet">
</noscript>

<!-- ======================== -->
<!-- SEO META TAGS            -->
<!-- ======================== -->

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- WebSite & Brand Schemas -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      "url": SITE_URL,
      "name": SITE_TITLE,
      "alternateName": "The Hustle Teacher",
      "description": SITE_DESCRIPTION,
      "publisher": {
        "@id": `${SITE_URL}/#organization`
      },
      "potentialAction": [
        {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": `${SITE_URL}/search?q={search_term_string}`
          },
          "query-input": "required name=search_term_string"
        }
      ],
      "inLanguage": "en-US"
    },
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      "name": SITE_TITLE,
      "url": SITE_URL,
      "logo": {
        "@type": "ImageObject",
        "inLanguage": "en-US",
        "@id": `${SITE_URL}/#logo`,
        "url": `${SITE_URL}/logo.png`,
        "contentUrl": `${SITE_URL}/logo.png`,
        "width": 512,
        "height": 512,
        "caption": SITE_TITLE
      },
      "image": {
        "@id": `${SITE_URL}/#logo`
      },
      "sameAs": [
        "https://x.com/thustleteacher",
        "https://www.youtube.com/@TheHustleTeacher",
        "https://www.instagram.com/hustle.teacher",
        "https://www.pinterest.com/thehustleteacher"
      ]
    },
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#author`,
      "name": author,
      "url": SITE_URL,
      "image": {
        "@type": "ImageObject",
        "inLanguage": "en-US",
        "@id": `${SITE_URL}/#authorlogo`,
        "url": `${SITE_URL}/logo.png`,
        "contentUrl": `${SITE_URL}/logo.png`,
        "caption": author
      },
      "description": "Founder of Hustle Teacher, dedicated to helping students and beginners earn money online."
    }
  ]
})} />

<!-- Primary Meta Tags -->
<title>{seoTitle || title}</title>
<meta name="title" content={seoTitle || title} />
<meta name="application-name" content={SITE_TITLE} />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="keywords" content="online earning, side hustle, student jobs, work from home, digital skills" />
<meta name="google-site-verification" content="3EdmATvJBUdbugqzo9-OtVXX2XRzn3FAZeajRzC5X58" />
<meta name="msvalidate.01" content="93CA3B3F5B43B0F1DE57B1A0E055E5C7" />
<meta name="yandex-verification" content="90b95e4715d20bef" />
<meta name="google-site-name" content="Hustle Teacher" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(typeof image === 'string' ? image : (image?.src || '/logo.png'), Astro.url)} />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={SITE_TITLE} />
{author && <meta property="article:author" content={author} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@thustleteacher" />
<meta name="twitter:creator" content="@thustleteacher" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(typeof image === 'string' ? image : (image?.src || '/logo.png'), Astro.url)} />

<!-- Additional SEO -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />

<link rel="me" href="https://twitter.com/hustle_teacher" />
<link rel="me" href="mailto:thehustleteacher@gmail.com" />

<!-- ======================== -->
<!-- ANALYTICS & TRACKING    -->
<!-- ======================== -->

<!-- Google Analytics 4 -->
{gaId && (
	<>
		<!-- Google tag (gtag.js) -->
		<script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
		<script type="text/partytown" define:vars={{ gaId }}>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());

		gtag('config', gaId);
		</script>
	</>
)}

<!-- Microsoft Clarity -->
{clarityId && clarityId !== 'your-clarity-project-id' && (
	<script type="text/partytown" define:vars={{ clarityId }}>
		(function(c,l,a,r,i,t,y){
			c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
			t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
			y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
		})(window, document, "clarity", "script", clarityId);
	</script>
)}

<!-- reCAPTCHA Script -->
<script type="text/partytown" src="https://www.google.com/recaptcha/api.js"></script>

<!-- Generator -->
<meta name="generator" content={Astro.generator} />

<!-- Ahrefs Analytics -->
<script type="text/partytown" src="https://analytics.ahrefs.com/analytics.js" data-key="ABvv/lPKJqYU90luw2eHUg" defer></script>

<!-- Service Worker Registration -->
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').catch(() => {
        // SW registration failed silently - no console errors
      });
    });
  }
</script>

<!-- Vercel Analytics -->
<Analytics />

<!-- Vercel Speed Insights -->
<SpeedInsights />

<!-- MailerLite Universal -->
<script is:inline>
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
    .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
    n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
    (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', '2192818');
</script>
<!-- End MailerLite Universal -->

