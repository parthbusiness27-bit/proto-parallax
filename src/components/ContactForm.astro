---
interface Props {
	title?: string;
	subtitle?: string;
}

const {
	title = 'Get in Touch',
	subtitle = "Have a question? We'd love to hear from you.",
} = Astro.props;

// Formspree endpoint — forwards submissions to parthbusiness27@gmail.com
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xwpokrvg';
---

<section class="contact-section">
	<div class="contact-container">
		<div class="contact-header">
			<h2>{title}</h2>
			{subtitle && <p>{subtitle}</p>}
		</div>

		<form
			id="contact-form"
			class="contact-form"
			method="POST"
			action={FORMSPREE_ENDPOINT}
		>
			<!-- Honeypot to prevent spam -->
			<input type="text" name="_gotcha" style="display:none" />

			<div class="form-group">
				<label for="name">Name *</label>
				<input type="text" id="name" name="name" required placeholder="Your name" />
			</div>

			<div class="form-group">
				<label for="email">Email *</label>
				<input type="email" id="email" name="email" required placeholder="your@email.com" />
			</div>

			<div class="form-group">
				<label for="subject">Subject *</label>
				<input type="text" id="subject" name="subject" required placeholder="What's this about?" />
			</div>

			<div class="form-group">
				<label for="message">Message *</label>
				<textarea id="message" name="message" required placeholder="Your message..." rows="6"></textarea>
			</div>

			<div id="form-success" class="form-success" style="display:none">
				✅ Message sent! We'll get back to you within 24–48 hours.
			</div>

			<div id="form-error" class="form-error" style="display:none">
				❌ Something went wrong. Please email us directly at
				<a href="mailto:parthbusiness27@gmail.com">parthbusiness27@gmail.com</a>
			</div>

			<button type="submit" id="submit-btn" class="submit-btn">Send Message</button>

			<p class="form-notice">
				We'll get back to you within 24–48 hours. Check our
				<a href="/privacy-policy/">Privacy Policy</a>
				for how we handle your data.
			</p>
		</form>
	</div>
</section>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const successMsg = document.getElementById('form-success') as HTMLElement;
	const errorMsg = document.getElementById('form-error') as HTMLElement;

	form?.addEventListener('submit', async (e: Event) => {
		e.preventDefault();
		submitBtn.disabled = true;
		submitBtn.textContent = 'Sending…';

		try {
			const res = await fetch(form.action, {
				method: 'POST',
				body: new FormData(form),
				headers: { Accept: 'application/json' },
			});

			if (res.ok) {
				successMsg.style.display = 'block';
				errorMsg.style.display = 'none';
				form.reset();
				submitBtn.textContent = 'Sent!';
			} else {
				throw new Error('Server error');
			}
		} catch {
			errorMsg.style.display = 'block';
			successMsg.style.display = 'none';
			submitBtn.disabled = false;
			submitBtn.textContent = 'Send Message';
		}
	});
</script>

<style>
	.contact-section {
		padding: 3em 1em;
		background: #f9fafb;
		border-radius: 1em;
		margin: 3em 0;
	}

	.contact-container {
		max-width: 600px;
		margin: 0 auto;
	}

	.contact-header {
		text-align: center;
		margin-bottom: 2em;
	}

	.contact-header h2 {
		font-size: 2em;
		margin: 0 0 0.5em 0;
		color: #111827;
	}

	.contact-header p {
		margin: 0;
		color: #6b7280;
		font-size: 1.05em;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	label {
		font-weight: 600;
		color: #1f2937;
		font-size: 0.95em;
	}

	input,
	textarea {
		padding: 0.75em 1em;
		border: 1px solid #d1d5db;
		border-radius: 0.5em;
		font-size: 1em;
		font-family: inherit;
		color: #1f2937;
		transition: all 0.3s ease;
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: #4338ca;
		box-shadow: 0 0 0 3px rgba(67, 56, 202, 0.1);
	}

	textarea {
		resize: vertical;
		min-height: 120px;
	}

	.recaptcha-container {
		display: flex;
		justify-content: center;
		padding: 1em 0;
	}

	.submit-btn {
		padding: 0.875em 2em;
		background: #4338ca;
		color: white;
		border: none;
		border-radius: 0.5em;
		font-weight: 700;
		cursor: pointer;
		font-size: 1em;
		transition: all 0.3s ease;
	}

	.submit-btn:hover {
		background: #3730a3;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(67, 56, 202, 0.3);
	}

	.form-notice {
		text-align: center;
		font-size: 0.85em;
		color: #6b7280;
		margin: 0;
	}

	.form-notice a {
		color: #4338ca;
		text-decoration: none;
		font-weight: 600;
	}

	.form-notice a:hover {
		text-decoration: underline;
	}

	.form-success {
		padding: 1em;
		background: #d1fae5;
		border: 1px solid #6ee7b7;
		color: #065f46;
		border-radius: 0.5em;
		text-align: center;
		font-weight: 600;
	}

	.form-error {
		padding: 1em;
		background: #fee2e2;
		border: 1px solid #fca5a5;
		color: #991b1b;
		border-radius: 0.5em;
		text-align: center;
	}

	.form-error a {
		color: #991b1b;
		text-decoration: underline;
	}

	@media (max-width: 600px) {
		.contact-header h2 {
			font-size: 1.5em;
		}

		input,
		textarea {
			font-size: 16px; /* Prevents zoom on iOS */
		}
	}
</style>
