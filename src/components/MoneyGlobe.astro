---
// MoneyGlobe.astro
// A glowing, interactive WebGL globe with floating money/success elements.
---
<div class="relative w-full max-w-[260px] sm:max-w-[320px] md:max-w-[450px] aspect-square mx-auto flex items-center justify-center animate-fade-in-up" style="animation-duration: 1.5s;">
  <!-- Glowing background aura -->
  <div class="absolute inset-0 bg-gradient-to-tr from-primary/30 via-emerald-500/20 to-blue-500/30 rounded-full blur-[60px] md:blur-[80px] animate-pulse" style="animation-duration: 4s;"></div>
  
  <!-- The Globe -->
  <div class="relative z-10 w-full h-full transform hover:scale-105 transition-transform duration-700">
    <canvas
      id="cobe"
      style="width: 100%; height: 100%; contain: layout paint size; opacity: 0; transition: opacity 1.5s ease; cursor: grab;"
    ></canvas>
  </div>

  <!-- Floating Money/Wealth Elements -->
  <!-- Outer Orbit -->
  <div class="absolute inset-[-10%] md:inset-[-15%] z-20 pointer-events-none origin-center animate-[spin_25s_linear_infinite]">
    <div class="absolute top-[10%] left-[10%] text-3xl md:text-5xl drop-shadow-[0_0_20px_rgba(16,185,129,0.8)] animate-[spin_25s_linear_infinite_reverse]">💵</div>
    <div class="absolute bottom-[10%] right-[10%] text-2xl md:text-4xl drop-shadow-[0_0_20px_rgba(250,204,21,0.8)] animate-[spin_25s_linear_infinite_reverse]">🚀</div>
  </div>

  <!-- Inner Orbit -->
  <div class="absolute inset-[10%] z-20 pointer-events-none origin-center animate-[spin_18s_linear_infinite_reverse]">
    <div class="absolute top-[5%] right-[20%] text-2xl md:text-4xl drop-shadow-[0_0_15px_rgba(59,130,246,0.8)] animate-[spin_18s_linear_infinite]">💎</div>
    <div class="absolute bottom-[10%] left-[10%] text-3xl md:text-5xl drop-shadow-[0_0_20px_rgba(16,185,129,0.8)] animate-[spin_18s_linear_infinite]">💰</div>
  </div>

  <!-- Floating Elements around the globe -->
  <div class="absolute inset-0 z-30 pointer-events-none">
    <div class="absolute top-[40%] right-[-10%] text-2xl md:text-3xl animate-bounce drop-shadow-[0_0_10px_rgba(250,204,21,0.8)]" style="animation-duration: 3s;">🪙</div>
    <div class="absolute bottom-[30%] left-[-5%] text-2xl md:text-3xl animate-bounce drop-shadow-[0_0_10px_rgba(16,185,129,0.8)]" style="animation-duration: 2.5s; animation-delay: 1s;">📈</div>
  </div>

  <!-- Central "Hustle" ring -->
  <div class="absolute inset-[-5%] md:inset-[-10%] z-0 pointer-events-none flex items-center justify-center">
    <div class="w-full h-full rounded-full border border-white/10 border-t-emerald-500/50 border-b-primary/50 animate-[spin_8s_linear_infinite]"></div>
    <div class="absolute w-[105%] h-[105%] rounded-full border border-white/5 border-l-blue-500/40 border-r-purple-500/40 animate-[spin_12s_linear_infinite_reverse]"></div>
  </div>
</div>

<script>
  import createGlobe from "cobe";

  const initGlobe = () => {
    const canvas = document.getElementById("cobe") as HTMLCanvasElement;
    if (!canvas) return;

    let phi = 0;
    
    // Size the internal WebGL buffer higher for crisp visuals on retina screens
    const width = 1000;
    
    // Fade in when ready
    setTimeout(() => {
      canvas.style.opacity = "1";
    }, 100);
    
    const globe = createGlobe(canvas, {
      devicePixelRatio: 2,
      width: width,
      height: width,
      phi: 0,
      theta: 0.3,
      dark: 1, // dark mode theme
      diffuse: 1.2,
      scale: 1.05,
      mapSamples: 16000,
      mapBrightness: 6,
      baseColor: [0.1, 0.1, 0.12], // Deep dark blue/gray
      markerColor: [0.1, 0.9, 0.5], // Emerald green for money/success markers
      glowColor: [0.2, 0.3, 0.5], // Cool blue glow
      markers: [
        // "Money hubs" or global success points
        { location: [40.7128, -74.0060], size: 0.08 }, // New York
        { location: [51.5074, -0.1278], size: 0.08 },  // London
        { location: [35.6762, 139.6503], size: 0.06 }, // Tokyo
        { location: [1.3521, 103.8198], size: 0.05 },  // Singapore
        { location: [25.2048, 55.2708], size: 0.07 },  // Dubai
        { location: [37.7749, -122.4194], size: 0.06 },// San Francisco
      ],
      onRender: (state) => {
        // Automatically rotate the globe slowly
        state.phi = phi;
        phi += 0.003;
      }
    });

    return globe;
  };

  // Run on first load
  let activeGlobe = initGlobe();

  // Astro view transitions support
  document.addEventListener("astro:page-load", () => {
    if (!activeGlobe && document.getElementById("cobe")) {
      activeGlobe = initGlobe();
    }
  });

  document.addEventListener("astro:before-swap", () => {
    if (activeGlobe) {
      activeGlobe.destroy();
      activeGlobe = undefined;
    }
  });
</script>
