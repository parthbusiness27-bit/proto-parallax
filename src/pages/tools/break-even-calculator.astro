---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "Break Even Calculator";
const description = "Determine exactly how many units or how much revenue you need to cover all your business costs.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-indigo-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-indigo-500/10 text-indigo-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-indigo-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(79,70,229,0.1)]">
					⚖️ Financial Balance
				</div>
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					Break <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-primary">Even</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					Know your numbers. Calculate exactly when your business becomes profitable by identifying the intersection of revenue and total expenses.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Left Column: Inputs -->
				<div class="lg:col-span-7 space-y-6">
					<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group">
						<div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						
						<div class="relative space-y-8">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								<div class="space-y-4">
									<label class="text-xs font-black text-gray-500 uppercase tracking-widest block px-2">Fixed Costs (Total)</label>
									<input 
										type="number" 
										id="fixed" 
										value="2000" 
										class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-xl font-black text-white outline-none focus:border-indigo-500/50 transition-all font-bold"
									/>
									<p class="text-[10px] text-gray-600 font-bold uppercase tracking-widest px-2">Rent, software, salaries, etc.</p>
								</div>
								<div class="space-y-4">
									<label class="text-xs font-black text-gray-500 uppercase tracking-widest block px-2">Variable Cost (Per Unit)</label>
									<input 
										type="number" 
										id="variable" 
										value="15" 
										class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-xl font-black text-white outline-none focus:border-indigo-500/50 transition-all font-bold"
									/>
									<p class="text-[10px] text-gray-600 font-bold uppercase tracking-widest px-2">Shipping, raw materials, etc.</p>
								</div>
							</div>

							<div class="space-y-4">
								<label class="text-xs font-black text-gray-500 uppercase tracking-widest block px-2">Sale Price (Per Unit)</label>
								<input 
									type="number" 
									id="price" 
									value="50" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-5 text-3xl font-black text-white outline-none focus:border-indigo-500/50 transition-all font-bold"
								/>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Results -->
				<div class="lg:col-span-5">
					<div class="bg-gradient-to-br from-indigo-500/10 to-primary/10 backdrop-blur-3xl border border-indigo-500/20 rounded-[2.5rem] p-10 shadow-2xl sticky top-32 text-center group overflow-hidden">
						<div class="absolute -right-10 -top-10 text-[10rem] opacity-5 group-hover:scale-110 transition-transform duration-700">⚖️</div>
						
						<div class="relative space-y-8">
							<div>
								<span class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-2 block">Break Even Point</span>
								<div class="text-6xl md:text-7xl font-black text-white" id="units-result">58</div>
								<span class="text-xs font-black text-gray-500 uppercase tracking-widest">Units Sold</span>
							</div>

							<div class="bg-white/5 rounded-3xl p-6 border border-white/10">
								<span class="text-[10px] font-black uppercase tracking-tighter text-gray-400 mb-2 block">Revenue Needed</span>
								<div class="text-3xl font-black text-emerald-400" id="revenue-result">$2,900.00</div>
							</div>

							<p class="text-[10px] text-gray-500 font-medium italic">
								*The point where total revenue equals total costs. Every sale after this is pure profit.
							</p>

							<button class="w-full bg-white text-black font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl uppercase tracking-tighter">
								Plan Your Growth
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const fixedInput = document.getElementById('fixed');
		const variableInput = document.getElementById('variable');
		const priceInput = document.getElementById('price');

		const unitsRes = document.getElementById('units-result');
		const revenueRes = document.getElementById('revenue-result');

		function updateCalculations() {
			const fixed = parseFloat(fixedInput.value) || 0;
			const variable = parseFloat(variableInput.value) || 0;
			const price = parseFloat(priceInput.value) || 0;

			// Logic
            const contributionMargin = price - variable;
            let units = 0;
            if (contributionMargin > 0) {
                units = fixed / contributionMargin;
            }
            
            const revenue = units * price;

			// Update Results
			unitsRes.textContent = Math.ceil(units).toLocaleString();
			revenueRes.textContent = '$' + revenue.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		}

		// Input events
		fixedInput.addEventListener('input', updateCalculations);
		variableInput.addEventListener('input', updateCalculations);
		priceInput.addEventListener('input', updateCalculations);

		// Initial Run
		updateCalculations();
	});
</script>
