---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "ROI Calculator";
const description = "Measure the return on investment for your marketing campaigns or business projects.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description} theme="dark">
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-purple-500/10 text-purple-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-purple-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(168,85,247,0.1)]">
					💎 Investment Analysis
				</div>
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					ROI <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-primary">Calculator</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					What is your money doing for you? Calculate your Return on Investment across marketing, assets, and business ventures to identify your top performers.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Left Column: Inputs -->
				<div class="lg:col-span-7 space-y-6">
					<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group">
						<div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						
						<div class="relative space-y-8">
							<div class="space-y-4">
								<label class="text-xs font-black text-gray-500 uppercase tracking-widest block px-2">Amount Invested ($)</label>
								<input 
									type="number" 
									id="invested" 
									value="500" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-xl font-black text-white outline-none focus:border-purple-500/50 transition-all font-bold"
								/>
                                <p class="text-[10px] text-gray-600 font-bold uppercase tracking-widest px-2">Ad spend, course cost, initial capital</p>
							</div>

							<div class="space-y-4">
								<label class="text-xs font-black text-gray-500 uppercase tracking-widest block px-2">Amount Returned ($)</label>
								<input 
									type="number" 
									id="returned" 
									value="1250" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-5 text-3xl font-black text-white outline-none focus:border-purple-500/50 transition-all font-bold"
								/>
                                <p class="text-[10px] text-gray-600 font-bold uppercase tracking-widest px-2">Total revenue or value generated</p>
							</div>

                            <!-- Performance Meter -->
                            <div class="pt-6 border-t border-white/5">
                                <div class="flex justify-between items-center mb-2 px-2">
                                     <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Efficiency Rating</span>
                                     <span class="text-xs font-black text-purple-400" id="rating">EXCELLENT</span>
                                </div>
                                <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                                     <div class="h-full bg-gradient-to-r from-purple-600 to-indigo-400 transition-all duration-1000" id="progress-bar" style="width: 100%"></div>
                                </div>
                            </div>
						</div>
					</div>
				</div>

				<!-- Right Column: Results -->
				<div class="lg:col-span-5">
					<div class="bg-gradient-to-br from-purple-500/10 to-primary/10 backdrop-blur-3xl border border-purple-500/20 rounded-[2.5rem] p-10 shadow-2xl sticky top-32 text-center group overflow-hidden">
						<div class="absolute -right-10 -top-10 text-[10rem] opacity-5 group-hover:scale-110 transition-transform duration-700">💎</div>
						
						<div class="relative space-y-8">
							<div>
								<span class="text-xs font-black uppercase tracking-widest text-purple-400 mb-2 block">Return on Investment</span>
								<div class="text-6xl md:text-7xl font-black text-white" id="roi-result">150%</div>
							</div>

							<div class="grid grid-cols-1 gap-4">
								<div class="bg-white/5 rounded-3xl p-6 border border-white/10">
									<span class="text-[10px] font-black uppercase tracking-tighter text-gray-400 mb-2 block">Net Profit</span>
									<div class="text-3xl font-black text-emerald-400" id="profit-result">$750.00</div>
								</div>
							</div>

							<p class="text-[10px] text-gray-500 font-medium italic">
								*ROI = ((Returned - Invested) / Invested) * 100.
							</p>

							<button class="w-full bg-white text-black font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl uppercase tracking-tighter">
								Calculate Next Project
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const investedInput = document.getElementById('invested');
		const returnedInput = document.getElementById('returned');

		const roiRes = document.getElementById('roi-result');
		const profitRes = document.getElementById('profit-result');
        const ratingRes = document.getElementById('rating');
        const progressBar = document.getElementById('progress-bar');

		function updateCalculations() {
			const invested = parseFloat(investedInput.value) || 0;
			const returned = parseFloat(returnedInput.value) || 0;

			// Logic
            const profit = returned - invested;
            let roi = 0;
            if (invested > 0) {
                roi = (profit / invested) * 100;
            }

            // Rating logic
            let rating = 'CRITICAL';
            let color = '#ef4444';
            let progress = 10;
            if (roi > 100) { rating = 'EXCELLENT'; color = '#a855f7'; progress = 100; }
            else if (roi > 50) { rating = 'GREAT'; color = '#8b5cf6'; progress = 75; }
            else if (roi > 20) { rating = 'GOOD'; color = '#6366f1'; progress = 50; }
            else if (roi >= 0) { rating = 'STABLE'; color = '#3b82f6'; progress = 25; }

			// Update Results
			roiRes.textContent = roi.toFixed(1) + '%';
			profitRes.textContent = '$' + profit.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            ratingRes.textContent = rating;
            ratingRes.style.color = color;
            progressBar.style.width = progress + '%';
            progressBar.style.background = `linear-gradient(90deg, ${color}, #6366f1)`;
		}

		// Input events
		investedInput.addEventListener('input', updateCalculations);
		returnedInput.addEventListener('input', updateCalculations);

		// Initial Run
		updateCalculations();
	});
</script>
