---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	title="YouTube Earnings Calculator | Hustle Teacher"
	description="Estimate your potential YouTube income with our advanced earnings calculator. Includes niche presets, daily/monthly/yearly projections, and CPM guide."
>
	<main class="flex-grow pt-24 pb-20">
		<div class="docs-site-container">
			<!-- Hero Header -->
			<div class="text-center mb-16 animate-fade-in-down">
				<div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-6 border border-primary/50 shadow-sm">
					📈 Creator Tools
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold mb-6 uppercase tracking-tight">
					YouTube <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Earnings</span> Calculator
				</h1>
				<p class="text-xl text-muted-foreground max-w-2xl mx-auto">
					Calculate your potential revenue, explore industry CPM benchmarks, and plan your content strategy for maximum profit.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
				<!-- Calculator Side -->
				<div class="lg:col-span-2 space-y-8 animate-fade-in-up" style="animation-delay: 150ms;">
					<div class="bg-card/50 backdrop-blur-xl border border-border rounded-3xl p-8 md:p-10 shadow-2xl relative overflow-hidden group">
						<div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-50"></div>
						
						<div class="relative z-10 space-y-10">
							<!-- Daily Views Input -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label for="views" class="text-lg font-bold text-foreground">Estimated Daily Views</label>
									<span class="text-2xl font-black text-primary" id="views-display">5,000</span>
								</div>
								<div class="relative group/slider">
									<input 
										type="range" 
										id="views-slider" 
										min="100" 
										max="1000000" 
										step="100" 
										value="5000"
										class="w-full h-3 bg-muted rounded-lg appearance-none cursor-pointer accent-primary"
									/>
								</div>
								<input 
									id="views" 
									type="number" 
									value="5000" 
									class="w-full bg-background/50 border border-border rounded-xl px-5 py-3 text-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all"
									placeholder="Or enter manually..."
								/>
							</div>

							<!-- CPM Input -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label for="cpm" class="text-lg font-bold text-foreground">Estimated CPM ($)</label>
									<span class="text-2xl font-black text-emerald-500" id="cpm-display">$4.00</span>
								</div>
								<div class="relative group/slider">
									<input 
										type="range" 
										id="cpm-slider" 
										min="0.1" 
										max="50" 
										step="0.1" 
										value="4"
										class="w-full h-3 bg-muted rounded-lg appearance-none cursor-pointer accent-emerald-500"
									/>
								</div>
								<input 
									id="cpm" 
									type="number" 
									value="4.00" 
									step="0.01"
									class="w-full bg-background/50 border border-border rounded-xl px-5 py-3 text-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none transition-all"
									placeholder="Example: 4.50"
								/>
							</div>

							<!-- Niche Presets -->
							<div class="space-y-4">
								<label class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">Select Niche Preset (Avg. CPM)</label>
								<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
									<button class="niche-btn p-3 rounded-xl border border-border bg-muted/30 hover:bg-primary/10 hover:border-primary/50 transition-all text-sm font-bold" data-cpm="1.5">Gaming</button>
									<button class="niche-btn p-3 rounded-xl border border-border bg-muted/30 hover:bg-primary/10 hover:border-primary/50 transition-all text-sm font-bold" data-cpm="3.5">vlog</button>
									<button class="niche-btn p-3 rounded-xl border border-border bg-muted/30 hover:bg-primary/10 hover:border-primary/50 transition-all text-sm font-bold" data-cpm="8.0">Tech</button>
									<button class="niche-btn p-3 rounded-xl border border-border bg-muted/30 hover:bg-primary/10 hover:border-primary/50 transition-all text-sm font-bold" data-cpm="15.0">Finance</button>
								</div>
							</div>
						</div>
					</div>

					<!-- Content Section -->
					<div class="prose prose-invert max-w-none bg-card/30 border border-border rounded-3xl p-8 md:p-10">
						<h2>How to Use This Calculator</h2>
						<p>
							Our YouTube Earnings Calculator helps you estimate your potential revenue by factoring in two main metrics: **Views** and **CPM**.
						</p>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose">
							<div class="p-5 rounded-2xl bg-background/50 border border-border">
								<h4 class="font-bold text-primary mb-2">What is CPM?</h4>
								<p class="text-sm text-muted-foreground">CPM (Cost Per Mille) is the amount advertisers pay for every 1,000 views. This varies wildly based on your niche, audience location, and time of year.</p>
							</div>
							<div class="p-5 rounded-2xl bg-background/50 border border-border">
								<h4 class="font-bold text-emerald-500 mb-2">YouTube's Cut</h4>
								<p class="text-sm text-muted-foreground">Note: YouTube typically takes 45% of ad revenue. This calculator estimates the amount *before* YouTube's cut unless you factor it into your CPM.</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Results Side -->
				<div class="space-y-6 animate-fade-in-up" style="animation-delay: 300ms;">
					<h2 class="text-2xl font-bold px-2">Earnings Projections</h2>
					
					<!-- Daily -->
					<div class="bg-gradient-to-br from-card to-card border border-border rounded-2xl p-6 shadow-lg hover:border-primary/50 transition-colors">
						<span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Daily Earnings</span>
						<div class="text-4xl font-black text-foreground mt-1" id="daily-result">$20.00</div>
					</div>

					<!-- Monthly -->
					<div class="bg-gradient-to-br from-primary/10 to-emerald-500/10 border border-primary/20 rounded-3xl p-8 shadow-xl relative overflow-hidden group">
						<div class="absolute -right-4 -top-4 text-7xl opacity-10 group-hover:scale-125 transition-transform">💰</div>
						<span class="text-sm font-bold uppercase tracking-widest text-primary">Monthly Earnings</span>
						<div class="text-5xl font-black text-foreground mt-2" id="monthly-result">$600.00</div>
						<p class="text-xs text-muted-foreground mt-4">Calculated over a 30-day period</p>
					</div>

					<!-- Yearly -->
					<div class="bg-gradient-to-br from-card to-card border border-border rounded-2xl p-6 shadow-lg hover:border-emerald-500/50 transition-colors">
						<span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Yearly Earnings</span>
						<div class="text-4xl font-black text-foreground mt-1" id="yearly-result">$7,300.00</div>
					</div>

					<!-- CTA Box -->
					<div class="bg-primary p-1 rounded-3xl shadow-2xl">
						<div class="bg-card rounded-[calc(1.5rem-2px)] p-6 text-center">
							<h4 class="font-bold text-lg mb-3">Want to boost your CPM?</h4>
							<p class="text-sm text-muted-foreground mb-6">Our YouTube Mastery guide covers high-ticket niching and audience optimization.</p>
							<a href="/guides/youtube-mastery" class="block w-full py-3 bg-primary text-white font-bold rounded-xl hover:scale-105 transition-transform shadow-lg shadow-primary/25">
								Read the Guide
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	/* Custom styling for ranges to ensure they look premium */
	input[type='range']::-webkit-slider-thumb {
		-webkit-appearance: none;
		appearance: none;
		width: 24px;
		height: 24px;
		background: #ffffff;
		border: 4px solid var(--primary);
		border-radius: 50%;
		cursor: pointer;
		box-shadow: 0 0 15px rgba(79, 70, 229, 0.4);
		transition: transform 0.2s;
	}

	input[type='range']#cpm-slider::-webkit-slider-thumb {
		border-color: #10b981;
		box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
	}

	input[type='range']::-webkit-slider-thumb:hover {
		transform: scale(1.15);
	}

	.niche-btn.active {
		@apply bg-primary text-white border-primary shadow-[0_0_15px_rgba(79,70,229,0.3)];
	}
</style>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const viewsInput = document.getElementById('views');
		const viewsSlider = document.getElementById('views-slider');
		const viewsDisplay = document.getElementById('views-display');

		const cpmInput = document.getElementById('cpm');
		const cpmSlider = document.getElementById('cpm-slider');
		const cpmDisplay = document.getElementById('cpm-display');

		const dailyRes = document.getElementById('daily-result');
		const monthlyRes = document.getElementById('monthly-result');
		const yearlyRes = document.getElementById('yearly-result');

		const nicheBtns = document.querySelectorAll('.niche-btn');

		function updateCalculations() {
			const views = parseFloat(viewsInput.value) || 0;
			const cpm = parseFloat(cpmInput.value) || 0;

			// Sync displays
			viewsDisplay.textContent = views.toLocaleString();
			cpmDisplay.textContent = '$' + cpm.toFixed(2);

			// Logic: (Views / 1000) * CPM
			const daily = (views / 1000) * cpm;
			const monthly = daily * 30;
			const yearly = daily * 365;

			// Update Results
			dailyRes.textContent = '$' + daily.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
			monthlyRes.textContent = '$' + monthly.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
			yearlyRes.textContent = '$' + yearly.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
		}

		// Input events
		viewsSlider.addEventListener('input', (e) => {
			viewsInput.value = e.target.value;
			updateCalculations();
		});

		viewsInput.addEventListener('input', (e) => {
			viewsSlider.value = e.target.value;
			updateCalculations();
		});

		cpmSlider.addEventListener('input', (e) => {
			cpmInput.value = e.target.value;
			updateCalculations();
		});

		cpmInput.addEventListener('input', (e) => {
			cpmSlider.value = e.target.value;
			updateCalculations();
		});

		// Niche Presets
		nicheBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				nicheBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				const val = btn.getAttribute('data-cpm');
				cpmInput.value = val;
				cpmSlider.value = val;
				updateCalculations();
			});
		});

		// Initial Run
		updateCalculations();
	});
</script>