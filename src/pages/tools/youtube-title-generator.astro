---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	title="YouTube Title Generator | Hustle Teacher"
	description="Generate viral, high-CTR YouTube titles using proven psychological patterns and hooks."
>
	<main class="flex-grow pt-24 pb-20">
		<div class="docs-site-container">
			<div class="text-center mb-16 animate-fade-in-down">
				<div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-6 border border-primary/50 shadow-sm">
					🎬 Viral Tools
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold mb-6 uppercase tracking-tight">
					YouTube <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Title</span> Generator
				</h1>
				<p class="text-xl text-muted-foreground max-w-2xl mx-auto">
					Stop guessing. Use psychological triggers like curiosity, fear, and desire to get more clicks.
				</p>
			</div>

			<div class="max-w-4xl mx-auto space-y-10">
				<div class="bg-card/50 backdrop-blur-xl border border-border rounded-3xl p-8 shadow-2xl">
					<div class="space-y-6">
						<label class="text-lg font-bold block">What is your video about?</label>
						<div class="flex flex-col md:flex-row gap-4">
							<input 
								id="keyword" 
								type="text" 
								placeholder="e.g. Making Money, Travel to Japan, Coding Tutorial" 
								class="flex-1 bg-background/50 border border-border rounded-xl px-6 py-4 text-lg outline-none focus:ring-2 focus:ring-primary"
							/>
							<button id="generateBtn" class="bg-primary hover:bg-primary/90 text-white font-black px-8 py-4 rounded-xl transition-all hover:scale-105 active:scale-95 shadow-lg shadow-primary/25 whitespace-nowrap">
								GENERATE TITLES
							</button>
						</div>
					</div>
				</div>

				<div id="results-container" class="hidden space-y-4 animate-fade-in-up">
					<h3 class="text-xl font-bold px-2 flex items-center gap-2">
						✨ Your High-CTR Titles
					</h3>
					<div id="titles-grid" class="grid grid-cols-1 gap-4">
						<!-- Results injected here -->
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('generateBtn');
		const input = document.getElementById('keyword');
		const container = document.getElementById('results-container');
		const grid = document.getElementById('titles-grid');

		const templates = [
			"Why Most People Fail at {x} (And How to Succeed)",
			"I Tried {x} for 30 Days. Here's What Happened.",
			"10 {x} Secrets the Pros Don't Want You to Know",
			"How to Master {x} in 2026 (Full Guide)",
			"Stop Doing {x} Like This! (Do This Instead)",
			"The TRUTH About {x} That Nobody Tells You",
			"Is {x} Actually Worth It? (Honest Review)",
			"From $0 to $10k with {x} (Step by Step)",
			"The Ultimate {x} Checklist for Beginners",
			"5 {x} Mistakes That Are Killing Your Growth",
			"How I Built a Business Around {x} (My Story)",
			"Everything You Need to Know About {x} in 10 Minutes"
		];

		function generate() {
			const x = input.value.trim();
			if (!x) return;

			grid.innerHTML = '';
			templates.forEach(t => {
				const title = t.replace(/{x}/g, x);
				const div = document.createElement('div');
				div.className = "group bg-card border border-border rounded-2xl p-5 flex justify-between items-center hover:border-primary/50 transition-all cursor-pointer";
				div.innerHTML = `
					<span class="font-bold text-lg group-hover:text-primary transition-colors">${title}</span>
					<button class="copy-btn p-2 hover:bg-muted rounded-lg" title="Copy to clipboard">
						📋
					</button>
				`;
				div.addEventListener('click', () => {
					navigator.clipboard.writeText(title);
					const icon = div.querySelector('.copy-btn');
					icon.textContent = "✅";
					setTimeout(() => icon.textContent = "📋", 2000);
				});
				grid.appendChild(div);
			});

			container.classList.remove('hidden');
		}

		btn.addEventListener('click', generate);
		input.addEventListener('keypress', (e) => { if (e.key === 'Enter') generate(); });
	});
</script>
