---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "YouTube Channel Name Generator";
const description = "Find unique, catchy, and brandable channel name ideas for your niche.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-emerald-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-blue-500/10 text-blue-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-blue-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(59,130,246,0.1)]">
					📛 Branding Engine
				</div>
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					Channel <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500">Name</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					Your channel name is your brand. Generate creative, memorable, and unique names that resonate with your target audience.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="space-y-8">
				<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					
					<div class="relative space-y-8">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<div class="relative">
								<label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 block px-2">Your Niche/Keyword</label>
								<input 
									type="text" 
									id="niche" 
									placeholder="e.g. Finance, Gaming, Cooking" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-blue-500/50 transition-all font-bold"
								/>
							</div>
							<div class="relative">
								<label class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 block px-2">Channel Vibe</label>
								<select id="vibe" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-blue-500/50 transition-all font-bold appearance-none cursor-pointer">
									<option value="modern" class="bg-black">Modern & Sleek</option>
									<option value="playful" class="bg-black">Playful & Fun</option>
									<option value="professional" class="bg-black">Professional & Authority</option>
									<option value="minimal" class="bg-black">Short & Minimal</option>
								</select>
							</div>
						</div>
						
						<button id="generateBtn" class="w-full bg-white text-black font-black py-6 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl uppercase tracking-tighter">
							Generate Name Ideas
						</button>

						<div id="resultsArea" class="hidden animate-fade-in grid grid-cols-1 sm:grid-cols-2 gap-4">
							<!-- Names injected here -->
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const nicheInput = document.getElementById('niche');
		const vibeSelect = document.getElementById('vibe');
		const generateBtn = document.getElementById('generateBtn');
		const resultsArea = document.getElementById('resultsArea');

		const prefixes = {
			modern: ['Neo', 'Flux', 'Zen', 'Pulse', 'Vertex', 'Core'],
			playful: ['Happy', 'Crazy', 'Super', 'Funky', 'Hyper', 'Mega'],
			professional: ['Pro', 'Master', 'Expert', 'Direct', 'Prime', 'Official'],
			minimal: ['', 'The', 'Pure', 'Only']
		};

		const suffixes = {
			modern: ['Flow', 'Line', 'Grid', 'Next', 'Sphere', 'Ops'],
			playful: ['Hub', 'Zone', 'World', 'Land', 'Squad', 'Crew'],
			professional: ['Guide', 'Academy', 'Path', 'Consult', 'Focus', 'Lab'],
			minimal: ['HQ', 'Lab', 'Station', 'Room']
		};

		generateBtn.addEventListener('click', () => {
			const niche = nicheInput.value.trim();
			if (!niche) return;

			generateBtn.textContent = 'Analyzing Trends...';
			generateBtn.disabled = true;

			setTimeout(() => {
				resultsArea.innerHTML = '';
				const vibe = vibeSelect.value;
				
				const names = [];
				for(let i=0; i<8; i++) {
					const pre = prefixes[vibe][Math.floor(Math.random() * prefixes[vibe].length)];
					const suf = suffixes[vibe][Math.floor(Math.random() * suffixes[vibe].length)];
					
					let name = '';
					const type = Math.floor(Math.random() * 3);
					if (type === 0) name = `${pre}${niche}`;
					else if (type === 1) name = `${niche}${suf}`;
					else name = `${pre} ${niche} ${suf}`;
					
					names.push(name);
				}
				
				names.forEach(name => {
					const div = document.createElement('div');
					div.className = 'group/item relative bg-white/5 border border-white/10 p-6 rounded-2xl flex items-center justify-between hover:border-blue-500/40 hover:bg-blue-500/5 transition-all cursor-pointer';
					div.innerHTML = `
						<span class="font-black text-white text-lg tracking-tight">${name}</span>
						<span class="text-[10px] font-black text-gray-500 opacity-0 group-hover/item:opacity-100 transition-opacity uppercase tracking-widest">Copy</span>
					`;
					div.onclick = () => {
						navigator.clipboard.writeText(name);
						const span = div.querySelector('span:last-child');
						span.textContent = 'Saved!';
						setTimeout(() => span.textContent = 'Copy', 2000);
					};
					resultsArea.appendChild(div);
				});

				resultsArea.classList.remove('hidden');
				generateBtn.textContent = 'Generate Name Ideas';
				generateBtn.disabled = false;
			}, 800);
		});
	});
</script>
