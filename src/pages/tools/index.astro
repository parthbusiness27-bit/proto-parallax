---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/cards/ToolCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';

const allTools = await getCollection('tools');

// Get unique categories from tools
const toolCategories = [...new Set(allTools.map(t => t.data.category))];

// Categorization Logic - mapping tool categories to display names
const categoryMap: Record<string, { id: string; name: string; icon: string }> = {
    'Bio Gens': { id: 'bio', name: 'Bio Generators', icon: '📸' },
    'Description Gens': { id: 'description', name: 'Description Generators', icon: '📝' },
    'Name Gens': { id: 'name', name: 'Name Generators', icon: '🚀' },
    'Idea Gens': { id: 'idea', name: 'Idea Generators', icon: '💡' },
    'Revenue Gens': { id: 'revenue', name: 'Revenue Calculators', icon: '💹' },
    'Writing Gens': { id: 'writing', name: 'Writing Generators', icon: '✍️' },
    'SEO Gens': { id: 'seo', name: 'SEO Generators', icon: '📈' }
};

// Group tools by their category
const groupedTools = toolCategories.map(catName => {
    const config = categoryMap[catName] || { id: catName.toLowerCase().replace(/\s+/g, '-'), name: catName, icon: '🔧' };
    return {
        ...config,
        id: config.id,
        name: config.name,
        icon: config.icon,
        tools: allTools.filter(t => t.data.category === catName)
    };
}).filter(g => g.tools.length > 0);

const title = "Tools Directory";
const description = "The ultimate creator toolkit. 25+ free and premium tools to grow your digital income.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<main class="flex-grow pt-24 pb-12 md:pt-32 md:pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Mesh Gradient Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-emerald-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 px-4 sm:px-6">
			<!-- Cinematic Header -->
			<div class="text-center mb-10 md:mb-16">
				<div class="inline-flex items-center gap-2 bg-primary/10 text-primary-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-primary/20 uppercase tracking-widest shadow-[0_0_20px_rgba(79,70,229,0.15)] animate-fade-in-down">
					🚀 {allTools.length} Professional Tools Available
				</div>
				<h1 class="text-5xl md:text-8xl font-black text-white mb-6 uppercase tracking-tighter leading-none">
					Creator <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-emerald-400 to-primary-600 animate-gradient">Toolkit</span>
				</h1>
				<p class="text-xl text-gray-400 max-w-3xl mx-auto font-medium leading-relaxed">
					The ultimate directory of software, calculators, and generators to help you build and scale your online income faster.
				</p>
			</div>

			<!-- Unified Search Bar -->
			<div class="max-w-3xl mx-auto mb-20 px-4 relative group">
				<div class="absolute inset-0 bg-primary/20 blur-[50px] opacity-0 group-hover:opacity-40 transition-opacity duration-700"></div>
				<div class="relative bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-full p-2 flex items-center shadow-2xl">
					<div class="pl-6 text-gray-400 text-2xl">🔍</div>
					<input 
						type="text" 
						id="tool-search" 
						placeholder="Search through professional tools..." 
						class="w-full bg-transparent border-none px-6 py-4 text-white text-lg outline-none placeholder:text-gray-600 font-bold"
					/>
				</div>
			</div>

			<!-- Categorized Tool Sections -->
			<div class="space-y-16 md:space-y-24" id="tools-container">
                {groupedTools.map((group) => (
                    <section class="tool-category-section space-y-8" data-category={group.id}>
                        <div class="flex items-center gap-4 mb-10 pb-4 border-b border-white/5">
                            <span class="text-3xl">{group.icon}</span>
                            <h2 class="text-2xl md:text-3xl font-black text-white uppercase tracking-tighter">
                                {group.name}
                                <span class="ml-4 text-[10px] font-black text-gray-600 tracking-widest bg-white/5 px-2 py-1 rounded-full">{group.tools.length} TOOLS</span>
                            </h2>
                        </div>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                            {group.tools.map((tool) => (
                                <div class="tool-card-wrapper transition-all duration-500 animate-fade-in">
                                    <ToolCard 
                                        title={tool.data.title}
                                        description={tool.data.description}
                                        url={tool.data.url}
                                        icon={tool.data.icon}
                                        isPremium={tool.data.isPremium}
                                        price={tool.data.price}
                                    />
                                </div>
                            ))}
                        </div>
                    </section>
                ))}
			</div>

			<!-- No Results State -->
			<div id="no-results" class="hidden text-center py-32 animate-fade-in relative px-4">
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary/20 rounded-full blur-[120px] -z-10"></div>
				<div class="text-8xl mb-10 grayscale opacity-40">🔍</div>
				<h3 class="text-4xl font-black text-white mb-4 uppercase tracking-tighter italic">No Tool Found</h3>
				<p class="text-gray-400 font-medium mb-12 max-w-md mx-auto">We couldn't find exactly what you're looking for. Try a different keyword or browse our categories.</p>
				<button onclick="document.getElementById('tool-search').value = ''; document.getElementById('tool-search').dispatchEvent(new Event('input'));" class="bg-primary hover:bg-primary-600 text-white font-black px-10 py-5 rounded-full transition-all shadow-xl shadow-primary/20 uppercase tracking-widest text-xs">
					Clear Search Filter
				</button>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	(() => {
		const searchInput = document.getElementById('tool-search');
		const categorySections = document.querySelectorAll('.tool-category-section');
		const noResults = document.getElementById('no-results');

		function handleSearch() {
			const query = searchInput.value.toLowerCase().trim();
			let totalVisibleTools = 0;

			categorySections.forEach(section => {
				let sectionHasVisibleTools = false;
				const sectionTools = section.querySelectorAll('.tool-card-wrapper');
				
				sectionTools.forEach(wrapper => {
					const title = wrapper.querySelector('h4').textContent.toLowerCase();
					const desc = wrapper.querySelector('p').textContent.toLowerCase();
					
					if (title.includes(query) || desc.includes(query)) {
						wrapper.classList.remove('hidden');
						sectionHasVisibleTools = true;
						totalVisibleTools++;
					} else {
						wrapper.classList.add('hidden');
					}
				});

				// Show/hide entire category section
				if (sectionHasVisibleTools) {
					section.classList.remove('hidden');
				} else {
					section.classList.add('hidden');
				}
			});

			if (totalVisibleTools > 0 || query === '') {
				noResults.classList.add('hidden');
			} else {
				noResults.classList.remove('hidden');
			}
		}

		if (searchInput) {
			searchInput.addEventListener('input', handleSearch);
		}
	})();
</script>

<style>
	@keyframes fade-in {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-fade-in {
		animation: fade-in 0.5s ease-out forwards;
	}

    .tool-category-section {
        animation: fade-in 0.8s ease-out forwards;
    }

	.tool-card-wrapper.hidden {
		display: none !important;
	}

    .animate-gradient {
        background-size: 200% auto;
        animation: gradient 5s linear infinite;
    }

    @keyframes gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
</style>