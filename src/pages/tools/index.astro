---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/cards/ToolCard.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

// Fetch all tool entries from the content collection
const allTools = await getCollection('tools');

// Separate into Free and Premium arrays
const freeTools = allTools.filter(tool => !tool.data.isPremium);
const premiumTools = allTools.filter(tool => tool.data.isPremium);
---

<BaseLayout title={`Best Side Hustle Tools | ${SITE_TITLE}`} description="Discover the best free and premium tools to grow your online income, boost productivity, and automate your side hustle.">
	<main class="flex-grow pt-24 pb-20 relative overflow-hidden">
		<!-- Global Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[10%] left-[5%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px] animate-pulse"></div>
			<div class="absolute bottom-[20%] right-[5%] w-[30%] h-[40%] bg-emerald-500/10 rounded-full blur-[100px] animate-pulse" style="animation-delay: 2s;"></div>
		</div>

        <div class="docs-site-container relative z-10">
                             
			<!-- Header Section -->
			<div class="mb-20 text-center md:text-left">
				<div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-6 border border-primary/50 shadow-[0_0_15px_rgba(79,70,229,0.2)] animate-fade-in-down">
					🛠️ Productivity Suite
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold mb-6 animate-fade-in-up uppercase tracking-tighter">
					Creator <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Toolkit</span>
				</h1>
				<p class="text-xl text-muted-foreground max-w-2xl animate-fade-in-up mb-12" style="animation-delay: 150ms;">
					The ultimate collection of calculators, generators, and side hustle engines built to help you scale your digital empire.
				</p>

				<!-- Search Bar with Glow -->
				<div class="relative max-w-2xl mx-auto md:mx-0 animate-fade-in-up group" style="animation-delay: 200ms;">
					<div class="absolute -inset-1 bg-gradient-to-r from-primary to-emerald-500 rounded-2xl blur opacity-25 group-focus-within:opacity-50 transition-opacity duration-500"></div>
					<div class="relative flex items-center bg-card/80 backdrop-blur-2xl border border-white/10 rounded-2xl shadow-2xl overflow-hidden">
						<div class="pl-6 flex items-center pointer-events-none">
							<span class="text-2xl">🔍</span>
						</div>
						<input 
							id="toolSearch" 
							type="text" 
							placeholder="Search tools (e.g. money, youtube, blog)..." 
							class="w-full bg-transparent pl-4 pr-6 py-5 text-xl outline-none text-foreground placeholder:text-muted-foreground/50 transition-all font-medium"
						/>
					</div>
				</div>
			</div>

			<!-- Free Tools Section -->
			<div id="freeSection" class={`mb-24 animate-fade-in-up ${freeTools.length === 0 ? 'hidden' : ''}`} style="animation-delay: 300ms;">
				<div class="flex items-center gap-4 mb-10">
					<div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
					<h2 class="text-2xl font-black text-foreground flex items-center gap-3 px-4 uppercase tracking-widest whitespace-nowrap">
						<span class="text-3xl">🎁</span>
						Free Tools
					</h2>
					<div class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 tools-grid">
					{freeTools.map(tool => (
						<div class="tool-card-wrapper transition-all duration-500" data-title={tool.data.title.toLowerCase()} data-desc={tool.data.description.toLowerCase()}>
							<ToolCard 
								title={tool.data.title}
								description={tool.data.description}
								url={tool.data.url}
								icon={tool.data.icon}
								isPremium={false}
							/>
						</div>
					))}
				</div>
			</div>

			<!-- Premium Tools Section -->
			<div id="premiumSection" class={`animate-fade-in-up ${premiumTools.length === 0 ? 'hidden' : ''}`} style="animation-delay: 450ms;">
				<div class="flex items-center gap-4 mb-10">
					<div class="h-px flex-1 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
					<h2 class="text-2xl font-black text-primary flex items-center gap-3 px-4 uppercase tracking-widest whitespace-nowrap">
						<span class="text-3xl text-primary">💎</span>
						Premium Software
					</h2>
					<div class="h-px flex-1 bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 tools-grid">
					{premiumTools.map(tool => (
						<div class="tool-card-wrapper transition-all duration-500" data-title={tool.data.title.toLowerCase()} data-desc={tool.data.description.toLowerCase()}>
							<ToolCard 
								title={tool.data.title}
								description={tool.data.description}
								url={tool.data.url}
								icon={tool.data.icon}
								isPremium={true}
								price={tool.data.price}
							/>
						</div>
					))}
				</div>
			</div>

			<div id="noResults" class="hidden py-32 text-center border border-dashed border-primary/20 rounded-3xl bg-primary/5 backdrop-blur-sm">
				<div class="text-6xl mb-6 opacity-30">🕵️‍♂️</div>
				<p class="text-muted-foreground text-2xl font-bold">Nothing matches your search.</p>
				<button onclick="document.getElementById('toolSearch').value=''; document.getElementById('toolSearch').dispatchEvent(new Event('input'))" class="mt-6 text-primary hover:underline font-bold text-lg">Clear search & show all tools</button>
			</div>

			{allTools.length === 0 && (
				<div class="py-20 text-center border border-dashed border-border rounded-2xl bg-muted/30">
					<p class="text-muted-foreground">Tools are currently being updated. Check back soon!</p>
				</div>
			)}

		</div>
	</main>v>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const searchInput = document.getElementById('toolSearch');
		const cardWrappers = document.querySelectorAll('.tool-card-wrapper');
		const freeSection = document.getElementById('freeSection');
		const premiumSection = document.getElementById('premiumSection');
		const noResults = document.getElementById('noResults');

		searchInput?.addEventListener('input', (e) => {
			const query = e.target.value.toLowerCase();
			let visibleFree = 0;
			let visiblePremium = 0;

			cardWrappers.forEach(wrapper => {
				const title = wrapper.getAttribute('data-title');
				const desc = wrapper.getAttribute('data-desc');
				const isVisible = title.includes(query) || desc.includes(query);
				
				wrapper.classList.toggle('hidden', !isVisible);
				
				if (isVisible) {
					if (wrapper.closest('#freeSection')) visibleFree++;
					if (wrapper.closest('#premiumSection')) visiblePremium++;
				}
			});

			// Hide/show headers if no tools are visible in that category
			if (freeSection) freeSection.classList.toggle('hidden', visibleFree === 0 && query !== '');
			if (premiumSection) premiumSection.classList.toggle('hidden', visiblePremium === 0 && query !== '');
			
			// Global no results message
			if (noResults) {
				const totalVisible = visibleFree + visiblePremium;
				noResults.classList.toggle('hidden', totalVisible > 0 || query === '');
			}
		});
	});
</script>