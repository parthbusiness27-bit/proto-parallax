---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "Hashtag Generator";
const description = "Generate trending and relevant hashtags for TikTok, Instagram, and Twitter.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-emerald-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-emerald-500/10 text-emerald-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-emerald-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(16,185,129,0.1)]">
					＃ Viral Reach
				</div>
				<h1 class="text-3xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					Hashtag <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-primary">Generator</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					Stop guessing. Generate optimized hashtag sets for your posts to hit the Explore page and reach new audiences.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="space-y-8">
				<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-6 md:p-12 shadow-2xl relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					
					<div class="relative space-y-8">
                        <div class="flex flex-col md:flex-row gap-4">
							<div class="flex-1 relative">
								<input 
									type="text" 
									id="topic" 
									placeholder="Enter post topic (e.g. Travel, Bitcoin, Coding)" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-8 py-6 text-xl text-white outline-none focus:border-emerald-500/50 transition-all font-bold placeholder:text-gray-600"
								/>
                                <div class="absolute right-6 top-1/2 -translate-y-1/2 flex items-center gap-4">
                                    <select id="platform" class="bg-transparent text-gray-500 font-black text-xs uppercase outline-none cursor-pointer hover:text-white transition-colors">
                                        <option value="instagram" class="bg-black">Instagram</option>
                                        <option value="tiktok" class="bg-black">TikTok</option>
                                        <option value="linkedin" class="bg-black">LinkedIn</option>
                                    </select>
                                </div>
							</div>
							<button id="generateBtn" class="bg-white text-black font-black px-12 py-6 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl uppercase tracking-tighter whitespace-nowrap">
								Generate
							</button>
						</div>

						<div id="resultsArea" class="hidden animate-fade-in space-y-6">
							<div class="flex justify-between items-center bg-black/40 p-3 rounded-2xl border border-white/5">
								<span class="text-[10px] font-black text-gray-500 uppercase tracking-widest px-4">Optimized Set</span>
								<button id="copyBtn" class="bg-emerald-500 text-white text-[10px] font-black px-6 py-2 rounded-xl hover:bg-emerald-600 transition-colors uppercase tracking-widest shadow-lg">
									Copy All
								</button>
							</div>
							
							<div id="hashtagContainer" class="flex flex-wrap gap-2 min-h-[120px]">
								<!-- Hashtags injected here -->
							</div>

                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 border-t border-white/5 pt-6">
                                <div class="text-center">
                                    <span class="text-xs font-black text-emerald-400 block pb-1">30m+</span>
                                    <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Est. Reach</span>
                                </div>
                                <div class="text-center">
                                    <span class="text-xs font-black text-emerald-400 block pb-1">98%</span>
                                    <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Relevance</span>
                                </div>
                                <div class="text-center">
                                    <span class="text-xs font-black text-emerald-400 block pb-1">Low</span>
                                    <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Competition</span>
                                </div>
                            </div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const topicInput = document.getElementById('topic');
		const platformSelect = document.getElementById('platform');
		const generateBtn = document.getElementById('generateBtn');
		const resultsArea = document.getElementById('resultsArea');
		const hashtagContainer = document.getElementById('hashtagContainer');
		const copyBtn = document.getElementById('copyBtn');

		const variations = [
			'', 'daily', 'tips', 'life', 'world', 'hacks', 'guide', 'mastery', 'pro', 'expert'
		];

		generateBtn.addEventListener('click', () => {
			const topic = topicInput.value.trim().toLowerCase().replace(/\s+/g, '');
			if (!topic) return;

			generateBtn.textContent = 'Analyzing Trends...';
			generateBtn.disabled = true;

			setTimeout(() => {
				hashtagContainer.innerHTML = '';
				const platform = platformSelect.value;
				
				const tags = [];
				// Base tag
				tags.push(`#${topic}`);
				
				// Generate variations
				variations.slice(0, 15).forEach(v => {
					tags.push(`#${topic}${v}`);
					if (v) tags.push(`#${v}${topic}`);
				});

				// Add viral tags based on platform
				if (platform === 'tiktok') tags.push('#fyp', '#viral', '#trending', '#foryou');
				if (platform === 'instagram') tags.push('#explore', '#trending', '#instagood');

				const uniqueTags = [...new Set(tags)].slice(0, 25);
				
				uniqueTags.forEach(tag => {
					const span = document.createElement('span');
					span.className = 'bg-emerald-500/10 border border-emerald-500/20 px-4 py-2 rounded-xl text-sm font-bold text-emerald-400 hover:bg-emerald-500 hover:text-white transition-all cursor-pointer';
					span.textContent = tag;
                    span.onclick = () => {
                        navigator.clipboard.writeText(tag);
                        span.textContent = 'Copied!';
                        setTimeout(() => span.textContent = tag, 1000);
                    }
					hashtagContainer.appendChild(span);
				});

				resultsArea.classList.remove('hidden');
				generateBtn.textContent = 'Generate';
				generateBtn.disabled = false;
			}, 700);
		});

		copyBtn.addEventListener('click', () => {
			const tags = Array.from(hashtagContainer.querySelectorAll('span')).map(s => s.textContent).join(' ');
			navigator.clipboard.writeText(tags);
			
			const originalText = copyBtn.textContent;
			copyBtn.textContent = 'Saved!';
			setTimeout(() => copyBtn.textContent = originalText, 2000);
		});
	});
</script>
