---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "YouTube CPM Calculator";
const description = "Calculate your estimated earnings based on Cost Per Mille (CPM) and total views.";
---

<ToolLayout 
	title={title} 
	description={description} 
	emoji="▶️"
	category="YouTube Growth"
	subtitle={description}
	conceptTitle="What is {title}?"
	conceptDescription={[
		"This tool helps you accurately calculate and generate insights for " + title + ".",
		"By using this free utility, you can streamline your digital hustle and make more informed decisions."
	]}
>
	<div class="w-full space-y-8 relative z-20">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Left Column: Inputs -->
				<div class="lg:col-span-7 space-y-6">
					<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group">
						<div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						
						<div class="relative space-y-8">
							<!-- Daily Views -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label for="views" class="text-sm font-black text-gray-400 uppercase tracking-widest">Total Views</label>
									<span class="text-3xl font-black text-white" id="views-display">50,000</span>
								</div>
								<input type="range" id="views-slider" min="1000" max="1000000" step="1000" value="50000" class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-primary" />
								<div class="flex items-center gap-3">
									<span class="text-xs text-gray-500 font-bold uppercase tracking-widest">Manual Input:</span>
									<input type="number" id="views" value="50000" class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-white font-bold w-32 focus:border-primary/50 outline-none transition-all" />
								</div>
							</div>

							<!-- CPM Rate -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label for="cpm" class="text-sm font-black text-gray-400 uppercase tracking-widest">CPM Rate ($)</label>
									<span class="text-3xl font-black text-emerald-400" id="cpm-display">$4.00</span>
								</div>
								<input type="range" id="cpm-slider" min="0.1" max="50" step="0.1" value="4" class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
								<div class="flex items-center gap-3">
									<span class="text-xs text-gray-500 font-bold uppercase tracking-widest">Manual Input:</span>
									<input type="number" id="cpm" value="4" step="0.1" class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-white font-bold w-24 focus:border-emerald-500/50 outline-none transition-all" />
								</div>
							</div>

							<!-- Niche Presets -->
							<div class="pt-6 border-t border-white/5">
								<p class="text-xs font-black text-gray-500 uppercase tracking-widest mb-4">Common Industry CPMs</p>
								<div class="flex flex-wrap gap-2">
									<button class="niche-btn" data-cpm="2.5">Entertainment</button>
									<button class="niche-btn" data-cpm="5.0">Lifestyle</button>
									<button class="niche-btn active" data-cpm="10.0">Finance</button>
									<button class="niche-btn" data-cpm="8.0">Tech</button>
									<button class="niche-btn" data-cpm="15.0">Business</button>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Results -->
				<div class="lg:col-span-5">
					<div class="bg-gradient-to-br from-primary/10 to-emerald-500/10 backdrop-blur-3xl border border-primary/20 rounded-[2.5rem] p-10 shadow-2xl sticky top-32 text-center group overflow-hidden">
						<div class="absolute -right-10 -top-10 text-[10rem] opacity-5 group-hover:scale-110 transition-transform duration-700">💰</div>
						
						<div class="relative space-y-8">
							<div>
								<span class="text-xs font-black uppercase tracking-widest text-primary-400 mb-2 block">Total Estimated Revenue</span>
								<div class="text-6xl md:text-7xl font-black text-white" id="total-result">$200.00</div>
							</div>

							<div class="grid grid-cols-2 gap-4">
								<div class="bg-white/5 rounded-2xl p-4 border border-white/10">
									<span class="text-[10px] font-black uppercase tracking-tighter text-gray-400 mb-1 block">Net After Share (55%)</span>
									<div class="text-2xl font-black text-emerald-400" id="net-result">$110.00</div>
								</div>
								<div class="bg-white/5 rounded-2xl p-4 border border-white/10">
									<span class="text-[10px] font-black uppercase tracking-tighter text-gray-400 mb-1 block">Per 1k Views</span>
									<div class="text-2xl font-black text-white" id="per1k-result">$4.00</div>
								</div>
							</div>

							<button class="w-full bg-white text-black font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl uppercase tracking-tighter flex items-center justify-center gap-3">
								Optimize Your CPM
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
							</button>

							<p class="text-xs text-gray-500 font-medium italic">
								*Estimates based on gross CPM before platform cuts and taxes.
							</p>
						</div>
					</div>
				
	</div>
</ToolLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const viewsInput = document.getElementById('views');
		const viewsSlider = document.getElementById('views-slider');
		const viewsDisplay = document.getElementById('views-display');

		const cpmInput = document.getElementById('cpm');
		const cpmSlider = document.getElementById('cpm-slider');
		const cpmDisplay = document.getElementById('cpm-display');

		const totalRes = document.getElementById('total-result');
		const netRes = document.getElementById('net-result');
		const per1kRes = document.getElementById('per1k-result');

		const nicheBtns = document.querySelectorAll('.niche-btn');

		function updateCalculations() {
			const views = parseFloat(viewsInput.value) || 0;
			const cpm = parseFloat(cpmInput.value) || 0;

			// Sync displays
			viewsDisplay.textContent = views.toLocaleString();
			cpmDisplay.textContent = '$' + cpm.toFixed(2);

			// Logic: (Views / 1000) * CPM
			const total = (views / 1000) * cpm;
			const net = total * 0.55; // Standard creator share

			// Update Results
			totalRes.textContent = '$' + total.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
			netRes.textContent = '$' + net.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
			per1kRes.textContent = '$' + cpm.toFixed(2);
		}

		// Input events
		viewsSlider.addEventListener('input', (e) => {
			viewsInput.value = e.target.value;
			updateCalculations();
		});

		viewsInput.addEventListener('input', (e) => {
			viewsSlider.value = e.target.value;
			updateCalculations();
		});

		cpmSlider.addEventListener('input', (e) => {
			cpmInput.value = e.target.value;
			updateCalculations();
		});

		cpmInput.addEventListener('input', (e) => {
			cpmSlider.value = e.target.value;
			updateCalculations();
		});

		// Niche Presets
		nicheBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				nicheBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				const val = btn.getAttribute('data-cpm');
				cpmInput.value = val;
				cpmSlider.value = val;
				updateCalculations();
			});
		});

		// Initial Run
		updateCalculations();
	});
</script>
