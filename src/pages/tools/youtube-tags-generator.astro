---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "YouTube Tags Generator";
const description = "Generate high-ranking SEO tags for your videos based on your main keyword.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-emerald-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-purple-500/10 text-purple-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-purple-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(168,85,247,0.1)]">
					🏷️ SEO Optimization
				</div>
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					Tags <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-primary">Generator</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					Create optimized video tags in seconds. Improve your YouTube SEO and help the algorithm understand exactly what your content is about.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="space-y-8">
				<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					
					<div class="relative space-y-8">
						<div class="flex flex-col md:flex-row gap-4">
							<div class="flex-1 relative">
								<input 
									type="text" 
									id="keyword" 
									placeholder="Enter your video topic (e.g. Side Hustle 2026)" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-8 py-6 text-xl text-white outline-none focus:border-purple-500/50 transition-all font-bold placeholder:text-gray-600"
								/>
							</div>
							<button id="generateBtn" class="bg-white text-black font-black px-10 py-6 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl uppercase tracking-tighter whitespace-nowrap">
								Generate Tags
							</button>
						</div>

						<div id="resultsArea" class="hidden animate-fade-in space-y-6">
							<div class="flex justify-between items-center">
								<h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Optimized Tags</h3>
								<button id="copyBtn" class="text-xs font-black text-purple-400 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-2 bg-purple-500/10 px-4 py-2 rounded-full border border-purple-500/20">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
									Copy All
								</button>
							</div>
							
							<div id="tagsContainer" class="flex flex-wrap gap-2 p-6 bg-black/40 rounded-3xl border border-white/5 min-h-[100px]">
								<!-- Tags injected here -->
							</div>

                            <p class="text-xs text-gray-500 font-medium text-center">
                                *Use 1-2 broad tags, 3-5 specific tags, and your brand tag for best results.
                            </p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const keywordInput = document.getElementById('keyword');
		const generateBtn = document.getElementById('generateBtn');
		const resultsArea = document.getElementById('resultsArea');
		const tagsContainer = document.getElementById('tagsContainer');
		const copyBtn = document.getElementById('copyBtn');

		const tagPatterns = [
			"{kw}", "{kw} 2026", "how to {kw}", "best {kw}", "{kw} for beginners",
			"{kw} tutorial", "{kw} tips", "{kw} examples", "expert {kw}",
			"{kw} strategy", "earning from {kw}", "{kw} guide", "{kw} review"
		];

		generateBtn.addEventListener('click', () => {
			const kw = keywordInput.value.trim();
			if (!kw) return;

			generateBtn.textContent = 'Generating...';
			generateBtn.disabled = true;

			setTimeout(() => {
				tagsContainer.innerHTML = '';
				const tags = tagPatterns.map(p => p.replace('{kw}', kw));
				
				tags.forEach(tag => {
					const span = document.createElement('span');
					span.className = 'bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-sm font-bold text-gray-300 hover:border-purple-500/30 hover:text-white transition-all cursor-default';
					span.textContent = tag;
					tagsContainer.appendChild(span);
				});

				resultsArea.classList.remove('hidden');
				generateBtn.textContent = 'Generate Tags';
				generateBtn.disabled = false;
				
				// Scroll to results
				resultsArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			}, 600);
		});

		copyBtn.addEventListener('click', () => {
			const tags = Array.from(tagsContainer.querySelectorAll('span')).map(s => s.textContent).join(', ');
			navigator.clipboard.writeText(tags);
			
			const originalText = copyBtn.innerHTML;
			copyBtn.innerHTML = 'Copied!';
			setTimeout(() => copyBtn.innerHTML = originalText, 2000);
		});

		// Enter key support
		keywordInput.addEventListener('keypress', (e) => {
			if (e.key === 'Enter') generateBtn.click();
		});
	});
</script>
