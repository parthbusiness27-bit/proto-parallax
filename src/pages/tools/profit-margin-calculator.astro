---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "Profit Margin Calculator";
const description = "Calculate your net profit margins, cost of goods, and markup to ensure your business remains profitable.";
---

<ToolLayout 
	title={title} 
	description={description} 
	emoji="💹"
	category="Finance"
	subtitle="Smarter pricing starts here. Calculate your profit percentage, total profit, and markup to ensure your products generate the revenue you deserve."
	conceptTitle="What is Profit Margin?"
	conceptDescription={[
		"Profit margin is one of the most important accounting ratios used to determine the financial health of a business. It represents the percentage of revenue that remains in your business after all operating expenses, taxes, and costs are deducted.",
		"For digital entrepreneurs and freelancers, knowing your exact profit margin ensures you aren't just making sales, but actually keeping the money you generate."
	]}
	faqs={[
		{ q: "What is a good profit margin?", a: "For retail, a 10% net profit margin is considered average, while 20% is excellent. For digital products or SaaS, margins can frequently exceed 70% due to low variable costs." },
		{ q: "How is Markup different from Profit Margin?", a: "Markup is the percentage added to your cost to reach your selling price. Margin is the percentage of the selling price that is profit. A 100% markup results in a 50% profit margin." }
	]}
	howToSteps={[
		"Enter your primary Cost of Item into the first field.",
		"Enter your intended Selling Price across your platforms.",
		"Review your Net Profit Margin and Markup percentages instantly below."
	]}
>
	<!-- Left Column: Inputs -->
	<div class="space-y-6">
		<div class="bg-card border border-border backdrop-blur-2xl rounded-3xl p-8 md:p-10 shadow-2xl relative overflow-hidden group">
			<div class="absolute inset-0 bg-gradient-to-br from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
			
			<div class="relative space-y-8">
				<div class="space-y-4">
					<label class="text-xs font-black text-muted-foreground uppercase tracking-widest block px-2">Cost of Item ($)</label>
					<div class="relative">
						<span class="absolute left-6 top-1/2 -translate-y-1/2 text-2xl font-black text-muted-foreground">$</span>
						<input 
							type="number" 
							id="cost" 
							value="50" 
							class="w-full bg-background border border-border rounded-2xl pl-12 pr-8 py-6 text-3xl font-black text-foreground outline-none focus:border-secondary transition-all"
						/>
					</div>
				</div>

				<div class="space-y-4">
					<label class="text-xs font-black text-muted-foreground uppercase tracking-widest block px-2">Selling Price ($)</label>
					<div class="relative">
						<span class="absolute left-6 top-1/2 -translate-y-1/2 text-2xl font-black text-muted-foreground">$</span>
						<input 
							type="number" 
							id="price" 
							value="100" 
							class="w-full bg-background border border-border rounded-2xl pl-12 pr-8 py-6 text-3xl font-black text-foreground outline-none focus:border-secondary transition-all"
						/>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Left Column: Results -->
	<div class="mt-8">
		<div class="bg-gradient-to-br from-card to-background border border-secondary/20 rounded-3xl p-10 shadow-[0_0_40px_rgba(45,106,45,0.1)] text-center group overflow-hidden relative">
			<div class="absolute -right-10 -top-10 text-[10rem] opacity-5 group-hover:scale-110 transition-transform duration-700">💹</div>
			
			<div class="relative space-y-8 z-10">
				<div class="grid grid-cols-1 gap-6">
					<div class="bg-background/80 rounded-3xl p-8 border border-border">
						<span class="text-xs font-black uppercase tracking-widest text-secondary-accent mb-2 block">Net Profit Margin</span>
						<div class="text-6xl md:text-7xl font-black text-foreground drop-shadow-md" id="margin-result">50%</div>
					</div>
					
					<div class="grid grid-cols-2 gap-4">
						<div class="bg-card rounded-2xl p-6 border border-border">
							<span class="text-[10px] font-black uppercase tracking-tighter text-muted-foreground mb-2 block">Profit Amount</span>
							<div class="text-3xl font-black text-foreground" id="profit-result">$50.00</div>
						</div>
						<div class="bg-card rounded-2xl p-6 border border-border">
							<span class="text-[10px] font-black uppercase tracking-tighter text-muted-foreground mb-2 block">Markup</span>
							<div class="text-3xl font-black text-primary" id="markup-result">100%</div>
						</div>
					</div>
				</div>

				<button class="w-full bg-secondary hover:bg-secondary-accent text-black font-black py-5 rounded-2xl transition-all shadow-xl uppercase tracking-tighter text-base md:text-lg">
					Analyze Pricing Strategy
				</button>
			</div>
		</div>
	</div>

</ToolLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const costInput = document.getElementById('cost');
		const priceInput = document.getElementById('price');

		const marginRes = document.getElementById('margin-result');
		const profitRes = document.getElementById('profit-result');
		const markupRes = document.getElementById('markup-result');

		function updateCalculations() {
			const cost = parseFloat(costInput.value) || 0;
			const price = parseFloat(priceInput.value) || 0;

			// Logic
			const profit = price - cost;
			const margin = price > 0 ? (profit / price) * 100 : 0;
			const markup = cost > 0 ? (profit / cost) * 100 : 0;

			// Update Results
			marginRes.textContent = margin.toFixed(1) + '%';
			profitRes.textContent = '$' + profit.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
			markupRes.textContent = markup.toFixed(1) + '%';
		}

		// Input events
		costInput.addEventListener('input', updateCalculations);
		priceInput.addEventListener('input', updateCalculations);

		// Initial Run
		updateCalculations();
	});
</script>
