---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "Freelance Hourly Rate Calculator";
const description = "Free tools and resources for Freelance Hourly Rate Calculator.";
---

<ToolLayout 
	title={title} 
	description={description} 
	emoji="🧮"
	category="Financial Calculators"
	subtitle={description}
	conceptTitle="What is {title}?"
	conceptDescription={[
		"This tool helps you accurately calculate and generate insights for " + title + ".",
		"By using this free utility, you can streamline your digital hustle and make more informed decisions."
	]}
>
	<div class="w-full space-y-8 relative z-20">
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
				<div class="lg:col-span-2 space-y-8 animate-fade-in-up">
					<div class="bg-card/50 backdrop-blur-xl border border-border rounded-3xl p-8 shadow-2xl space-y-10">
						<!-- Desired Income -->
						<div class="space-y-4">
							<div class="flex justify-between items-end">
								<label class="text-lg font-bold">Desired Net Monthly Income ($)</label>
								<span class="text-2xl font-black text-primary" id="income-display">$5,000</span>
							</div>
							<input type="range" id="income-slider" min="1000" max="50000" step="500" value="5000" class="w-full h-3 bg-muted rounded-lg appearance-none cursor-pointer accent-primary" />
							<input id="income" type="number" value="5000" class="w-full bg-background/50 border border-border rounded-xl px-4 py-2" />
						</div>

						<!-- Monthly Expenses -->
						<div class="space-y-4">
							<div class="flex justify-between items-end">
								<label class="text-lg font-bold">Monthly Business Expenses & Taxes ($)</label>
								<span class="text-2xl font-black text-emerald-500" id="expenses-display">$1,500</span>
							</div>
							<input type="range" id="expenses-slider" min="0" max="20000" step="100" value="1500" class="w-full h-3 bg-muted rounded-lg appearance-none cursor-pointer accent-emerald-500" />
							<input id="expenses" type="number" value="1500" class="w-full bg-background/50 border border-border rounded-xl px-4 py-2" />
						</div>

						<!-- Billable Hours -->
						<div class="space-y-4">
							<div class="flex justify-between items-end">
								<label class="text-lg font-bold">Billable Hours Per Week</label>
								<span class="text-2xl font-black text-indigo-400" id="hours-display">25</span>
							</div>
							<input type="range" id="hours-slider" min="1" max="80" step="1" value="25" class="w-full h-3 bg-muted rounded-lg appearance-none cursor-pointer accent-indigo-400" />
							<input id="hours" type="number" value="25" class="w-full bg-background/50 border border-border rounded-xl px-4 py-2" />
						</div>
					</div>
				</div>

				<div class="space-y-6 animate-fade-in-up" style="animation-delay: 300ms;">
					<h2 class="text-2xl font-bold px-2">Your Rates</h2>
					
					<div class="bg-gradient-to-br from-primary/10 to-emerald-500/10 border border-primary/20 rounded-3xl p-8 shadow-xl text-center">
						<span class="text-sm font-bold uppercase tracking-widest text-primary">Recommended Hourly Rate</span>
						<div class="text-6xl font-black text-foreground mt-2" id="hourly-result">$65</div>
						<p class="text-xs text-muted-foreground mt-4">Based on 4 weeks per month</p>
					</div>

					<div class="bg-card border border-border rounded-2xl p-6 shadow-lg">
						<span class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Required Monthly Revenue</span>
						<div class="text-3xl font-bold text-foreground mt-1" id="revenue-result">$6,500</div>
					</div>
				
	</div>
</ToolLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const inputs = ['income', 'expenses', 'hours'];
		const els = {};
		inputs.forEach(i => {
			els[i] = document.getElementById(i);
			els[i+'Slider'] = document.getElementById(i+'-slider');
			els[i+'Display'] = document.getElementById(i+'-display');
		});

		const hourlyRes = document.getElementById('hourly-result');
		const revenueRes = document.getElementById('revenue-result');

		function update() {
			const income = parseFloat(els.income.value) || 0;
			const expenses = parseFloat(els.expenses.value) || 0;
			const hours = parseFloat(els.hours.value) || 1;

			els.incomeDisplay.textContent = '$' + income.toLocaleString();
			els.expensesDisplay.textContent = '$' + expenses.toLocaleString();
			els.hoursDisplay.textContent = hours;

			const totalNeeded = income + expenses;
			const hourly = totalNeeded / (hours * 4);

			hourlyRes.textContent = '$' + Math.ceil(hourly);
			revenueRes.textContent = '$' + totalNeeded.toLocaleString();
		}

		inputs.forEach(i => {
			[els[i], els[i+'Slider']].forEach(el => {
				el.addEventListener('input', () => {
					if (el === els[i]) els[i+'Slider'].value = el.value;
					else els[i].value = el.value;
					update();
				});
			});
		});
		update();
	});
</script>
