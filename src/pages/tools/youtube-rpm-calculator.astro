---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = "YouTube RPM Calculator";
const description = "Calculate your actual revenue per 1000 views (RPM) after YouTube";
---

<ToolLayout 
	title={title} 
	description={description} 
	emoji="▶️"
	category="YouTube Growth"
	subtitle={description}
	conceptTitle="What is {title}?"
	conceptDescription={[
		"This tool helps you accurately calculate and generate insights for " + title + ".",
		"By using this free utility, you can streamline your digital hustle and make more informed decisions."
	]}
>
	<div class="w-full space-y-8 relative z-20">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
				<!-- Left Column: Inputs -->
				<div class="lg:col-span-7 space-y-6">
					<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group">
						<div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						
						<div class="relative space-y-8">
                            <!-- Revenue Input -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label class="text-sm font-black text-gray-400 uppercase tracking-widest">Total Estimated Revenue ($)</label>
                                    <input type="number" id="revenue" value="1000" class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-white text-3xl font-black w-48 text-right focus:border-primary/50 outline-none transition-all" />
								</div>
                                <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Enter the revenue you want to analyze</p>
							</div>

							<!-- Total Views -->
							<div class="space-y-4">
								<div class="flex justify-between items-end">
									<label class="text-sm font-black text-gray-400 uppercase tracking-widest">Total Views</label>
									<span class="text-3xl font-black text-white" id="views-display">100,000</span>
								</div>
								<input type="range" id="views-slider" min="1000" max="1000000" step="1000" value="100000" class="w-full h-2 bg-white/10 rounded-lg appearance-none cursor-pointer accent-primary" />
								<div class="flex items-center gap-3">
									<span class="text-xs text-gray-500 font-bold uppercase tracking-widest">Manual Input:</span>
									<input type="number" id="views" value="100000" class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-white font-bold w-40 focus:border-primary/50 outline-none transition-all" />
								</div>
							</div>

                            <!-- Tips/Helper -->
                            <div class="bg-primary/5 rounded-2xl p-6 border border-primary/20">
                                <h4 class="text-primary-400 font-black text-sm uppercase tracking-widest mb-2 flex items-center gap-2">
                                    <span class="text-lg">💡</span> Pro Tip
                                </h4>
                                <p class="text-xs text-gray-400 leading-relaxed font-medium">
                                    RPM includes all revenue sources (Ads, Memberships, Super Chats, etc.) divided by total views. It's usually lower than CPM but more accurate for business tracking.
                                </p>
                            </div>
						</div>
					</div>
				</div>

				<!-- Right Column: Results -->
				<div class="lg:col-span-5">
					<div class="bg-gradient-to-br from-emerald-500/10 to-primary/10 backdrop-blur-3xl border border-emerald-500/20 rounded-[2.5rem] p-10 shadow-2xl sticky top-32 text-center group overflow-hidden">
						<div class="absolute -right-10 -top-10 text-[10rem] opacity-5 group-hover:scale-110 transition-transform duration-700">📈</div>
						
						<div class="relative space-y-8">
							<div>
								<span class="text-xs font-black uppercase tracking-widest text-emerald-400 mb-2 block">Your Current RPM</span>
								<div class="text-6xl md:text-7xl font-black text-white" id="rpm-result">$10.00</div>
							</div>

							<div class="bg-white/5 rounded-2xl p-6 border border-white/10 space-y-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-xs font-black uppercase tracking-tighter text-gray-400">Monthly View Goal</span>
                                    <span class="text-sm font-black text-white">Target: +25%</span>
                                </div>
                                <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                                    <div class="h-full bg-gradient-to-r from-emerald-500 to-primary w-[75%]"></div>
                                </div>
								<p class="text-[10px] font-black uppercase tracking-tighter text-gray-400">Improve CTR and Average View Duration to boost RPM.</p>
							</div>

							<button class="w-full bg-emerald-500 text-white font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl uppercase tracking-tighter flex items-center justify-center gap-3">
								Increase Channel RPM
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
							</button>

							<p class="text-xs text-gray-500 font-medium italic">
								*RPM = (Total Revenue / Total Views) * 1000
							</p>
						</div>
					</div>
				
	</div>
</ToolLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const revenueInput = document.getElementById('revenue');
		const viewsInput = document.getElementById('views');
		const viewsSlider = document.getElementById('views-slider');
		const viewsDisplay = document.getElementById('views-display');

		const rpmRes = document.getElementById('rpm-result');

		function updateCalculations() {
			const revenue = parseFloat(revenueInput.value) || 0;
			const views = parseFloat(viewsInput.value) || 0;

			// Sync displays
			viewsDisplay.textContent = views.toLocaleString();

			// Logic: (Revenue / Views) * 1000
            let rpm = 0;
            if (views > 0) {
			    rpm = (revenue / views) * 1000;
            }

			// Update Results
			rpmRes.textContent = '$' + rpm.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
		}

		// Input events
		viewsSlider.addEventListener('input', (e) => {
			viewsInput.value = e.target.value;
			updateCalculations();
		});

		viewsInput.addEventListener('input', (e) => {
			viewsSlider.value = e.target.value;
			updateCalculations();
		});

        revenueInput.addEventListener('input', () => {
			updateCalculations();
		});

		// Initial Run
		updateCalculations();
	});
</script>
