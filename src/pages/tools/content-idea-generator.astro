---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Content Idea Generator | Hustle Teacher"
	description="Never run out of post ideas. Generate content topics for your blog, social media, or YouTube channel."
	theme="dark"
>
	<main class="flex-grow pt-24 pb-20">
		<div class="docs-site-container text-center">
			<div class="mb-16 animate-fade-in-down">
				<div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-6 border border-primary/50 shadow-sm">
					🧠 Brainstorming Tools
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold mb-6 uppercase tracking-tight">
					Content <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Idea</span> Generator
				</h1>
			</div>

			<div class="max-w-2xl mx-auto space-y-8">
				<div class="bg-card border border-border rounded-3xl p-8 shadow-xl">
					<input id="niche" type="text" placeholder="Your Niche (e.g. Finance, Fitness)..." class="w-full bg-background border border-border rounded-xl px-6 py-4 mb-4" />
					<button id="genBtn" class="w-full bg-primary text-white font-black py-4 rounded-xl shadow-lg">GENERATE 10 IDEAS</button>
				</div>

				<div id="results" class="hidden space-y-3 text-left">
					<!-- Ideas -->
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	const patterns = [
		"A day in the life of a {n} expert",
		"Why I stopped doing {n} (and what I do now)",
		"5 Tool I use every day for {n}",
		"The biggest mistake beginners make in {n}",
		"How much I earned from {n} last month",
		"Reviewing the top {n} trends of 2026",
		"My secret strategy for mastering {n}",
		"Tutorial: How to start {n} from scratch",
		"Reacting to popular {n} advice (Is it true?)",
		"10 {n} tips for busy people"
	];

	document.getElementById('genBtn').onclick = () => {
		const niche = document.getElementById('niche').value || 'Business';
		const res = document.getElementById('results');
		res.innerHTML = '';
		patterns.forEach(p => {
			const div = document.createElement('div');
			div.className = "p-4 bg-muted/30 border border-border rounded-xl font-bold hover:border-primary/50 cursor-pointer";
			div.textContent = p.replace(/{n}/g, niche);
			res.appendChild(div);
		});
		res.classList.remove('hidden');
	};
</script>
