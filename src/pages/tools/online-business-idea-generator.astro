---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Online Business Idea Generator | Hustle Teacher"
	description="Find profitable online business models tailored to your budget and expertise."
	theme="dark"
>
	<main class="flex-grow pt-24 pb-20">
		<div class="docs-site-container text-center">
			<div class="mb-16 animate-fade-in-down">
				<div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-6 border border-primary/50 shadow-sm">
					🌐 Global Tools
				</div>
				<h1 class="text-4xl md:text-6xl font-extrabold mb-6 uppercase tracking-tight">
					Online Business <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">Idea</span> Generator
				</h1>
			</div>

			<div class="max-w-3xl mx-auto">
				<div class="bg-card border border-border rounded-3xl p-8 shadow-xl mb-10">
					<div class="space-y-6 text-left mb-8">
						<label class="font-bold">What's your startup budget?</label>
						<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
							<button class="budget-btn p-3 rounded-xl border border-border bg-muted/30 hover:border-primary transition-all font-bold" data-val="0">$0</button>
							<button class="budget-btn p-3 rounded-xl border border-border bg-muted/30 hover:border-primary transition-all font-bold" data-val="100"><$100</button>
							<button class="budget-btn p-3 rounded-xl border border-border bg-muted/30 hover:border-primary transition-all font-bold" data-val="1000"><$1000</button>
							<button class="budget-btn p-3 rounded-xl border border-border bg-muted/30 hover:border-primary transition-all font-bold" data-val="plus">$1000+</button>
						</div>
					</div>
					<button id="genBtn" class="w-full bg-emerald-500 text-white font-black py-4 rounded-xl shadow-lg hover:scale-105 transition-transform">GENERATE BUSINESS MODEL</button>
				</div>

				<div id="result" class="hidden animate-fade-in-up">
					<div class="bg-card/50 border border-border rounded-3xl p-8">
						<h3 id="res-title" class="text-3xl font-black mb-4">Business Model</h3>
						<p id="res-desc" class="text-lg text-muted-foreground"></p>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	const data = {
		"0": { title: "Service Arbitrage", desc: "Find clients on LinkedIn/Upwork and outsource the fulfillment to specialists on Fiverr, keeping the margin." },
		"100": { title: "Digital Products / Etsy", desc: "Create digital templates, checklists, or printables once and sell them infinitely with low overhead." },
		"1000": { title: "Niche E-com / Branding", desc: "Source a specific product, build a brand around it, and sell directly via Shopify and Social Media ads." },
		"plus": { title: "SaaS / Software Lab", desc: "Hire a developer to build a solution for a specific industry problem and run it on a subscription model." }
	};

	let selected = "0";
	document.querySelectorAll('.budget-btn').forEach(btn => {
		btn.onclick = () => {
			document.querySelectorAll('.budget-btn').forEach(b => b.classList.remove('border-primary', 'bg-primary/10'));
			btn.classList.add('border-primary', 'bg-primary/10');
			selected = btn.dataset.val;
		}
	});

	document.getElementById('genBtn').onclick = () => {
		const res = data[selected];
		document.getElementById('res-title').textContent = res.title;
		document.getElementById('res-desc').textContent = res.desc;
		document.getElementById('result').classList.remove('hidden');
	};
</script>
