---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const title = "Startup Name Generator";
const description = "Generate powerful, creative, and brandable names for your next startup or business.";
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description} theme="dark">
	<main class="flex-grow pt-32 pb-20 relative overflow-hidden bg-[#030303]">
		<!-- Animated Background -->
		<div class="absolute inset-0 pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/20 rounded-full blur-[160px] animate-pulse opacity-50"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-blue-500/15 rounded-full blur-[140px] animate-pulse opacity-40"></div>
		</div>

		<div class="docs-site-container relative z-10 max-w-4xl mx-auto px-4">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-blue-500/10 text-blue-400 px-4 py-2 rounded-full text-xs font-black mb-6 border border-blue-500/20 uppercase tracking-widest shadow-[0_0_20px_rgba(59,130,246,0.1)]">
					🚀 Launch Engine
				</div>
				<h1 class="text-4xl md:text-7xl font-black text-white mb-6 uppercase tracking-tighter leading-tight">
					Startup <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500">Name</span>
				</h1>
				<p class="text-lg text-gray-400 max-w-2xl mx-auto font-medium">
					Every unicorn starts with a name. Generate unique, industry-appropriate, and creative brand ideas that stick.
				</p>
			</div>

			<!-- Tool UI -->
			<div class="space-y-8">
				<div class="bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					
					<div class="relative space-y-8">
						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="space-y-4">
								<label class="text-[10px] font-black text-gray-500 uppercase tracking-widest block px-2">Core Industry</label>
								<input 
									type="text" 
									id="industry" 
									placeholder="e.g. AI, Crypto, Solar, Clean" 
									class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-blue-500/50 transition-all font-bold"
								/>
							</div>
							<div class="space-y-4">
								<label class="text-[10px] font-black text-gray-500 uppercase tracking-widest block px-2">Brand Style</label>
								<select id="style" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white outline-none focus:border-blue-500/50 transition-all font-bold appearance-none cursor-pointer">
									<option value="tech" class="bg-black">High-Tech & Future</option>
									<option value="modern" class="bg-black">Modern Minimalist</option>
									<option value="abstract" class="bg-black">Abstract & Unique</option>
									<option value="traditional" class="bg-black">Traditional & Trust</option>
								</select>
							</div>
						</div>
						
						<button id="generateBtn" class="w-full bg-white text-black font-black py-6 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl uppercase tracking-tighter">
							Generate Brand Names
						</button>

						<div id="resultsArea" class="hidden animate-fade-in grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
							<!-- Names injected here -->
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const industryInput = document.getElementById('industry');
		const styleSelect = document.getElementById('style');
		const generateBtn = document.getElementById('generateBtn');
		const resultsArea = document.getElementById('resultsArea');

		const configs = {
			tech: { pre: ['Cyber', 'Nano', 'Quant', 'Aero', 'Vector'], suf: ['ly', 'io', 'ai', 'net', 'sys'] },
			modern: { pre: ['Pure', 'Zen', 'Nova', 'Flux', 'Loom'], suf: ['base', 'point', 'grid', 'way', 'line'] },
			abstract: { pre: ['Eivo', 'Salo', 'Vora', 'Xero', 'Zont'], suf: ['ra', 'na', 'zo', 'la', 'qi'] },
			traditional: { pre: ['Grand', 'Prime', 'Direct', 'Global', 'Solid'], suf: ['Group', 'Partners', 'Corp', 'Solutions', 'Associates'] }
		};

		generateBtn.addEventListener('click', () => {
			const ind = industryInput.value.trim();
			if (!ind) return;

			generateBtn.textContent = 'Brainstorming...';
			generateBtn.disabled = true;

			setTimeout(() => {
				resultsArea.innerHTML = '';
				const style = styleSelect.value;
				const config = configs[style];
				
				const names = [];
				for(let i=0; i<12; i++) {
					const p = config.pre[Math.floor(Math.random() * config.pre.length)];
					const s = config.suf[Math.floor(Math.random() * config.suf.length)];
					
					let name = '';
					const format = Math.floor(Math.random() * 3);
					if (format === 0) name = `${p}${ind}`;
					else if (format === 1) name = `${ind}${s}`;
					else name = `${p} ${ind}`;
					
					names.push(name);
				}
				
				[...new Set(names)].forEach(name => {
					const div = document.createElement('div');
					div.className = 'group relative bg-black/40 border border-white/10 p-6 rounded-[2rem] hover:border-blue-500/40 transition-all cursor-pointer flex flex-col items-center justify-center min-h-[120px] text-center';
                    div.innerHTML = `
                        <div class="text-xl font-black text-white tracking-tight mb-2 group-hover:scale-110 transition-transform">${name}</div>
                        <span class="text-[10px] font-black text-blue-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Copy</span>
                    `;
					div.onclick = () => {
						navigator.clipboard.writeText(name);
						const span = div.querySelector('span');
						span.textContent = 'Saved!';
						setTimeout(() => span.textContent = 'Copy', 2000);
					};
					resultsArea.appendChild(div);
				});

				resultsArea.classList.remove('hidden');
				generateBtn.textContent = 'Generate Brand Names';
				generateBtn.disabled = false;
			}, 800);
		});
	});
</script>
