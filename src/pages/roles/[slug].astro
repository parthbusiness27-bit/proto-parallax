---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../../consts';
import { roles } from '../../../../scripts/roles.js';

export async function getStaticPaths() {
    return roles.map((role) => ({
        params: { slug: role.id },
        props: { role },
    }));
}

const { role } = Astro.props;
---

<BaseLayout 
    title={`${role.title} Blueprint | ${SITE_TITLE}`} 
    description={`Inside the ${role.title} identity. Learn the mission, tools, and income potential for this archetype.`}
    theme="dark">
    
    <main class="docs-site-container border-x overflow-hidden flex-grow bg-background pb-20">
        
        <!-- Header Ribbon -->
        <div class={`h-3 md:h-4 w-full bg-gradient-to-r ${role.color}`}></div>

        <div class="max-w-4xl mx-auto px-4 mt-12 animate-fade-in-down">
            <a href="/roles/" class="inline-flex items-center text-sm font-semibold text-muted-foreground hover:text-primary transition-colors mb-8">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mr-2"><path d="m15 18-6-6 6-6"/></svg>
                Back to All Blueprints
            </a>
            
            <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-8 mb-12">
                <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-black border border-border flex items-center justify-center flex-shrink-0 shadow-xl">
                    <Fragment set:html={role.icon.replace('width="24"', 'width="40"').replace('height="24"', 'height="40"')} />
                </div>
                <div>
                    <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-foreground mb-4">{role.title}</h1>
                    <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl">{role.mission}</p>
                </div>
            </div>
        </div>

        <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-8 md:gap-12 animate-fade-in-up" style="animation-delay: 150ms;">
            
            <!-- Left Content: Description -->
            <div class="lg:col-span-2 space-y-10">
                <section class="prose prose-invert prose-emerald max-w-none">
                    <h2 class="text-2xl font-bold text-foreground mb-4">The Identity</h2>
                    <p class="text-muted-foreground text-lg leading-relaxed">{role.description}</p>
                </section>
                
                <section>
                    <h2 class="text-2xl font-bold text-foreground mb-6">Connected Pathways</h2>
                    <p class="text-muted-foreground mb-6">To master this role, study the following masterclasses from our guides database:</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {role.categories.map(cat => (
                            <a href={`/blog/category/${cat.slug}/`} class="flex items-center justify-between p-4 bg-muted/30 border border-border rounded-xl hover:border-primary/50 hover:bg-muted/50 transition-colors group">
                                <span class="font-bold text-foreground group-hover:text-primary transition-colors">{cat.name}</span>
                                <span class="text-primary font-bold group-hover:translate-x-1 transition-transform">&rarr;</span>
                            </a>
                        ))}
                    </div>
                </section>
            </div>

            <!-- Right Sidebar: Stats -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Stack -->
                <div class="bg-black border border-border rounded-2xl p-6">
                    <h3 class="text-sm font-black uppercase text-muted-foreground tracking-widest mb-4">Daily Stack</h3>
                    <ul class="space-y-3">
                        {role.dailyStack.map(tool => (
                            <li class="flex items-center gap-3 text-sm font-semibold text-foreground">
                                <div class="w-1.5 h-1.5 rounded-full bg-primary flex-shrink-0"></div>
                                {tool}
                            </li>
                        ))}
                    </ul>
                </div>

                <!-- Difficulty -->
                <div class="bg-black border border-border rounded-2xl p-6">
                    <h3 class="text-sm font-black uppercase text-muted-foreground tracking-widest mb-4">Difficulty Curve</h3>
                    <div class="flex gap-2 mb-2">
                        {[1,2,3,4,5].map((star) => (
                            <div class={`flex-1 h-2 rounded-full ${star <= role.difficulty ? 'bg-primary shadow-[0_0_8px_var(--color-primary)]' : 'bg-muted'}`}></div>
                        ))}
                    </div>
                    <p class="text-xs text-muted-foreground mt-3 text-center">Level {role.difficulty} out of 5</p>
                </div>

                <!-- Income -->
                <div class="bg-black border border-border rounded-2xl p-6 relative overflow-hidden">
                    <div class={`absolute inset-0 bg-gradient-to-br ${role.color} opacity-20`}></div>
                    <h3 class="relative text-sm font-black uppercase text-muted-foreground tracking-widest mb-4">Earning Potential</h3>
                    <p class="relative text-2xl font-bold text-foreground tracking-tight">{role.income}</p>
                </div>
            </div>
        </div>

    </main>
</BaseLayout>
