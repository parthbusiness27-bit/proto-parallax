---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import { Image } from 'astro:assets';
import { SITE_TITLE } from '../consts';

const title = `About Me | ${SITE_TITLE}`;
const description = 'Learn about Hustle Teacher — your guide to making money online through practical guides, tools, and proven digital strategies.';
---

<BaseLayout title={title} description={description} theme="dark">
	<main class="flex-grow docs-site-container border-x">
		<!-- Simple Hero Section -->
		<section class="max-w-4xl mx-auto pt-16 pb-8 px-4 text-center">
			<h1 class="heading-gold text-5xl md:text-7xl mb-6 leading-tight">About Me</h1>
			<p class="text-xl text-muted-foreground max-w-2xl mx-auto prose-italic">
				Demystifying the process of making money online and empowering everyday people to build digital income streams.
			</p>
		</section>

		<article class="prose prose-invert prose-lg max-w-4xl mx-auto py-8 px-4">
			{AboutHeroImage && (
				<div class="mb-12 rounded-2xl overflow-hidden border border-primary/20 shadow-2xl">
					<Image 
						src={AboutHeroImage} 
						alt="Hustle Teacher About" 
						class="w-full h-auto object-cover m-0"
						width={1000}
						height={500}
					/>
				</div>
			)}

			<h2 class="heading-gold text-3xl md:text-4xl mb-8 mt-4 text-center">My Story</h2>
			
			<div class="divider mb-12">
			  <div class="divider-line"></div>
			  <div class="divider-coin">$</div>
			  <div class="divider-line"></div>
			</div>

			<p class="text-xl text-center font-medium mb-12">
				Hi, I'm <strong>Parth</strong>, the founder of Hustle Teacher. 
			</p>

			<div class="stats-bar rounded-3xl mb-16 py-8 px-4 bg-gradient-to-br from-card to-background border border-primary/20 shadow-xl flex flex-wrap justify-around gap-8">
				<div class="stats-item text-center">
					<span class="stats-val text-4xl font-black text-primary block mb-1">50+</span>
					<span class="stats-label text-xs uppercase tracking-widest text-muted-foreground font-bold font-cinzel">Guides</span>
				</div>
				<div class="stats-item text-center">
					<span class="stats-val text-4xl font-black text-primary block mb-1">10k+</span>
					<span class="stats-label text-xs uppercase tracking-widest text-muted-foreground font-bold font-cinzel">Readers</span>
				</div>
				<div class="stats-item text-center">
					<span class="stats-val text-4xl font-black text-primary block mb-1">24/7</span>
					<span class="stats-label text-xs uppercase tracking-widest text-muted-foreground font-bold font-cinzel">Hustle</span>
				</div>
			</div>

			<p>
				The internet is full of noise—get-rich-quick schemes, overpriced courses, and confusing jargon. I created Hustle Teacher to cut through that noise. My philosophy is straightforward: <strong class="text-primary font-bold">Learn → Start → Earn</strong>. We focus on proven, actionable strategies that actually work in today's digital economy.
			</p>

			<p>
				Whether you're a student looking for a side gig, a professional wanting to transition into freelancing, or an aspiring entrepreneur ready to launch a scalable online business, I've designed this space for you. I spend countless hours researching and testing the methods we recommend, so you don't have to guess what works.
			</p>

			<p class="mb-12">
				From detailed blueprints on dropshipping and YouTube automation to carefully curated free tools and premium digital products, our goal is to provide everything you need under one roof. I believe that with the right guidance and a bit of hustle, financial independence is within everyone's reach. Let's start building your empire today.
			</p>

			<div class="flex justify-center mt-12 pb-16">
				<a href="/start-here/" class="btn-gold px-12 py-5 text-lg">Start Your Journey</a>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	.stats-val { text-shadow: 0 0 20px rgba(201,162,39,0.3); }
	.font-cinzel { font-family: 'Cinzel', serif; }
</style>
