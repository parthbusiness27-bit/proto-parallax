---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { categories as siteCategories } from '../../../../scripts/categories.js';

export async function getStaticPaths() {
	const allKnownCategories = siteCategories.map(c => c.slug);

	const allPosts = await getCollection('blog');

	return allKnownCategories.map((category) => {
		const filteredPosts = allPosts
			.filter((post) => post.data.category === category && !post.data.hidden)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { category },
			props: { posts: filteredPosts, category },
		};
	});
}

const { category } = Astro.props;
let { posts } = Astro.props;

const SHOW_ALL_POSTS = false;

if (!SHOW_ALL_POSTS) {
    posts = posts.slice(0, 6);
}

const siteCat = siteCategories.find(c => c.slug === category);

const meta = {
	emoji: siteCat?.emoji || '📖',
	label: siteCat?.title || category.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
	subtitle: siteCat?.subcategories?.slice(0, 3).join(', ') || 'Explore guides in this category',
};
---

<BaseLayout
	title={`${meta.label} Guides | ${SITE_TITLE}`}
	description={`Explore all of our high-value strategies and comprehensive masterclasses for ${meta.label.toLowerCase()}.`}
	robotsMeta="index, follow, noodp"
	theme="dark"
>
	<main class="flex-grow">

		<section class="py-10 md:py-16 px-4 max-w-7xl mx-auto text-center animate-fade-in-down">
			<div class="inline-block bg-primary/10 text-primary px-3 md:px-4 py-1.5 rounded-full text-xs md:text-sm font-semibold mb-4 md:mb-6 border border-primary/20">
				Guides Category
			</div>
			<h1 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-extrabold mb-3 md:mb-4 tracking-tight">
				<span class="mr-2 md:mr-3 text-xl md:text-3xl">{meta.emoji}</span><span class="bg-gradient-to-r from-primary to-emerald-500 bg-clip-text text-transparent">{meta.label}</span>
			</h1>
			<p class="text-sm md:text-base lg:text-lg text-muted-foreground max-w-2xl mx-auto mb-4 md:mb-6 px-2">{meta.subtitle}</p>
			<p class="text-xs md:text-sm text-muted-foreground max-w-2xl mx-auto mb-6 md:mb-8 px-2">
				Explore all of our high-value strategies and comprehensive masterclasses for {meta.label.toLowerCase()}.
			</p>
			<a href="/blog/" class="inline-block text-primary text-sm md:text-base font-medium hover:underline mb-6 md:mb-8">
				← Back to All Guides
			</a>
		</section>

		<div class="max-w-[1200px] mx-auto px-4 pb-16 md:pb-24">
			<div class="grid gap-4 md:gap-6 lg:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
				{posts.length === 0 ? (
					<div class="col-span-full text-center py-16 md:py-20 bg-card rounded-2xl border border-border">
						<div class="text-4xl md:text-5xl mb-4">{meta.emoji}</div>
						<h2 class="text-xl md:text-2xl font-bold text-foreground mb-3 md:mb-4">No guides published yet.</h2>
						<p class="text-sm md:text-base text-muted-foreground mb-5 md:mb-6">We're working on in-depth guides for {meta.label}. Check back soon!</p>
						<a href="/blog/" class="inline-flex items-center gap-2 bg-primary text-white px-5 md:px-6 py-2.5 md:py-3 rounded-lg md:rounded-xl font-semibold hover:bg-primary/90 transition-colors text-sm md:text-base">
							← Browse All Guides
						</a>
					</div>
				) : (
					posts.map((post: any, i: number) => (
						<a href={`/blog/${post.id}/`} class="group flex flex-col bg-card border border-border rounded-xl md:rounded-2xl overflow-hidden hover:border-primary/40 transition-all duration-300 hover:-translate-y-1 md:hover:-translate-y-2 hover:shadow-lg md:hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] animate-fade-in-up" style={`animation-delay: ${100 + (i * 100)}ms;`}>
							<div class="aspect-[16/10] overflow-hidden relative bg-muted">
								<Image
									src={post.data.heroImage}
									alt={post.data.title}
									width={600}
									height={375}
									class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
								/>
								<div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
							</div>
							<div class="p-4 md:p-6 flex flex-col flex-grow">
								<div class="text-xs font-medium text-muted-foreground mb-3 md:mb-4 flex items-center justify-between flex-wrap gap-2">
									<FormattedDate date={post.data.pubDate} />
									<span class="uppercase tracking-wider text-[10px] md:text-xs text-primary font-bold">{post.data.category}</span>
								</div>
								<h3 class="text-base md:text-lg lg:text-xl font-bold text-foreground mb-2 md:mb-3 leading-snug group-hover:text-primary transition-colors line-clamp-2">
									{post.data.title}
								</h3>
								<p class="text-xs md:text-sm text-muted-foreground line-clamp-2 mb-4 md:mb-6 flex-grow">
									{post.data.description}
								</p>
								<div class="mt-auto pt-3 md:pt-4 border-t border-border/50">
									<span class="text-xs md:text-sm font-bold text-primary inline-flex items-center group-hover:translate-x-1 transition-transform">
										Read guide <span class="ml-1">&rarr;</span>
									</span>
								</div>
							</div>
						</a>
					))
				)}
			</div>
		</div>
	</main>
</BaseLayout>
