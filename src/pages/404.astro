---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '404 - Page Not Found';
const description = 'The page you are looking for could not be found.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div style="text-align: center; padding: 4em 2em; min-height: 60vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
				<h1 style="font-size: 6em; margin: 0; color: #4338ca;">404</h1>
				<h2 style="font-size: 2em; margin: 0.5em 0; color: #1f2937;">Page Not Found</h2>
				<p style="font-size: 1.1em; color: #6b7280; margin: 1em 0;">
					Sorry, the page you're looking for doesn't exist or has been moved.
				</p>

				<div style="margin-top: 2em;">
					<a href="/" style="display: inline-block; background: #4338ca; color: white; padding: 0.8em 2em; border-radius: 0.5em; text-decoration: none; margin: 0.5em; font-weight: 600;">
						Go to Home
					</a>
					<a href="/blog/" style="display: inline-block; background: #e5e7eb; color: #1f2937; padding: 0.8em 2em; border-radius: 0.5em; text-decoration: none; margin: 0.5em; font-weight: 600;">
						Back to Blog
					</a>
				</div>

				<h3 style="margin-top: 2em; color: #1f2937;">Quick Links</h3>
				<ul style="list-style: none; padding: 0; text-align: left; display: inline-block;">
					<li><a href="/about/" style="color: #4338ca; text-decoration: none;">About Us</a></li>
					<li><a href="/blog/" style="color: #4338ca; text-decoration: none;">Latest Articles</a></li>
					<li><a href="/privacy-policy/" style="color: #4338ca; text-decoration: none;">Privacy Policy</a></li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		color: #1f2937;
	}

	a {
		transition: all 0.3s ease;
	}

	a:hover {
		transform: translateY(-2px);
		text-decoration: underline;
	}

	ul li {
		margin: 0.5em 0;
	}
</style>
