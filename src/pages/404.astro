---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '404 - Page Not Found';
const description = 'The page you are looking for could not be found.';
---

<BaseLayout title={title} description={description} theme="dark">
    <main class="flex-grow flex flex-col">
        <div class="flex-grow flex items-center justify-center p-8">
            <div class="text-center max-w-2xl">
                <h1 class="text-8xl md:text-9xl font-extrabold text-primary mb-4">404</h1>
                <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-4">Page Not Found</h2>
                <p class="text-lg text-muted-foreground mb-8">
                    Sorry, the page you're looking for doesn't exist or has been moved.
                </p>

                <div class="flex flex-wrap justify-center gap-4 mb-8">
                    <a href="/" class="inline-flex items-center justify-center bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:opacity-90 transition-opacity">
                        Go to Home
                    </a>
                    <a href="/blog/" class="inline-flex items-center justify-center bg-muted text-foreground px-8 py-3 rounded-xl font-semibold hover:bg-muted/80 transition-colors">
                        Back to Blog
                    </a>
                </div>

                <h3 class="text-lg font-semibold text-foreground mb-4">Quick Links</h3>
                <ul class="space-y-2 text-left inline-block">
                    <li><a href="/about/" class="text-primary hover:underline">About Us</a></li>
                    <li><a href="/blog/" class="text-primary hover:underline">Latest Articles</a></li>
                    <li><a href="/privacy-policy/" class="text-primary hover:underline">Privacy Policy</a></li>
                </ul>
            </div>
        </div>
    </main>
</BaseLayout>
