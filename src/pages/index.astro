---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SEOSchema from '../components/SEOSchema.astro';
import TrendingMethods from '../components/TrendingMethods.astro';
import PopularGuides from '../components/PopularGuides.astro';
import CategoriesGrid from '../components/CategoriesGrid.astro';
import PopularPlatforms from '../components/PopularPlatforms.astro';
import FreeToolsHub from '../components/FreeToolsHub.astro';
import DigitalProducts from '../components/DigitalProducts.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_INSTAGRAM, SOCIAL_YOUTUBE, SOCIAL_TWITTER, SOCIAL_FACEBOOK, SOCIAL_LINKEDIN, SOCIAL_PINTEREST } from '../consts';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';
---
<BaseLayout title={`${SITE_TITLE} | Master Making Money Online`} description={SITE_DESCRIPTION}>
	<Fragment slot="head">
		<SEOSchema type="Organization" />
	</Fragment>
	<main class="flex-grow">
            <!-- Hero Section -->
			<section class="relative docs-site-container border-x py-12 md:py-20 lg:py-32 overflow-hidden">
                <!-- Animated Background and Floating Orbs -->
                <div class="absolute inset-0 pointer-events-none overflow-hidden">
                    <!-- Layer 1: Moving Gradients -->
                    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-primary/20 hover:bg-primary/30 blur-[120px] rounded-full mix-blend-screen animate-pulse duration-10000"></div>
                    <div class="absolute top-[20%] -right-[10%] w-[40%] h-[50%] bg-purple-500/20 blur-[120px] rounded-full mix-blend-screen animate-pulse" style="animation-duration: 8s;"></div>
                    <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[60%] bg-blue-500/10 blur-[150px] rounded-full mix-blend-screen animate-pulse" style="animation-duration: 12s;"></div>
                    
                    <!-- Layer 2: Floating Icons - Desktop Only -->
                    <div class="hidden md:block absolute top-1/4 left-1/4 text-6xl opacity-10 animate-bounce" style="animation-duration: 4s;">💰</div>
                    <div class="hidden md:block absolute top-1/3 right-1/4 text-7xl opacity-10 animate-bounce" style="animation-duration: 5s; animation-delay: 1s;">🚀</div>
                    <div class="hidden md:block absolute bottom-1/4 left-1/3 text-5xl opacity-10 animate-bounce" style="animation-duration: 4.5s; animation-delay: 0.5s;">📈</div>
                    <div class="hidden md:block absolute bottom-1/3 right-1/3 text-6xl opacity-10 animate-bounce" style="animation-duration: 5.5s; animation-delay: 1.5s;">💻</div>
                    <div class="hidden md:block absolute top-[15%] left-[60%] text-4xl opacity-10 animate-bounce" style="animation-duration: 3.5s; animation-delay: 2s;">🔥</div>
                </div>
                
                <div class="mx-auto max-w-[1200px] relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12 lg:gap-20">
                    <!-- Text Content (Left Side) -->
                    <div class="flex-1 text-center md:text-left">
                        <div class="inline-block bg-primary/20 text-primary-400 px-4 py-1.5 md:px-5 md:py-2 rounded-full text-xs md:text-sm font-semibold mb-6 md:mb-10 border border-primary/50 shadow-sm animate-fade-in-down">
                            🚀 Join 10,000+ Hustlers
                        </div>
                        <h1 class="font-extrabold tracking-tight leading-tight mb-6 md:mb-8 text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl animate-fade-in-up">
                            Learn Real Ways To <br/>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">
                                Make Money Online
                            </span>
                        </h1>
                        <p class="text-base md:text-xl lg:text-2xl text-muted-foreground max-w-[650px] mb-8 md:mb-12 animate-fade-in-up md:mx-0 mx-auto" style="animation-delay: 150ms;">
                            Guides, tools, and strategies to help you start your online hustle.
                        </p>
                        <div class="flex flex-col sm:flex-row justify-center md:justify-start gap-4 md:gap-6 animate-fade-in-up" style="animation-delay: 300ms;">
                            <a href="#pathways" class="group relative inline-flex items-center justify-center rounded-xl text-base md:text-xl font-bold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background bg-primary text-white h-12 md:h-16 px-6 md:px-10 duration-300 hover:scale-[1.03] hover:shadow-[0_0_50px_rgba(79,70,229,0.5)] overflow-hidden">
                                <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-primary-400 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                                <span class="relative z-10 flex items-center gap-2 md:gap-3">Start Learning <span class="group-hover:translate-x-2 transition-transform">→</span></span>
                            </a>
                            <a href="#pathways" class="group inline-flex items-center justify-center rounded-xl text-base md:text-xl font-bold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background border-2 border-primary/30 hover:border-primary text-white bg-white/10 backdrop-blur h-12 md:h-16 px-6 md:px-10 duration-300 hover:scale-[1.03] hover:shadow-[0_0_40px_rgba(79,70,229,0.25)]">
                                Choose Path
                            </a>
                        </div>
                        <div class="flex items-center justify-center md:justify-start gap-4 md:gap-5 mt-8 md:mt-10 animate-fade-in-up" style="animation-delay: 450ms;">
                            <span class="text-xs md:text-sm text-muted-foreground hidden sm:inline">Follow us:</span>
                            <div class="flex items-center gap-3">
                                <a href={SOCIAL_YOUTUBE} target="_blank" class="text-white/60 hover:text-red-500 transition-colors" aria-label="YouTube">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                </a>
                                <a href={SOCIAL_INSTAGRAM} target="_blank" class="text-white/60 hover:text-pink-500 transition-colors" aria-label="Instagram">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                                </a>
                                <a href={SOCIAL_TWITTER} target="_blank" class="text-white/60 hover:text-white transition-colors" aria-label="Twitter/X">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.004 3.916H5.078z"/></svg>
                                </a>
                                <a href={SOCIAL_FACEBOOK} target="_blank" class="text-white/60 hover:text-blue-500 transition-colors" aria-label="Facebook">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                                </a>
                                <a href={SOCIAL_LINKEDIN} target="_blank" class="text-white/60 hover:text-blue-400 transition-colors" aria-label="LinkedIn">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                </a>
                                <a href={SOCIAL_PINTEREST} target="_blank" class="text-white/60 hover:text-red-500 transition-colors" aria-label="Pinterest">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.965 1.406-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.162 0 7.398 2.965 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Logo & Brand (Right Side) -->
                    <div class="flex-1 hidden md:flex flex-col items-center justify-center animate-fade-in-up" style="animation-delay: 450ms;">
                        <div class="relative group cursor-pointer hover:scale-105 transition-transform duration-500">
                            <!-- Glowing background aura -->
                            <div class="absolute inset-0 bg-gradient-to-r from-primary to-emerald-500 rounded-full blur-[80px] opacity-40 group-hover:opacity-60 transition-opacity duration-500"></div>
                            
                            <!-- Full Hero Logo -->
                            <div class="relative flex-shrink-0 mx-auto w-full max-w-[280px] lg:max-w-[380px] aspect-square animate-pulse" style="animation-duration: 4s;">
                                <Image
                                    src={logoImage}
                                    alt="Hustle Teacher Logo - Wealth and Success Icon" 
                                    width={380} 
                                    height={380} 
                                    fetchpriority="high"
                                    loading="eager"
                                    decoding="async" 
                                    class="absolute inset-0 w-full h-full object-contain mix-blend-screen drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]" 
                                />
                            </div>
                        </div>
                    </div>
                </div>
			</section>

            <!-- Trending Methods Section -->
            <TrendingMethods />

            <!-- Popular Guides Section -->
            <PopularGuides />

            <!-- Categories Section -->
            <CategoriesGrid />

            <!-- Popular Platforms Section -->
            <PopularPlatforms />

            <!-- Free Tools Section -->
            <FreeToolsHub />

            <!-- Digital Products Section -->
            <DigitalProducts />

            <!-- Newsletter Section -->
            <section id="newsletter" class="docs-site-container border-x py-24 animate-fade-in-up">
                <NewsletterSignup />
            </section>
	</main>
</BaseLayout>
