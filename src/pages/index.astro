---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SEOSchema from '../components/SEOSchema.astro';
import TrendingMethods from '../components/TrendingMethods.astro';
import PopularGuides from '../components/PopularGuides.astro';
import CategoriesGrid from '../components/CategoriesGrid.astro';
import PopularPlatforms from '../components/PopularPlatforms.astro';
import FreeToolsHub from '../components/FreeToolsHub.astro';
import DigitalProducts from '../components/DigitalProducts.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_INSTAGRAM, SOCIAL_YOUTUBE, SOCIAL_TWITTER, SOCIAL_PINTEREST } from '../consts';
import logoImage from '../assets/logo.png';
import { Image } from 'astro:assets';
import MoneyGlobe from '../components/MoneyGlobe.astro';
---
<BaseLayout title={`${SITE_TITLE} | Master Making Money Online`} description={SITE_DESCRIPTION} robotsMeta="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1, noodp" theme="dark">
	<Fragment slot="head">
		<SEOSchema type="Organization" />
	</Fragment>
	<main class="flex-grow">
            <!-- Hero Section -->
			<section class="relative docs-site-container border-x py-12 md:py-20 lg:py-32 overflow-hidden">
                <!-- Animated Background and Floating Orbs -->
                <div class="absolute inset-0 pointer-events-none overflow-hidden">
                    <!-- Layer 1: Moving Gradients (Enhanced with dark/gold tints) -->
                    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-emerald-900/10 blur-[120px] rounded-full mix-blend-screen animate-pulse duration-[10s]"></div>
                    <div class="absolute top-[20%] -right-[10%] w-[40%] h-[50%] bg-yellow-600/10 blur-[120px] rounded-full mix-blend-screen animate-pulse duration-[8s]"></div>
                    <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[60%] bg-amber-700/5 blur-[150px] rounded-full mix-blend-screen animate-pulse duration-[12s]"></div>
                    
                    <!-- NEW: HERO CANVAS for floating coins -->
                    <canvas class="hero-canvas" id="heroCanvas"></canvas>
                </div>
                
                <div class="mx-auto max-w-[1200px] relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12 lg:gap-20">
                    <!-- Text Content (Left Side) -->
                    <div class="flex-1 text-center md:text-left">
                        <div class="eyebrow inline-block px-4 py-1.5 md:px-5 md:py-2 mb-6 md:mb-10 animate-fade-in-down" style="border: 1px solid var(--gold-dark); border-radius: 4px;">
                            🚀 Join Our Growing Community
                        </div>
                        <h1 class="heading-gold text-4xl sm:text-5xl md:text-6xl lg:text-7xl mb-6 md:mb-8 animate-fade-in-up">
                            Learn Real Ways To <br/>
                            Make Money Online
                        </h1>
                        <p class="prose-italic text-lg md:text-2xl max-w-[650px] mb-8 md:mb-12 animate-fade-in-up md:mx-0 mx-auto" style="animation-delay: 150ms; color: var(--cream);">
                            Guides, tools, and strategies to help you start your online hustle.
                        </p>
                        <div class="flex flex-col sm:flex-row justify-center md:justify-start gap-4 md:gap-6 animate-fade-in-up" style="animation-delay: 300ms;">
                            <a href="#pathways" class="btn-gold flex items-center justify-center rounded-xl bg-gradient-to-r from-amber-400 to-yellow-600 text-black h-12 md:h-16 px-6 md:px-10 duration-300">
                                Start Learning →
                            </a>
                            <a href="#pathways" class="btn-gold flex items-center justify-center rounded-xl h-12 md:h-16 px-6 md:px-10 duration-300" style="background: transparent !important; color: var(--gold-bright) !important; border: 2px solid var(--gold-dark); box-shadow: none;">
                                Choose Path
                            </a>
                        </div>
                        <div class="flex items-center justify-center md:justify-start gap-4 md:gap-5 mt-8 md:mt-10 animate-fade-in-up" style="animation-delay: 450ms;">
                            <span class="text-xs md:text-sm text-muted-foreground hidden sm:inline">Follow us:</span>
                            <div class="flex items-center gap-3">
                                <a href={SOCIAL_YOUTUBE} target="_blank" class="text-white/60 hover:text-red-500 transition-colors" aria-label="YouTube">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                </a>
                                <a href={SOCIAL_INSTAGRAM} target="_blank" class="text-white/60 hover:text-pink-500 transition-colors" aria-label="Instagram">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                                </a>
                                <a href={SOCIAL_TWITTER} target="_blank" class="text-white/60 hover:text-white transition-colors" aria-label="Twitter/X">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.004 3.916H5.078z"/></svg>
                                </a>
                                <a href={SOCIAL_PINTEREST} target="_blank" class="text-white/60 hover:text-red-500 transition-colors" aria-label="Pinterest">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.965 1.406-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.162 0 7.398 2.965 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Logo & Brand (Right Side) / Animated WebGL Globe -->
                    <div class="flex-1 flex flex-col items-center justify-center animate-fade-in-up mt-12 md:mt-0" style="animation-delay: 450ms;">
                        <MoneyGlobe />
                    </div>
                </div>
			</section>

            <!-- Trending Methods Section -->
            <TrendingMethods />

            <!-- Popular Guides Section -->
            <PopularGuides />

            <!-- Categories Section -->
            <CategoriesGrid />

            <!-- Popular Platforms Section -->
            <PopularPlatforms />

            <!-- Free Tools Section -->
            <FreeToolsHub />

            <!-- Digital Products Section -->
            <DigitalProducts />

            <!-- Newsletter Section -->
            <section id="newsletter" class="docs-site-container border-x py-12 md:py-24 animate-fade-in-up">
                <NewsletterSignup />
            </section>
	</main>
	<script is:inline>
// ── HERO CANVAS — floating coins & bills ─────────────────
// Only runs if a <canvas id="heroCanvas"> exists on the page
(function() {
  const heroCanvas = document.getElementById('heroCanvas');
  if (!heroCanvas) return;
  const hCtx = heroCanvas.getContext('2d');

  function resizeHero() {
    heroCanvas.width  = heroCanvas.offsetWidth;
    heroCanvas.height = heroCanvas.offsetHeight;
  }
  resizeHero();
  window.addEventListener('resize', resizeHero);

  const symbols = ['$','₹','€','£','¥','$','$'];

  class Particle {
    constructor() { this.reset(); }
    reset() {
      this.x        = Math.random() * heroCanvas.width;
      this.y        = Math.random() * heroCanvas.height;
      this.size     = Math.random() * 18 + 8;
      this.speedY   = Math.random() * 0.5 + 0.2;
      this.speedX   = (Math.random() - 0.5) * 0.3;
      this.opacity  = Math.random() * 0.4 + 0.1;
      this.symbol   = symbols[Math.floor(Math.random() * symbols.length)];
      this.rotation = Math.random() * Math.PI * 2;
      this.rotSpeed = (Math.random() - 0.5) * 0.02;
      this.isCoin   = Math.random() > 0.5;
    }
    draw() {
      hCtx.save();
      hCtx.translate(this.x, this.y);
      hCtx.rotate(this.rotation);
      hCtx.globalAlpha = this.opacity;
      if (this.isCoin) {
        hCtx.beginPath();
        hCtx.arc(0, 0, this.size, 0, Math.PI * 2);
        const g = hCtx.createRadialGradient(-this.size*.3,-this.size*.3,1,0,0,this.size);
        g.addColorStop(0,'#FFD700'); g.addColorStop(.5,'#c9a227'); g.addColorStop(1,'#8B6914');
        hCtx.fillStyle = g; hCtx.fill();
        hCtx.strokeStyle = '#0a0a0a'; hCtx.lineWidth = 2; hCtx.stroke();
        hCtx.fillStyle = '#0a0a0a';
        hCtx.font = `bold ${this.size*.8}px Cinzel,serif`;
        hCtx.textAlign = 'center'; hCtx.textBaseline = 'middle';
        hCtx.fillText(this.symbol, 0, 1);
      } else {
        const w = this.size*3, h = this.size*1.8;
        hCtx.fillStyle = '#2d6a2d'; hCtx.strokeStyle = '#0a0a0a'; hCtx.lineWidth = 2;
        hCtx.beginPath(); hCtx.roundRect(-w/2,-h/2,w,h,3); hCtx.fill(); hCtx.stroke();
        hCtx.fillStyle = 'rgba(255,255,255,.6)';
        hCtx.font = `bold ${this.size*.7}px Cinzel,serif`;
        hCtx.textAlign = 'center'; hCtx.textBaseline = 'middle';
        hCtx.fillText(this.symbol, 0, 1);
      }
      hCtx.restore();
    }
    update() {
      this.y -= this.speedY; this.x += this.speedX; this.rotation += this.rotSpeed;
      if (this.y < -50) { this.y = heroCanvas.height+50; this.x = Math.random()*heroCanvas.width; }
    }
  }

  const particles = [];
  for (let i=0; i<60; i++) {
    const p = new Particle();
    p.y = Math.random() * heroCanvas.height;
    particles.push(p);
  }

  function animateHero() {
    hCtx.clearRect(0, 0, heroCanvas.width, heroCanvas.height);
    particles.forEach(p => { p.update(); p.draw(); });
    requestAnimationFrame(animateHero);
  }
  animateHero();
})();
	</script>
</BaseLayout>
