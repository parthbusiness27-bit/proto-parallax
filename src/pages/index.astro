---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import SEOSchema from '../components/SEOSchema.astro';
import TrendingMethods from '../components/TrendingMethods.astro';
import PopularGuides from '../components/PopularGuides.astro';
import CategoriesGrid from '../components/CategoriesGrid.astro';
import PopularPlatforms from '../components/PopularPlatforms.astro';
import FreeToolsHub from '../components/FreeToolsHub.astro';
import DigitalProducts from '../components/DigitalProducts.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';
---
<BaseLayout title={`${SITE_TITLE} | Master Making Money Online`} description={SITE_DESCRIPTION}>
	<Fragment slot="head">
		<SEOSchema type="Organization" />
		<link rel="preload" href="/logo.png" as="image" type="image/png" fetchpriority="high" />
	</Fragment>
	<main class="flex-grow">
            <!-- Hero Section -->
			<section class="relative docs-site-container border-x md:py-32 py-20 overflow-hidden">
                <!-- Animated Background and Floating Orbs -->
                <div class="absolute inset-0 pointer-events-none overflow-hidden">
                    <!-- Layer 1: Moving Gradients -->
                    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-primary/20 hover:bg-primary/30 blur-[120px] rounded-full mix-blend-screen animate-pulse duration-10000"></div>
                    <div class="absolute top-[20%] -right-[10%] w-[40%] h-[50%] bg-purple-500/20 blur-[120px] rounded-full mix-blend-screen animate-pulse" style="animation-duration: 8s;"></div>
                    <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[60%] bg-blue-500/10 blur-[150px] rounded-full mix-blend-screen animate-pulse" style="animation-duration: 12s;"></div>
                    
                    <!-- Layer 2: Floating Icons -->
                    <div class="absolute top-1/4 left-1/4 text-6xl opacity-10 animate-bounce" style="animation-duration: 4s;">💰</div>
                    <div class="absolute top-1/3 right-1/4 text-7xl opacity-10 animate-bounce" style="animation-duration: 5s; animation-delay: 1s;">🚀</div>
                    <div class="absolute bottom-1/4 left-1/3 text-5xl opacity-10 animate-bounce" style="animation-duration: 4.5s; animation-delay: 0.5s;">📈</div>
                    <div class="absolute bottom-1/3 right-1/3 text-6xl opacity-10 animate-bounce" style="animation-duration: 5.5s; animation-delay: 1.5s;">💻</div>
                    <div class="absolute top-[15%] left-[60%] text-4xl opacity-10 animate-bounce" style="animation-duration: 3.5s; animation-delay: 2s;">🔥</div>
                </div>
                
                <div class="mx-auto max-w-[1200px] relative z-10 flex flex-col md:flex-row items-center gap-12 lg:gap-20">
                    <!-- Text Content (Left Side) -->
                    <div class="flex-1 text-center md:text-left">
                        <div class="inline-block bg-primary/20 text-primary-400 px-5 py-2 rounded-full text-sm font-semibold mb-10 border border-primary/50 shadow-sm animate-fade-in-down">
                            🚀 Join 10,000+ Hustlers
                        </div>
                        <h1 class="font-extrabold tracking-tight leading-tight mb-8 md:leading-[1.1] md:text-6xl lg:text-7xl text-5xl animate-fade-in-up">
                            Learn Real Ways To <br/>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-emerald-500">
                                Make Money Online
                            </span>
                        </h1>
                        <p class="md:text-2xl text-pretty max-w-[650px] mb-12 text-muted-foreground animate-fade-in-up md:mx-0 mx-auto" style="animation-delay: 150ms;">
                            Guides, tools, and strategies to help you start your online hustle.
                        </p>
                        <div class="flex flex-col sm:flex-row justify-center md:justify-start gap-6 animate-fade-in-up" style="animation-delay: 300ms;">
                            <a href="#pathways" class="group relative inline-flex items-center justify-center rounded-xl text-xl font-bold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background bg-primary text-white h-16 px-10 duration-300 hover:scale-[1.03] hover:shadow-[0_0_50px_rgba(79,70,229,0.5)] overflow-hidden">
                                <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-primary-400 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                                <span class="relative z-10 flex items-center gap-3">Start Learning <span class="group-hover:translate-x-2 transition-transform">→</span></span>
                            </a>
                            <a href="#pathways" class="group inline-flex items-center justify-center rounded-xl text-xl font-bold transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 ring-offset-background border-2 border-primary/30 hover:border-primary text-white bg-white/10 backdrop-blur h-16 px-10 duration-300 hover:scale-[1.03] hover:shadow-[0_0_40px_rgba(79,70,229,0.25)]">
                                Choose Path
                            </a>
                        </div>
                    </div>

                    <!-- Logo & Brand (Right Side) -->
                    <div class="flex-1 hidden md:flex flex-col items-center justify-center animate-fade-in-up" style="animation-delay: 450ms;">
                        <div class="relative group cursor-pointer hover:scale-105 transition-transform duration-500">
                            <!-- Glowing background aura -->
                            <div class="absolute inset-0 bg-gradient-to-r from-primary to-emerald-500 rounded-full blur-[80px] opacity-40 group-hover:opacity-60 transition-opacity duration-500"></div>
                            
                            <!-- Full Hero Logo -->
                            <div class="relative flex-shrink-0 mx-auto w-full max-w-[280px] lg:max-w-[380px] aspect-square animate-pulse" style="animation-duration: 4s;">
                                <Image
                                    src={logoImage}
                                    alt="Hustle Teacher Logo - Wealth and Success Icon" 
                                    width={380} 
                                    height={380} 
                                    fetchpriority="high"
                                    loading="eager"
                                    decoding="async" 
                                    class="absolute inset-0 w-full h-full object-contain mix-blend-screen drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]" 
                                />
                            </div>
                        </div>
                    </div>
                </div>
			</section>

            <!-- Trending Methods Section -->
            <TrendingMethods />

            <!-- Popular Guides Section -->
            <PopularGuides />

            <!-- Categories Section -->
            <CategoriesGrid />

            <!-- Popular Platforms Section -->
            <PopularPlatforms />

            <!-- Free Tools Section -->
            <FreeToolsHub />

            <!-- Digital Products Section -->
            <DigitalProducts />

            <!-- Newsletter Section -->
            <section id="newsletter" class="docs-site-container border-x py-24 animate-fade-in-up">
                <NewsletterSignup />
            </section>
	</main>
</BaseLayout>
