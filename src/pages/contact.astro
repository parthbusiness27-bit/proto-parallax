---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_TITLE } from '../consts';
---

<BaseLayout title={`Contact Us | ${SITE_TITLE}`} description="Get in touch with the Hustle Teacher team." theme="dark">
	<main class="flex-grow docs-site-container border-x">
		<section class="py-20 md:py-32 px-4 max-w-2xl mx-auto">
            <div class="mb-12 text-center">
                <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Contact Us</h1>
                <p class="text-xl text-muted-foreground">Have a question? Drop us a line and we'll get back to you as soon as possible.</p>
            </div>
            
            <div class="p-8 bg-card border border-border rounded-2xl shadow-lg">
                <ContactForm />
            </div>
		</section>
	</main>
</BaseLayout>
