---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const allBlog = await getCollection('blog');
const allTools = await getCollection('tools');
const allResources = await getCollection('resources');

// Static pages
const staticPages = [
  { title: 'Home', url: '/', description: 'Homepage' },
  { title: 'About', url: '/about/', description: 'About Hustle Teacher' },
  { title: 'Start Here', url: '/start-here/', description: 'Getting started guide' },
  { title: 'YouTube Mastery', url: '/youtube-mastery/', description: 'YouTube monetization course' },
  { title: 'Tools', url: '/tools/', description: 'Free online tools for creators' },
  { title: 'Resources', url: '/resources/', description: 'Free resources and templates' },
  { title: 'Blog', url: '/blog/', description: 'Latest articles and guides' },
  { title: 'Contact', url: '/contact/', description: 'Get in touch' },
  { title: 'Privacy Policy', url: '/privacy-policy/', description: 'Privacy policy' },
  { title: 'Terms & Conditions', url: '/terms-conditions/', description: 'Terms of service' },
  { title: 'Affiliate Disclosure', url: '/affiliate-disclosure/', description: 'Affiliate disclosure' },
  { title: 'Disclaimer', url: '/disclaimer/', description: 'Website disclaimer' },
];

// Get unique blog categories
const blogCategories = [...new Set(allBlog.map(post => post.data.category))].sort();

// Get unique tool categories
const toolCategories = [...new Set(allTools.map(tool => tool.data.category))].sort();
---

<BaseLayout title={`Sitemap | ${SITE_TITLE}`} description="Complete sitemap of all pages on Hustle Teacher">
  <main class="flex-grow pt-24 pb-12 md:pt-32 md:pb-20 relative overflow-hidden bg-[#030303]">
    <div class="container mx-auto px-4 relative z-10">
      
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Sitemap</h1>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
          Browse all pages and content on Hustle Teacher
        </p>
        <div class="mt-6 flex justify-center gap-4">
          <a 
            href="/sitemap-index.xml"
            class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
            target="_blank"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
            </svg>
            XML Sitemap
          </a>
        </div>
      </div>

      <!-- Static Pages -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">🏠</span> Main Pages
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {staticPages.map(page => (
            <a 
              href={page.url}
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="text-lg font-semibold text-white group-hover:text-blue-400 transition-colors">
                {page.title}
              </h3>
              <p class="text-sm text-gray-400 mt-1">{page.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Blog Categories -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">📚</span> Blog Categories ({blogCategories.length})
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {blogCategories.map(category => (
            <a 
              href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors">
                {category}
              </h3>
              <p class="text-sm text-gray-400 mt-1">
                {allBlog.filter(post => post.data.category === category).length} posts
              </p>
            </a>
          ))}
        </div>
      </section>

      <!-- Tools Categories -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">🛠️</span> Tools Categories ({toolCategories.length})
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {toolCategories.map(category => (
            <a 
              href={`/tools/`}
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors">
                {category}
              </h3>
              <p class="text-sm text-gray-400 mt-1">
                {allTools.filter(tool => tool.data.category === category).length} tools
              </p>
            </a>
          ))}
        </div>
      </section>

      <!-- Popular Blog Posts -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">🔥</span> Popular Articles ({allBlog.length} total)
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {allBlog.slice(0, 24).map(post => (
            <a 
              href={`/blog/${post.id}/`}
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-400 mt-2 line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
        {allBlog.length > 24 && (
          <div class="text-center mt-6">
            <a 
              href="/blog/"
              class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors"
            >
              View All {allBlog.length} Articles →
            </a>
          </div>
        )}
      </section>

      <!-- All Tools -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">⚡</span> All Tools ({allTools.length} total)
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {allTools.map(tool => (
            <a 
              href={tool.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors">
                {tool.data.title}
              </h3>
              <p class="text-sm text-gray-400 mt-1 line-clamp-2">{tool.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Resources -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">📦</span> Free Resources ({allResources.length} total)
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {allResources.map(resource => (
            <a 
              href={resource.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block p-4 rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-600 transition-colors group"
            >
              <h3 class="font-semibold text-white group-hover:text-blue-400 transition-colors">
                {resource.data.title}
              </h3>
              <p class="text-sm text-gray-400 mt-1 line-clamp-2">{resource.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Stats -->
      <section class="mb-12">
        <div class="p-6 rounded-xl bg-gradient-to-br from-blue-900/20 to-purple-900/20 border border-zinc-800">
          <h2 class="text-2xl font-bold text-white mb-4 text-center">Website Statistics</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
            <div>
              <div class="text-3xl font-bold text-blue-400">{staticPages.length}</div>
              <div class="text-gray-400">Pages</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-green-400">{allBlog.length}</div>
              <div class="text-gray-400">Blog Posts</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-yellow-400">{allTools.length}</div>
              <div class="text-gray-400">Tools</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-purple-400">{allResources.length}</div>
              <div class="text-gray-400">Resources</div>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>
