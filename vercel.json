{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "astro",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/blog/freelancing-seo-writing",
      "destination": "/blog/freelancing-seo-writing-guide/",
      "permanent": true
    },
    {
      "source": "/blog/freelancing-seo-writing/",
      "destination": "/blog/freelancing-seo-writing-guide/",
      "permanent": true
    },
    {
      "source": "/guides",
      "destination": "/blog/",
      "permanent": true
    },
    {
      "source": "/guides/content-creator",
      "destination": "/blog/category/content-creation/",
      "permanent": true
    },
    {
      "source": "/guides/side-hustles",
      "destination": "/blog/category/website-businesses/",
      "permanent": true
    },
    {
      "source": "/guides/affiliate",
      "destination": "/blog/category/affiliate-marketing/",
      "permanent": true
    },
    {
      "source": "/guides/virtual-assistant",
      "destination": "/blog/category/virtual-assistance/",
      "permanent": true
    },
    {
      "source": "/guides/ai-income",
      "destination": "/blog/category/ai-services/",
      "permanent": true
    },
    {
      "source": "/guides/:path*",
      "destination": "/blog/category/:path*",
      "permanent": true
    },
    {
      "source": "/blog/category/content-creator",
      "destination": "/blog/category/content-creation/",
      "permanent": true
    },
    {
      "source": "/blog/category/side-hustles",
      "destination": "/blog/category/website-businesses/",
      "permanent": true
    },
    {
      "source": "/blog/category/affiliate",
      "destination": "/blog/category/affiliate-marketing/",
      "permanent": true
    },
    {
      "source": "/blog/category/virtual-assistant",
      "destination": "/blog/category/virtual-assistance/",
      "permanent": true
    },
    {
      "source": "/blog/category/ai-income",
      "destination": "/blog/category/ai-services/",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/tools/ahrefs-generator",
      "destination": "/tools/hashtag-generator/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml"
    }
  ]
}
